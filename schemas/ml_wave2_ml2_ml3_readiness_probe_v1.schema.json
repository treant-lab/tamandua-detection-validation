{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamandua.io/schemas/ml_wave2_ml2_ml3_readiness_probe_v1.schema.json",
  "title": "Tamandua ML Wave 2 ML-2/ML-3 Readiness Probe v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "api_version",
    "kind",
    "metadata",
    "configuration",
    "source",
    "ready_for_ml2_ml3_parity",
    "blockers",
    "checks",
    "operator_sequence"
  ],
  "properties": {
    "api_version": {"const": "tamandua.io/ml-wave2-ml2-ml3-readiness-probe/v1"},
    "kind": {"const": "MLWave2ML2ML3ReadinessProbe"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_id", "generated_at", "created_by", "claim_boundary"],
      "properties": {
        "report_id": {"type": "string", "minLength": 1},
        "generated_at": {"type": "string", "format": "date-time"},
        "created_by": {"type": "string", "minLength": 1},
        "claim_boundary": {"type": "string", "minLength": 10}
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status_ref", "wave2_ml1_readiness_ref", "ml1_report", "model_contract", "onnx_model", "onnx_metadata", "launcher", "data_root"],
      "properties": {
        "status_ref": {"type": "string", "minLength": 1},
        "wave2_ml1_readiness_ref": {"type": "string", "minLength": 1},
        "ml1_report": {"type": "string", "pattern": "ml-prod-candidate-v1-ml1\\.json$"},
        "model_contract": {"type": "string", "pattern": "ml-prod-candidate-v1-model-contract\\.json$"},
        "onnx_model": {"type": "string", "pattern": "ml-prod-candidate-v1-artifacts[\\\\/]malware_smell\\.onnx$"},
        "onnx_metadata": {"type": "string", "pattern": "ml-prod-candidate-v1-artifacts[\\\\/]malware_smell\\.json$"},
        "launcher": {"type": "string", "pattern": "wave_2_ml2_ml3_parity_launcher\\.ps1$"},
        "data_root": {"type": "string", "minLength": 1}
      }
    },
    "ready_for_ml2_ml3_parity": {"type": "boolean"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "execution_status",
        "execution_status_validation",
        "wave2_ml1_readiness",
        "wave2_ml1_readiness_validation",
        "ml1_report",
        "ml1_report_validation",
        "model_contract",
        "ml1_model_contract_validation",
        "onnx_model",
        "onnx_metadata",
        "source_status_summary"
      ],
      "properties": {
        "execution_status": {"type": "string", "pattern": "20260604T-ml-execution-status\\.json$"},
        "execution_status_validation": {"type": "string", "enum": ["jsonschema+built-in", "failed"]},
        "wave2_ml1_readiness": {"type": "string", "pattern": "20260604T-ml-wave2-ml1-readiness-probe\\.json$"},
        "wave2_ml1_readiness_validation": {"type": "string", "enum": ["jsonschema+built-in", "failed"]},
        "ml1_report": {"type": "string", "pattern": "ml-prod-candidate-v1-ml1\\.json$"},
        "ml1_report_validation": {"type": "string", "enum": ["jsonschema+built-in", "failed", "missing"]},
        "model_contract": {"type": "string", "pattern": "ml-prod-candidate-v1-model-contract\\.json$"},
        "ml1_model_contract_validation": {"type": "string", "enum": ["jsonschema+built-in", "failed", "missing"]},
        "onnx_model": {"type": "string", "pattern": "ml-prod-candidate-v1-artifacts[\\\\/]malware_smell\\.onnx$"},
        "onnx_metadata": {"type": "string", "pattern": "ml-prod-candidate-v1-artifacts[\\\\/]malware_smell\\.json$"},
        "source_status_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "goal_complete",
            "completion_state",
            "goal_missing_requirements",
            "goal_required_evidence_total",
            "goal_present_required_evidence",
            "goal_usable_required_evidence",
            "goal_missing_required_evidence",
            "goal_unusable_present_required_evidence",
            "next_unproven_requirement_id",
            "next_unproven_requirement_phase",
            "next_unproven_execute_guard_env",
            "missing_requirement_ids",
            "evidence_status_summary",
            "next_unproven_requirement",
            "wave2_ml1_ready_for_candidate",
            "wave2_ml1_lab_guard_proof_mismatch_count",
            "wave2_ml1_ml_lab_standby_guards_unset",
            "ml1_benchmark_report_present",
            "ml1_model_contract_present",
            "ml1_model_contract_valid",
            "ml1_model_contract_artifact_sha256",
            "ml1_model_contract_artifact_size_bytes",
            "ml1_model_contract_artifact_sha256_matches_onnx",
            "ml1_model_contract_artifact_size_matches_onnx",
            "ml1_model_contract_metadata_sha256",
            "ml1_model_contract_metadata_size_bytes",
            "ml1_model_contract_metadata_sha256_matches_sidecar",
            "ml1_model_contract_metadata_size_matches_sidecar",
            "candidate_onnx_model_present",
            "candidate_onnx_model_nonempty",
            "candidate_onnx_model_size_bytes",
            "candidate_onnx_model_sha256",
            "candidate_onnx_model_canonical_path",
            "candidate_onnx_metadata_present",
            "candidate_onnx_metadata_sha256",
            "candidate_onnx_metadata_contract_ref",
            "candidate_onnx_metadata_model_contract_type",
            "candidate_onnx_metadata_io_names_valid",
            "candidate_onnx_metadata_preprocessing_valid",
            "rustc_version",
            "rustc_minimum_version",
            "rustc_present_for_agent_onnx_parity",
            "rustc_meets_minimum_for_agent_onnx_parity",
            "ort_dylib_path",
            "ort_dylib_version",
            "ort_dylib_minimum_version",
            "ort_dylib_path_configured_for_agent_onnx_parity",
            "ort_dylib_path_exists_for_agent_onnx_parity",
            "ort_dylib_path_is_dll_for_agent_onnx_parity",
            "ort_dylib_meets_minimum_for_agent_onnx_parity",
            "ml2_ml3_launcher_exists",
            "data_root_outside_repo",
            "required_input_count",
            "required_inputs_present",
            "blocker_count",
            "blockers"
          ],
          "properties": {
            "goal_complete": {"type": "boolean"},
            "completion_state": {"enum": ["not_executed", "partial_evidence", "complete"]},
            "goal_missing_requirements": {"type": "integer", "minimum": 0},
            "goal_required_evidence_total": {"type": "integer", "minimum": 0},
            "goal_present_required_evidence": {"type": "integer", "minimum": 0},
            "goal_usable_required_evidence": {"type": "integer", "minimum": 0},
            "goal_missing_required_evidence": {"type": "integer", "minimum": 0},
            "goal_unusable_present_required_evidence": {"type": "integer", "minimum": 0},
            "next_unproven_requirement_id": {"type": "string"},
            "next_unproven_requirement_phase": {"type": "string"},
            "next_unproven_execute_guard_env": {"type": "string"},
            "missing_requirement_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
            "evidence_status_summary": {"type": "object"},
            "next_unproven_requirement": {"type": "object"},
            "wave2_ml1_ready_for_candidate": {"type": "boolean"},
            "wave2_ml1_lab_guard_proof_mismatch_count": {"type": "integer", "minimum": 0},
            "wave2_ml1_ml_lab_standby_guards_unset": {"type": "boolean"},
            "ml1_benchmark_report_present": {"type": "boolean"},
            "ml1_model_contract_present": {"type": "boolean"},
            "ml1_model_contract_valid": {"type": "boolean"},
            "ml1_model_contract_artifact_sha256": {"type": "string", "pattern": "^([a-f0-9]{64})?$"},
            "ml1_model_contract_artifact_size_bytes": {"type": "integer", "minimum": 0},
            "ml1_model_contract_artifact_sha256_matches_onnx": {"type": "boolean"},
            "ml1_model_contract_artifact_size_matches_onnx": {"type": "boolean"},
            "ml1_model_contract_metadata_sha256": {"type": "string", "pattern": "^([a-f0-9]{64})?$"},
            "ml1_model_contract_metadata_size_bytes": {"type": "integer", "minimum": 0},
            "ml1_model_contract_metadata_sha256_matches_sidecar": {"type": "boolean"},
            "ml1_model_contract_metadata_size_matches_sidecar": {"type": "boolean"},
            "candidate_onnx_model_present": {"type": "boolean"},
            "candidate_onnx_model_nonempty": {"type": "boolean"},
            "candidate_onnx_model_size_bytes": {"type": "integer", "minimum": 0},
            "candidate_onnx_model_sha256": {"type": "string", "pattern": "^([a-f0-9]{64})?$"},
            "candidate_onnx_model_canonical_path": {"type": "boolean"},
            "candidate_onnx_metadata_present": {"type": "boolean"},
            "candidate_onnx_metadata_sha256": {"type": "string", "pattern": "^([a-f0-9]{64})?$"},
            "candidate_onnx_metadata_contract_ref": {"type": "string"},
            "candidate_onnx_metadata_model_contract_type": {"type": "string"},
            "candidate_onnx_metadata_io_names_valid": {"type": "boolean"},
            "candidate_onnx_metadata_preprocessing_valid": {"type": "boolean"},
            "rustc_version": {"type": ["string", "null"]},
            "rustc_minimum_version": {"const": "1.88.0"},
            "rustc_present_for_agent_onnx_parity": {"type": "boolean"},
            "rustc_meets_minimum_for_agent_onnx_parity": {"type": "boolean"},
            "ort_dylib_path": {"type": "string"},
            "ort_dylib_version": {"type": ["string", "null"]},
            "ort_dylib_minimum_version": {"const": "1.23.0"},
            "ort_dylib_path_configured_for_agent_onnx_parity": {"type": "boolean"},
            "ort_dylib_path_exists_for_agent_onnx_parity": {"type": "boolean"},
            "ort_dylib_path_is_dll_for_agent_onnx_parity": {"type": "boolean"},
            "ort_dylib_meets_minimum_for_agent_onnx_parity": {"type": "boolean"},
            "ml2_ml3_launcher_exists": {"type": "boolean"},
            "data_root_outside_repo": {"type": "boolean"},
            "required_input_count": {"type": "integer", "minimum": 0},
            "required_inputs_present": {"type": "integer", "minimum": 0},
            "blocker_count": {"type": "integer", "minimum": 0},
            "blockers": {"type": "array", "items": {"type": "string", "minLength": 1}}
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "passed", "detail"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "passed": {"type": "boolean"},
          "detail": {"type": "string"}
        }
      }
    },
    "operator_sequence": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step", "mode", "command", "claim_boundary"],
        "properties": {
          "step": {"type": "integer", "minimum": 1},
          "mode": {"type": "string", "enum": ["validation_only", "execute"]},
          "required_env": {
            "type": "object",
            "additionalProperties": {"type": "string"}
          },
          "guard_set_command": {"type": "string", "minLength": 1},
          "command": {"type": "string", "minLength": 1},
          "guard_cleanup_command": {"type": "string", "minLength": 1},
          "claim_boundary": {"type": "string", "minLength": 10}
        }
      }
    }
  }
}
