{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamandua.io/schemas/ml_wave1_lab_transcript_template_v1.schema.json",
  "title": "Tamandua ML Wave 1 Lab Transcript Template v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["api_version", "kind", "metadata", "configuration", "template", "required_fields", "required_fields_sha256", "hash_verification", "capture_helper", "log_policy", "vx_policy", "operator_instructions", "output_path", "source_validation"],
  "properties": {
    "api_version": {"const": "tamandua.io/ml-wave1-lab-transcript-template/v1"},
    "kind": {"const": "MLWave1LabTranscriptTemplate"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_id", "generated_at", "created_by", "claim_boundary"],
      "properties": {
        "report_id": {"type": "string", "minLength": 1},
        "generated_at": {"type": "string", "format": "date-time"},
        "created_by": {"type": "string", "minLength": 1},
        "claim_boundary": {"type": "string", "minLength": 10}
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["execution_packet", "guarded_run_command_packet", "lab_run_intake", "transcript_output"],
      "properties": {
        "execution_packet": {"type": "string", "pattern": "20260604T-ml-wave1-execution-packet\\.json$"},
        "guarded_run_command_packet": {"type": "string", "pattern": "20260604T-ml-wave1-guarded-run-command-packet\\.json$"},
        "lab_run_intake": {"type": "string", "pattern": "20260604T-ml-wave1-lab-run-intake\\.json$"},
        "transcript_output": {"type": "string", "pattern": "20260604T-ml-wave1-real-acquisition-transcript\\.json$"}
      }
    },
    "template": {
      "type": "object",
      "additionalProperties": false,
      "required": ["api_version", "kind", "metadata", "command", "launcher_ref", "launcher_sha256", "acquisition_command", "acquisition_command_sha256", "guarded_run_command_packet_ref", "guarded_run_command_packet_sha256", "started_at", "finished_at", "returncode", "stdout_ref", "stdout_sha256", "stderr_ref", "stderr_sha256", "published_logs_are_sanitized", "hashes_cover_published_sanitized_logs", "sanitization_rules_sha256", "operator", "lab_host", "data_root_ref", "data_root_outside_repo", "guard_env", "vx_policy"],
      "properties": {
        "api_version": {"const": "tamandua.io/ml-wave1-acquisition-transcript/v1"},
        "kind": {"const": "MLWave1AcquisitionTranscript"},
        "metadata": {
          "type": "object",
          "additionalProperties": false,
          "required": ["report_id", "created_by", "claim_boundary"],
          "properties": {
            "report_id": {"type": "string", "minLength": 1},
            "created_by": {"type": "string", "minLength": 1},
            "claim_boundary": {"type": "string", "minLength": 10}
          }
        },
        "command": {"type": "string", "minLength": 1},
        "launcher_ref": {"type": "string", "pattern": "20260604T-ml-execution-plan\\.handoff.*wave_1_real_acquisition_launcher\\.ps1$"},
        "launcher_sha256": {"type": "string", "minLength": 1},
        "acquisition_command": {"type": "string", "minLength": 1},
        "acquisition_command_sha256": {"type": "string", "minLength": 1},
        "guarded_run_command_packet_ref": {"type": "string", "pattern": "20260604T-ml-wave1-guarded-run-command-packet\\.json$"},
        "guarded_run_command_packet_sha256": {"type": "string", "minLength": 1},
        "started_at": {"type": "string", "minLength": 1},
        "finished_at": {"type": "string", "minLength": 1},
        "returncode": {"type": ["integer", "string"]},
        "stdout_ref": {"type": "string"},
        "stdout_sha256": {"type": "string", "minLength": 1},
        "stderr_ref": {"type": "string"},
        "stderr_sha256": {"type": "string", "minLength": 1},
        "published_logs_are_sanitized": {"const": true},
        "hashes_cover_published_sanitized_logs": {"const": true},
        "sanitization_rules_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "operator": {"type": "string", "minLength": 1},
        "lab_host": {"type": "string", "minLength": 1},
        "data_root_ref": {"type": "string", "pattern": "^external://"},
        "data_root_outside_repo": {"const": true},
        "guard_env": {
          "type": "object",
          "additionalProperties": {"type": "string"},
          "required": ["TAMANDUA_ALLOW_ML_REAL_ACQUISITION"],
          "properties": {
            "TAMANDUA_ALLOW_ML_REAL_ACQUISITION": {"type": "string", "minLength": 1}
          }
        },
        "vx_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "vx_inventory_ref",
            "vx_inventory_metadata_only",
            "vx_samples_in_training_splits",
            "vx_archive_download_guard_env",
            "vx_archive_download_guard_must_be_unset",
            "operator_note"
          ],
          "properties": {
            "vx_inventory_ref": {"type": "string", "pattern": "ml-vx-inthewild-inventory\\.json$"},
            "vx_inventory_metadata_only": {"const": true},
            "vx_samples_in_training_splits": {"const": false},
            "vx_archive_download_guard_env": {"const": "TAMANDUA_ALLOW_VX_UNDERGROUND_DOWNLOAD"},
            "vx_archive_download_guard_must_be_unset": {"const": true},
            "operator_note": {"type": "string", "pattern": "metadata-only"}
          }
        }
      }
    },
    "required_fields": {
      "type": "array",
      "minItems": 10,
      "items": {"type": "string", "minLength": 1}
    },
    "required_fields_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "hash_verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "hex_format", "acquisition_command_encoding", "file_fields", "powershell_commands"],
      "properties": {
        "algorithm": {"const": "SHA256"},
        "hex_format": {"const": "lowercase"},
        "acquisition_command_encoding": {"const": "UTF-8"},
        "file_fields": {
          "type": "object",
          "additionalProperties": false,
          "required": ["launcher_sha256", "guarded_run_command_packet_sha256", "stdout_sha256", "stderr_sha256"],
          "properties": {
            "launcher_sha256": {"type": "string", "pattern": "20260604T-ml-execution-plan\\.handoff.*wave_1_real_acquisition_launcher\\.ps1$"},
            "guarded_run_command_packet_sha256": {"type": "string", "pattern": "20260604T-ml-wave1-guarded-run-command-packet\\.json$"},
            "stdout_sha256": {"type": "string", "pattern": "20260604T-ml-wave1-real-acquisition\\.stdout\\.txt$"},
            "stderr_sha256": {"type": "string", "pattern": "20260604T-ml-wave1-real-acquisition\\.stderr\\.txt$"}
          }
        },
        "powershell_commands": {
          "type": "array",
          "minItems": 5,
          "items": {"type": "string", "minLength": 10}
        }
      }
    },
    "operator_instructions": {
      "type": "array",
      "minItems": 3,
      "items": {"type": "string", "minLength": 5}
    },
    "capture_helper": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "shell",
        "mode",
        "claim_boundary",
        "requires_guard_env",
        "requires_vx_download_guard_unset",
        "raw_stdout_ref",
        "raw_stderr_ref",
        "published_stdout_ref",
        "published_stderr_ref",
        "commands"
      ],
      "properties": {
        "shell": {"const": "powershell"},
        "mode": {"const": "operator_copy_paste"},
        "claim_boundary": {"type": "string", "pattern": "not executed"},
        "requires_guard_env": {"const": "TAMANDUA_ALLOW_ML_REAL_ACQUISITION"},
        "requires_vx_download_guard_unset": {"const": "TAMANDUA_ALLOW_VX_UNDERGROUND_DOWNLOAD"},
        "raw_stdout_ref": {"type": "string", "pattern": "^external://.*\\.raw\\.stdout\\.txt$"},
        "raw_stderr_ref": {"type": "string", "pattern": "^external://.*\\.raw\\.stderr\\.txt$"},
        "published_stdout_ref": {"type": "string", "pattern": "20260604T-ml-wave1-real-acquisition\\.stdout\\.txt$"},
        "published_stderr_ref": {"type": "string", "pattern": "20260604T-ml-wave1-real-acquisition\\.stderr\\.txt$"},
        "commands": {
          "type": "array",
          "minItems": 12,
          "items": {"type": "string", "minLength": 5}
        }
      }
    },
    "log_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_log_root",
        "raw_stdout_ref",
        "raw_stderr_ref",
        "published_stdout_ref",
        "published_stderr_ref",
        "published_logs_are_sanitized",
        "hashes_cover_published_sanitized_logs",
        "sanitization_rules",
        "sanitization_rules_sha256",
        "forbidden_published_log_content"
      ],
      "properties": {
        "raw_log_root": {"type": "string", "pattern": "^external://.*/logs/wave1$"},
        "raw_stdout_ref": {"type": "string", "pattern": "^external://.*\\.raw\\.stdout\\.txt$"},
        "raw_stderr_ref": {"type": "string", "pattern": "^external://.*\\.raw\\.stderr\\.txt$"},
        "published_stdout_ref": {"type": "string", "pattern": "20260604T-ml-wave1-real-acquisition\\.stdout\\.txt$"},
        "published_stderr_ref": {"type": "string", "pattern": "20260604T-ml-wave1-real-acquisition\\.stderr\\.txt$"},
        "published_logs_are_sanitized": {"const": true},
        "hashes_cover_published_sanitized_logs": {"const": true},
        "sanitization_rules": {
          "type": "array",
          "minItems": 4,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "sanitization_rules_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "forbidden_published_log_content": {
          "type": "array",
          "minItems": 3,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      }
    },
    "vx_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vx_inventory_ref",
        "vx_inventory_metadata_only",
        "vx_samples_in_training_splits",
        "vx_archive_download_guard_env",
        "vx_archive_download_guard_must_be_unset",
        "operator_note"
      ],
      "properties": {
        "vx_inventory_ref": {"type": "string", "pattern": "ml-vx-inthewild-inventory\\.json$"},
        "vx_inventory_metadata_only": {"const": true},
        "vx_samples_in_training_splits": {"const": false},
        "vx_archive_download_guard_env": {"const": "TAMANDUA_ALLOW_VX_UNDERGROUND_DOWNLOAD"},
        "vx_archive_download_guard_must_be_unset": {"const": true},
        "operator_note": {"type": "string", "pattern": "metadata-only"}
      }
    },
    "output_path": {"type": "string", "pattern": "20260604T-ml-wave1-real-acquisition-transcript\\.json$"},
    "source_validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["execution_packet", "guarded_run_command_packet", "lab_run_intake", "source_status_summary"],
      "properties": {
        "execution_packet": {"enum": ["jsonschema+built-in", "built-in"]},
        "guarded_run_command_packet": {"enum": ["jsonschema+built-in", "built-in"]},
        "lab_run_intake": {"enum": ["jsonschema", "schema-unavailable"]},
        "source_status_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "execution_packet_safe_to_operator",
            "guarded_run_command_packet_ready",
            "guarded_run_command_packet_acquisition_command_matches_template",
            "template_ready_for_operator_execution",
            "lab_run_intake_ready_for_post_acquisition_refresh",
            "lab_run_intake_blockers",
            "required_transcript_fields",
            "required_transcript_field_names",
            "required_transcript_fields_sha256",
            "intake_required_transcript_fields_sha256",
            "template_field_count",
            "template_field_names",
            "template_fields_sha256",
            "hash_verification_algorithm",
            "hash_verification_command_count",
            "capture_helper_shell",
            "capture_helper_command_count",
            "capture_helper_requires_guard_env",
            "capture_helper_requires_vx_download_guard_unset",
            "capture_helper_published_stdout_ref",
            "capture_helper_published_stderr_ref",
            "published_logs_are_sanitized",
            "hashes_cover_published_sanitized_logs",
            "sanitization_rules_sha256",
            "sanitization_rule_count",
            "forbidden_published_log_content_count",
            "operator_instruction_count",
            "output_path",
            "execute_guard_env"
          ],
          "properties": {
            "execution_packet_safe_to_operator": {"type": "boolean"},
            "guarded_run_command_packet_ready": {"type": "boolean"},
            "guarded_run_command_packet_acquisition_command_matches_template": {"type": "boolean"},
            "template_ready_for_operator_execution": {"type": "boolean"},
            "lab_run_intake_ready_for_post_acquisition_refresh": {"type": "boolean"},
            "lab_run_intake_blockers": {
              "type": "array",
              "items": {"type": "string", "minLength": 1},
              "uniqueItems": true
            },
            "required_transcript_fields": {"type": "integer", "minimum": 1},
            "required_transcript_field_names": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string", "minLength": 1},
              "uniqueItems": true
            },
            "required_transcript_fields_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
            "intake_required_transcript_fields_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
            "template_field_count": {"type": "integer", "minimum": 1},
            "template_field_names": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string", "minLength": 1},
              "uniqueItems": true
            },
            "template_fields_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
            "hash_verification_algorithm": {"const": "SHA256"},
            "hash_verification_command_count": {"type": "integer", "minimum": 5},
            "capture_helper_shell": {"const": "powershell"},
            "capture_helper_command_count": {"type": "integer", "minimum": 16},
            "capture_helper_requires_guard_env": {"const": "TAMANDUA_ALLOW_ML_REAL_ACQUISITION"},
            "capture_helper_requires_vx_download_guard_unset": {"const": "TAMANDUA_ALLOW_VX_UNDERGROUND_DOWNLOAD"},
            "capture_helper_published_stdout_ref": {"type": "string", "pattern": "20260604T-ml-wave1-real-acquisition\\.stdout\\.txt$"},
            "capture_helper_published_stderr_ref": {"type": "string", "pattern": "20260604T-ml-wave1-real-acquisition\\.stderr\\.txt$"},
            "published_logs_are_sanitized": {"const": true},
            "hashes_cover_published_sanitized_logs": {"const": true},
            "sanitization_rules_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
            "sanitization_rule_count": {"type": "integer", "minimum": 4},
            "forbidden_published_log_content_count": {"type": "integer", "minimum": 3},
            "operator_instruction_count": {"type": "integer", "minimum": 1},
            "output_path": {"type": "string", "pattern": "20260604T-ml-wave1-real-acquisition-transcript\\.json$"},
            "execute_guard_env": {"const": "1"},
            "goal_complete": {"const": false},
            "next_unproven_requirement_id": {"type": "string", "minLength": 1}
          }
        }
      }
    }
  }
}
