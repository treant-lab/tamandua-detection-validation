{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamandua.io/schemas/ml_benchmark_unblock_handoff_bundle_v1.schema.json",
  "title": "Tamandua ML Benchmark Unblock Handoff Bundle v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["api_version", "kind", "metadata", "source", "output_dir", "readme", "summary", "handoff_files"],
  "properties": {
    "api_version": {"const": "tamandua.io/ml-benchmark-unblock-handoff-bundle/v1"},
    "kind": {"const": "MLBenchmarkUnblockHandoffBundle"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_id", "generated_at", "created_by", "claim_boundary"],
      "properties": {
        "report_id": {"type": "string", "minLength": 1},
        "generated_at": {"type": "string", "format": "date-time"},
        "created_by": {"type": "string", "minLength": 1},
        "claim_boundary": {"type": "string", "minLength": 10}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["benchmark_unblock_queue", "benchmark_unblock_queue_validation", "source_queue_summary", "source_status_summary"],
      "properties": {
        "benchmark_unblock_queue": {"type": "string", "pattern": "20260604T-ml-benchmark-unblock-queue\\.json$"},
        "benchmark_unblock_queue_validation": {"enum": ["jsonschema+built-in", "built-in"]},
        "source_queue_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["queue_items", "queue_item_ids"],
          "properties": {
            "queue_items": {"type": "integer", "minimum": 0},
            "queue_item_ids": {
              "type": "array",
              "items": {"type": "string", "pattern": "^ml-benchmark-unblock-[0-9]{3}$"}
            }
          }
        },
        "source_status_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "benchmark_unblock_queue_validated",
            "source_queue_items",
            "source_queue_item_ids",
            "readme_written",
            "handoff_files_written",
            "dependency",
            "artifact",
            "env",
            "other",
            "validation_command_count",
            "validation_only_commands",
            "wave1_evidence_items",
            "upstream_ready_validation_only",
            "upstream_blocked",
            "items_with_resolution_command_exposure",
            "items_without_resolution_command_exposure",
            "goal_complete",
            "completion_state",
            "goal_snapshot_anchor_check_passed",
            "goal_missing_requirements",
            "goal_required_evidence_total",
            "goal_present_required_evidence",
            "goal_usable_required_evidence",
            "goal_missing_required_evidence",
            "goal_unusable_present_required_evidence",
            "next_unproven_requirement_id",
            "next_unproven_requirement_phase",
            "next_unproven_execute_guard_env",
            "missing_requirement_ids",
            "evidence_status_summary",
            "next_unproven_requirement"
          ],
          "properties": {
            "benchmark_unblock_queue_validated": {"type": "boolean"},
            "source_queue_items": {"type": "integer", "minimum": 0},
            "source_queue_item_ids": {
              "type": "array",
              "items": {"type": "string", "pattern": "^ml-benchmark-unblock-[0-9]{3}$"}
            },
            "readme_written": {"type": "boolean"},
            "handoff_files_written": {"type": "integer", "minimum": 0},
            "dependency": {"type": "integer", "minimum": 0},
            "artifact": {"type": "integer", "minimum": 0},
            "env": {"type": "integer", "minimum": 0},
            "other": {"type": "integer", "minimum": 0},
            "validation_command_count": {"type": "integer", "minimum": 0},
            "validation_only_commands": {"type": "integer", "minimum": 0},
            "wave1_evidence_items": {"type": "integer", "minimum": 0},
            "upstream_ready_validation_only": {"type": "integer", "minimum": 0},
            "upstream_blocked": {"type": "integer", "minimum": 0},
            "items_with_resolution_command_exposure": {"type": "integer", "minimum": 0},
            "items_without_resolution_command_exposure": {"type": "integer", "minimum": 0},
            "goal_complete": {"type": "boolean"},
            "completion_state": {"enum": ["partial_evidence", "complete"]},
            "goal_snapshot_anchor_check_passed": {"const": true},
            "goal_missing_requirements": {"type": "integer", "minimum": 0},
            "goal_required_evidence_total": {"type": "integer", "minimum": 0},
            "goal_present_required_evidence": {"type": "integer", "minimum": 0},
            "goal_usable_required_evidence": {"type": "integer", "minimum": 0},
            "goal_missing_required_evidence": {"type": "integer", "minimum": 0},
            "goal_unusable_present_required_evidence": {"type": "integer", "minimum": 0},
            "next_unproven_requirement_id": {"type": "string", "minLength": 1},
            "next_unproven_requirement_phase": {"type": "string", "minLength": 1},
            "next_unproven_execute_guard_env": {"type": "string", "minLength": 1},
            "missing_requirement_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
            "evidence_status_summary": {"type": "object"},
            "next_unproven_requirement": {"type": "object"}
          }
        }
      }
    },
    "output_dir": {"type": "string", "pattern": "20260604T-ml-benchmark-unblock-queue\\.handoff$"},
    "readme": {"type": "string", "pattern": "20260604T-ml-benchmark-unblock-queue\\.handoff/README\\.md$"},
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_handoff_files",
        "dependency",
        "artifact",
        "env",
        "other",
        "upstream_ready_validation_only",
        "upstream_blocked",
        "validation_command_count",
        "validation_only_commands",
        "items_with_resolution_command_exposure",
        "items_without_resolution_command_exposure",
        "goal_complete",
        "completion_state",
        "goal_snapshot_anchor_check_passed",
        "goal_usable_required_evidence",
        "goal_required_evidence_total",
        "next_unproven_requirement_id",
        "next_unproven_execute_guard_env"
      ],
      "properties": {
        "total_handoff_files": {"type": "integer", "minimum": 1},
        "dependency": {"type": "integer", "minimum": 0},
        "artifact": {"type": "integer", "minimum": 0},
        "env": {"type": "integer", "minimum": 0},
        "other": {"type": "integer", "minimum": 0},
        "upstream_ready_validation_only": {"type": "integer", "minimum": 0},
        "upstream_blocked": {"type": "integer", "minimum": 0},
        "validation_command_count": {"type": "integer", "minimum": 0},
        "validation_only_commands": {"type": "integer", "minimum": 0},
        "items_with_resolution_command_exposure": {"type": "integer", "minimum": 0},
        "items_without_resolution_command_exposure": {"type": "integer", "minimum": 0},
        "goal_complete": {"type": "boolean"},
        "completion_state": {"enum": ["partial_evidence", "complete"]},
        "goal_snapshot_anchor_check_passed": {"const": true},
        "goal_usable_required_evidence": {"type": "integer", "minimum": 0},
        "goal_required_evidence_total": {"type": "integer", "minimum": 0},
        "next_unproven_requirement_id": {"type": "string", "minLength": 1},
        "next_unproven_execute_guard_env": {"type": "string", "minLength": 1}
      }
    },
    "handoff_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["unblock_id", "lane_id", "scope", "parallel_group", "category", "target", "priority", "path", "expected_evidence", "validation_command", "validation_command_sha256", "readiness_evidence_paths"],
        "properties": {
          "unblock_id": {"type": "string", "pattern": "^ml-benchmark-unblock-[0-9]{3}$"},
          "lane_id": {"enum": ["ML-1", "ML-2", "ML-3", "ML-4", "ML-5", "ML-6"]},
          "scope": {"enum": ["isolated_model", "onnx_parity", "agent_local", "service_api", "platform_replay", "cross_time_holdout"]},
          "parallel_group": {"type": "string", "minLength": 1},
          "category": {"enum": ["dependency", "artifact", "env", "other"]},
          "target": {"type": "string", "minLength": 1},
          "priority": {"type": "integer", "minimum": 1},
          "path": {"type": "string", "pattern": "20260604T-ml-benchmark-unblock-queue\\.handoff/.+\\.md$"},
          "expected_evidence": {"type": "string", "minLength": 10},
          "validation_command": {"type": "string", "minLength": 10},
          "validation_command_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "readiness_evidence_paths": {"type": "array", "items": {"type": "string", "minLength": 1}}
        }
      }
    }
  }
}
