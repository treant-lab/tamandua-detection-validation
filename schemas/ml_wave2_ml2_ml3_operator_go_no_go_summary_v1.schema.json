{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamandua.io/schemas/ml_wave2_ml2_ml3_operator_go_no_go_summary_v1.schema.json",
  "title": "Tamandua ML Wave 2 ML-2/ML-3 Operator Go/No-Go Summary v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "api_version",
    "kind",
    "metadata",
    "source",
    "source_artifact_hashes",
    "operator_decision",
    "agent_smoke_context",
    "source_status_summary",
    "operator_sequence",
    "checks"
  ],
  "properties": {
    "api_version": {"const": "tamandua.io/ml-wave2-ml2-ml3-operator-go-no-go-summary/v1"},
    "kind": {"const": "MLWave2ML2ML3OperatorGoNoGoSummary"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_id", "generated_at", "created_by", "claim_boundary"],
      "properties": {
        "report_id": {"type": "string", "minLength": 1},
        "generated_at": {"type": "string", "format": "date-time"},
        "created_by": {"type": "string", "minLength": 1},
        "claim_boundary": {"type": "string", "minLength": 10}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wave1_acceptance_checklist",
        "wave1_acceptance_checklist_validation",
        "wave2_ml2_ml3_readiness",
        "wave2_ml2_ml3_readiness_validation"
      ],
      "properties": {
        "wave1_acceptance_checklist": {"type": "string", "pattern": "20260604T-ml-wave1-acceptance-checklist\\.json$"},
        "wave1_acceptance_checklist_validation": {"enum": ["jsonschema+built-in", "built-in"]},
        "wave2_ml2_ml3_readiness": {"type": "string", "pattern": "(20260604T-ml-wave2-ml2-ml3-readiness-probe|20260620T-ml-wave2-ml2-ml3-readiness-post-secret-hardening|20260620T2105Z-ml-wave2-ml2-ml3-readiness-ml1-packets|(20260621T-ml-wave2-ml2-ml3-readiness-post-onnx-runtime|20260621T-ml-wave2-ml2-ml3-readiness-post-win-template-gate-threading))\\.json$"},
        "wave2_ml2_ml3_readiness_validation": {"enum": ["jsonschema+built-in", "built-in"]},
        "ml3_agent_smoke_report": {"type": "string", "pattern": "(20260620T-ml3-agent-parity-with-win-template|20260621T-ml3-agent-onnx-parity-smoke-post-staging-clean|20260621T-ml3-agent-parity-with-win-template-local-inference|missing)\\.json$"},
        "ml3_agent_smoke_report_validation": {"enum": ["jsonschema+built-in", "built-in", "missing"]}
      }
    },
    "source_artifact_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wave1_acceptance_checklist",
        "wave2_ml2_ml3_readiness"
      ],
      "properties": {
        "wave1_acceptance_checklist": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": {"type": "string", "pattern": "20260604T-ml-wave1-acceptance-checklist\\.json$"},
            "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
          }
        },
        "wave2_ml2_ml3_readiness": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": {"type": "string", "pattern": "(20260604T-ml-wave2-ml2-ml3-readiness-probe|20260620T-ml-wave2-ml2-ml3-readiness-post-secret-hardening|20260620T2105Z-ml-wave2-ml2-ml3-readiness-ml1-packets|(20260621T-ml-wave2-ml2-ml3-readiness-post-onnx-runtime|20260621T-ml-wave2-ml2-ml3-readiness-post-win-template-gate-threading))\\.json$"},
            "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
          }
        },
        "ml3_agent_smoke_report": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": {"type": "string", "pattern": "(20260620T-ml3-agent-parity-with-win-template|20260621T-ml3-agent-onnx-parity-smoke-post-staging-clean|20260621T-ml3-agent-parity-with-win-template-local-inference)\\.json$"},
            "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
          }
        }
      }
    },
    "operator_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ready_for_ml2_ml3_parity_go_no_go",
        "decision",
        "validation_command",
        "execute_command",
        "execute_guard_env",
        "ml1_report",
        "onnx_model",
        "data_root",
        "authorization_inputs_sha256",
        "no_execution_claim_boundary"
      ],
      "properties": {
        "ready_for_ml2_ml3_parity_go_no_go": {"type": "boolean"},
        "decision": {"enum": ["go_for_guarded_ml2_ml3_parity", "no_go"]},
        "validation_command": {"type": "string", "pattern": "wave_2_ml2_ml3_parity_launcher\\.ps1'?$"},
        "execute_command": {"type": "string", "pattern": "wave_2_ml2_ml3_parity_launcher\\.ps1'? -Execute$"},
        "execute_guard_env": {"const": "TAMANDUA_ALLOW_ML_PARITY"},
        "ml1_report": {"type": "string", "pattern": "ml-prod-candidate-v1-ml1\\.json$"},
        "onnx_model": {"type": "string", "pattern": "malware_smell\\.onnx$"},
        "data_root": {"type": "string", "minLength": 1},
        "authorization_inputs_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "no_execution_claim_boundary": {"type": "string", "minLength": 10}
      }
    },
    "agent_smoke_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "present",
        "validation",
        "path",
        "smoke_agent_side_evidence_present",
        "smoke_agent_side_evidence_valid",
        "smoke_agent_side_evidence_quality_gate_passed",
        "smoke_agent_side_evidence_win_template_attached",
        "smoke_agent_side_evidence_unblocks_production",
        "claim_boundary"
      ],
      "properties": {
        "present": {"type": "boolean"},
        "validation": {"enum": ["jsonschema+built-in", "built-in", "missing"]},
        "path": {"type": "string", "minLength": 1},
        "lane": {"type": "string"},
        "model_version": {"type": "string"},
        "dataset_id": {"type": "string"},
        "sample_count": {"type": "integer", "minimum": 0},
        "verdict_agreement": {"type": ["number", "null"]},
        "confidence_delta_p95": {"type": ["number", "null"]},
        "quality_gate_status": {"type": "string"},
        "smoke_agent_side_evidence_present": {"type": "boolean"},
        "smoke_agent_side_evidence_valid": {"type": "boolean"},
        "smoke_agent_side_evidence_quality_gate_passed": {"type": "boolean"},
        "smoke_agent_side_evidence_win_template_attached": {"type": "boolean"},
        "smoke_agent_side_evidence_unblocks_production": {"const": false},
        "win_template_local_inference_status": {"type": "string"},
        "win_template_false_positive_candidate_count": {"type": "integer", "minimum": 0},
        "win_template_false_positive_candidate_sample_ids": {"type": "array", "items": {"type": "string"}},
        "win_template_production_gate_impact": {"type": "string"},
        "claim_boundary": {"type": "string", "minLength": 10},
        "production_boundary_reason": {"type": "string", "minLength": 10}
      }
    },
    "source_status_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ready_for_ml2_ml3_parity_go_no_go",
        "check_count",
        "passed_checks",
        "failed_checks",
        "ready_for_ml2_ml3_parity",
        "wave2_ml1_ready_for_candidate",
        "ml1_benchmark_report_present",
        "candidate_onnx_model_present",
        "candidate_onnx_model_nonempty",
        "rustc_version",
        "rustc_minimum_version",
        "rustc_present_for_agent_onnx_parity",
        "rustc_meets_minimum_for_agent_onnx_parity",
        "ml2_ml3_launcher_exists",
        "required_inputs_present",
        "required_input_count",
        "data_root_outside_repo",
        "validation_command_no_execute",
        "execute_command_has_execute",
        "execute_guard_env",
        "guard_set_command",
        "guard_cleanup_command",
        "operator_guard_commands_preserved",
        "operator_sequence_steps",
        "blocker_count",
        "blockers",
        "agent_smoke_evidence_present",
        "agent_smoke_evidence_valid",
        "agent_smoke_evidence_quality_gate_passed",
        "agent_smoke_evidence_win_template_attached",
        "agent_smoke_evidence_unblocks_production",
        "goal_complete",
        "completion_state",
        "goal_missing_requirements",
        "goal_required_evidence_total",
        "goal_present_required_evidence",
        "goal_usable_required_evidence",
        "goal_missing_required_evidence",
        "goal_unusable_present_required_evidence",
        "next_unproven_requirement_id",
        "next_unproven_requirement_phase",
        "next_unproven_execute_guard_env",
        "evidence_status_summary",
        "next_unproven_requirement"
      ],
      "properties": {
        "ready_for_ml2_ml3_parity_go_no_go": {"type": "boolean"},
        "check_count": {"type": "integer", "minimum": 1},
        "passed_checks": {"type": "integer", "minimum": 0},
        "failed_checks": {"type": "integer", "minimum": 0},
        "ready_for_ml2_ml3_parity": {"type": "boolean"},
        "wave2_ml1_ready_for_candidate": {"type": "boolean"},
        "ml1_benchmark_report_present": {"type": "boolean"},
        "candidate_onnx_model_present": {"type": "boolean"},
        "candidate_onnx_model_nonempty": {"type": "boolean"},
        "rustc_version": {"type": ["string", "null"]},
        "rustc_minimum_version": {"const": "1.88.0"},
        "rustc_present_for_agent_onnx_parity": {"type": "boolean"},
        "rustc_meets_minimum_for_agent_onnx_parity": {"type": "boolean"},
        "ml2_ml3_launcher_exists": {"type": "boolean"},
        "required_inputs_present": {"type": "integer", "minimum": 0},
        "required_input_count": {"type": "integer", "minimum": 0},
        "data_root_outside_repo": {"type": "boolean"},
        "validation_command_no_execute": {"type": "boolean"},
        "execute_command_has_execute": {"type": "boolean"},
        "execute_guard_env": {"const": "TAMANDUA_ALLOW_ML_PARITY"},
        "guard_set_command": {"const": "$env:TAMANDUA_ALLOW_ML_PARITY = '1'"},
        "guard_cleanup_command": {"const": "Remove-Item Env:TAMANDUA_ALLOW_ML_PARITY -ErrorAction SilentlyContinue"},
        "operator_guard_commands_preserved": {"const": true},
        "operator_sequence_steps": {"const": 2},
        "blocker_count": {"type": "integer", "minimum": 0},
        "blockers": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "agent_smoke_evidence_present": {"type": "boolean"},
        "agent_smoke_evidence_valid": {"type": "boolean"},
        "agent_smoke_evidence_quality_gate_passed": {"type": "boolean"},
        "agent_smoke_evidence_win_template_attached": {"type": "boolean"},
        "agent_smoke_evidence_unblocks_production": {"const": false},
        "goal_complete": {"const": false},
        "completion_state": {"enum": ["not_executed", "partial_evidence"]},
        "goal_missing_requirements": {"const": 9},
        "goal_required_evidence_total": {"type": "integer", "minimum": 1},
        "goal_present_required_evidence": {"type": "integer", "minimum": 0},
        "goal_usable_required_evidence": {"type": "integer", "minimum": 0},
        "goal_missing_required_evidence": {"type": "integer", "minimum": 0},
        "goal_unusable_present_required_evidence": {"type": "integer", "minimum": 0},
        "next_unproven_requirement_id": {"const": "wave1_governed_acquisition"},
        "next_unproven_requirement_phase": {"const": "01-wave1-manifest-publication"},
        "next_unproven_execute_guard_env": {"const": "TAMANDUA_ALLOW_ML_REAL_ACQUISITION"},
        "evidence_status_summary": {"type": "object"},
        "next_unproven_requirement": {"type": "object"}
      }
    },
    "operator_sequence": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step", "mode", "command", "required_env", "claim_boundary"],
        "properties": {
          "step": {"type": "integer", "minimum": 1, "maximum": 2},
          "mode": {"enum": ["validation_only", "guarded_execute"]},
          "guard_set_command": {"type": "string", "minLength": 1},
          "command": {"type": "string", "minLength": 1},
          "required_env": {
            "type": "object",
            "additionalProperties": {"type": "string"}
          },
          "guard_cleanup_command": {"type": "string", "minLength": 1},
          "claim_boundary": {"type": "string", "minLength": 10}
        }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "passed", "detail"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "passed": {"type": "boolean"},
          "detail": {"type": "string"}
        }
      }
    }
  }
}
