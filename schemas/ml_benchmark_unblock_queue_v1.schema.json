{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamandua.io/schemas/ml_benchmark_unblock_queue_v1.schema.json",
  "title": "Tamandua ML Benchmark Unblock Queue v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["api_version", "kind", "metadata", "source", "summary", "items"],
  "properties": {
    "api_version": {"const": "tamandua.io/ml-benchmark-unblock-queue/v1"},
    "kind": {"const": "MLBenchmarkUnblockQueue"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_id", "generated_at", "created_by", "claim_boundary"],
      "properties": {
        "report_id": {"type": "string", "minLength": 1},
        "generated_at": {"type": "string", "format": "date-time"},
        "created_by": {"type": "string", "minLength": 1},
        "claim_boundary": {"type": "string", "minLength": 10}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["benchmark_execution_matrix", "benchmark_execution_matrix_validation", "benchmark_handoff_bundle", "benchmark_handoff_bundle_validation", "benchmark_handoff_consistency", "benchmark_handoff_consistency_validation", "ml_platform_readiness_audit", "ml_platform_readiness_audit_validation", "source_status_summary"],
      "properties": {
        "benchmark_execution_matrix": {"type": "string", "pattern": "20260604T-ml-benchmark-execution-matrix\\.json$"},
        "benchmark_execution_matrix_validation": {"enum": ["jsonschema+built-in", "built-in"]},
        "benchmark_handoff_bundle": {"type": "string", "pattern": "20260604T-ml-benchmark-handoff-bundle\\.json$"},
        "benchmark_handoff_bundle_validation": {"enum": ["jsonschema+built-in", "built-in"]},
        "benchmark_handoff_consistency": {"type": "string", "pattern": "20260604T-ml-benchmark-handoff-consistency\\.json$"},
        "benchmark_handoff_consistency_validation": {"enum": ["jsonschema+built-in", "built-in"]},
        "ml_platform_readiness_audit": {
          "type": "string",
          "pattern": "(20260604T-ml-platform-readiness-audit|20260621T0020Z-ml-platform-readiness-command-packet-blockers)\\.json$"
        },
        "ml_platform_readiness_audit_validation": {"enum": ["jsonschema+built-in", "built-in"]},
        "source_status_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "benchmark_execution_matrix_validated",
            "benchmark_handoff_bundle_validated",
            "benchmark_handoff_consistency_validated",
            "platform_readiness_audit_validated",
            "handoff_consistency_passed",
            "source_lane_count",
            "blocked_lane_count",
            "blocked_lane_ids",
            "pending_items",
            "dependency_items",
            "artifact_items",
            "env_items",
            "other_items",
            "unique_handoff_refs",
            "upstream_ready_validation_only",
            "upstream_blocked",
            "priority_sequence_valid",
            "items_with_resolution_command_exposure",
            "items_without_resolution_command_exposure",
            "goal_complete",
            "completion_state",
            "goal_snapshot_anchor_check_passed",
            "goal_missing_requirements",
            "goal_required_evidence_total",
            "goal_present_required_evidence",
            "goal_usable_required_evidence",
            "goal_missing_required_evidence",
            "goal_unusable_present_required_evidence",
            "next_unproven_requirement_id",
            "next_unproven_requirement_phase",
            "next_unproven_execute_guard_env",
            "missing_requirement_ids",
            "evidence_status_summary",
            "next_unproven_requirement"
          ],
          "properties": {
            "benchmark_execution_matrix_validated": {"type": "boolean"},
            "benchmark_handoff_bundle_validated": {"type": "boolean"},
            "benchmark_handoff_consistency_validated": {"type": "boolean"},
            "platform_readiness_audit_validated": {"type": "boolean"},
            "handoff_consistency_passed": {"type": "boolean"},
            "source_lane_count": {"type": "integer", "minimum": 0},
            "blocked_lane_count": {"type": "integer", "minimum": 0},
            "blocked_lane_ids": {
              "type": "array",
              "items": {"enum": ["ML-1", "ML-2", "ML-3", "ML-4", "ML-5", "ML-6"]}
            },
            "pending_items": {"type": "integer", "minimum": 0},
            "dependency_items": {"type": "integer", "minimum": 0},
            "artifact_items": {"type": "integer", "minimum": 0},
            "env_items": {"type": "integer", "minimum": 0},
            "other_items": {"type": "integer", "minimum": 0},
            "unique_handoff_refs": {"type": "integer", "minimum": 0},
            "upstream_ready_validation_only": {"type": "integer", "minimum": 0},
            "upstream_blocked": {"type": "integer", "minimum": 0},
            "priority_sequence_valid": {"type": "boolean"},
            "items_with_resolution_command_exposure": {"type": "integer", "minimum": 0},
            "items_without_resolution_command_exposure": {"type": "integer", "minimum": 0},
            "goal_complete": {"const": false},
            "completion_state": {"enum": ["not_executed", "partial_evidence"]},
            "goal_snapshot_anchor_check_passed": {"const": true},
            "goal_missing_requirements": {"const": 9},
            "goal_required_evidence_total": {"type": "integer", "minimum": 1},
            "goal_present_required_evidence": {"type": "integer", "minimum": 0},
            "goal_usable_required_evidence": {"type": "integer", "minimum": 0},
            "goal_missing_required_evidence": {"type": "integer", "minimum": 0},
            "goal_unusable_present_required_evidence": {"type": "integer", "minimum": 0},
            "next_unproven_requirement_id": {"const": "wave1_governed_acquisition"},
            "next_unproven_requirement_phase": {"const": "01-wave1-manifest-publication"},
            "next_unproven_execute_guard_env": {"const": "TAMANDUA_ALLOW_ML_REAL_ACQUISITION"},
            "missing_requirement_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
            "evidence_status_summary": {"type": "object"},
            "next_unproven_requirement": {"type": "object"}
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_items",
        "dependency",
        "artifact",
        "env",
        "other",
        "blocked_lanes",
        "upstream_ready_validation_only",
        "upstream_blocked",
        "items_with_resolution_command_exposure",
        "items_without_resolution_command_exposure",
        "goal_complete",
        "completion_state",
        "goal_snapshot_anchor_check_passed",
        "goal_usable_required_evidence",
        "goal_required_evidence_total",
        "next_unproven_requirement_id",
        "next_unproven_execute_guard_env"
      ],
      "properties": {
        "total_items": {"type": "integer", "minimum": 1},
        "dependency": {"type": "integer", "minimum": 0},
        "artifact": {"type": "integer", "minimum": 0},
        "env": {"type": "integer", "minimum": 0},
        "other": {"type": "integer", "minimum": 0},
        "blocked_lanes": {"type": "integer", "minimum": 0},
        "upstream_ready_validation_only": {"type": "integer", "minimum": 0},
        "upstream_blocked": {"type": "integer", "minimum": 0},
        "items_with_resolution_command_exposure": {"type": "integer", "minimum": 0},
        "items_without_resolution_command_exposure": {"type": "integer", "minimum": 0},
        "goal_complete": {"const": false},
        "completion_state": {"enum": ["not_executed", "partial_evidence"]},
        "goal_snapshot_anchor_check_passed": {"const": true},
        "goal_usable_required_evidence": {"type": "integer", "minimum": 0},
        "goal_required_evidence_total": {"type": "integer", "minimum": 1},
        "next_unproven_requirement_id": {"const": "wave1_governed_acquisition"},
        "next_unproven_execute_guard_env": {"const": "TAMANDUA_ALLOW_ML_REAL_ACQUISITION"}
      }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["unblock_id", "priority", "lane_id", "scope", "parallel_group", "category", "target", "blocker", "handoff_ref", "description", "resolution_state", "resolution_plan"],
        "properties": {
          "unblock_id": {"type": "string", "pattern": "^ml-benchmark-unblock-[0-9]{3}$"},
          "priority": {"type": "integer", "minimum": 1},
          "lane_id": {"enum": ["ML-1", "ML-2", "ML-3", "ML-4", "ML-5", "ML-6"]},
          "scope": {"enum": ["isolated_model", "onnx_parity", "agent_local", "service_api", "platform_replay", "cross_time_holdout"]},
          "parallel_group": {"type": "string", "minLength": 1},
          "category": {"enum": ["dependency", "artifact", "env", "other"]},
          "target": {"type": "string", "minLength": 1},
          "blocker": {"type": "string", "minLength": 1},
          "handoff_ref": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "resolution_state": {"enum": ["pending"]},
          "resolution_plan": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "command_available", "validation_command", "execute_command", "execute_guard_env", "operator_note"],
            "properties": {
              "kind": {
                "enum": [
                  "wave1_governed_acquisition",
                  "wave2_ml1_candidate",
                  "wave2_ml2_ml3_parity",
                  "wave2_ml4_service",
                  "ml5_outcome_builder",
                  "ml6_outcome_builder",
                  "ml1_model_contract_builder",
                  "ml1_model_card_builder",
                  "wave3_ml5_pipeline",
                  "wave3_ml6_holdout",
                  "ml4_api_key_env_validation",
                  "ml6_training_cutoff_env_validation",
                  "ml_prelab_validation_refresh",
                  "ml_lab_standby_guard_validation",
                  "ml_master_handoff_refresh",
                  "dependency",
                  "artifact",
                  "env",
                  "other"
                ]
              },
              "command_available": {"type": "boolean"},
              "validation_command": {
                "anyOf": [
                  {"type": "string", "minLength": 1},
                  {"type": "null"}
                ]
              },
              "execute_command": {
                "anyOf": [
                  {"type": "string", "minLength": 1},
                  {"type": "null"}
                ]
              },
              "execute_guard_env": {
                "anyOf": [
                  {"type": "string", "minLength": 1},
                  {"type": "null"}
                ]
              },
              "operator_note": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    }
  }
}
