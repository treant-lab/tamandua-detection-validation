{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamandua.io/schemas/ml_dataset_manifest_publish_probe_v1.schema.json",
  "title": "Tamandua ML Dataset Manifest Publish Probe v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "api_version",
    "kind",
    "metadata",
    "source_status_summary",
    "configuration",
    "passed",
    "checks",
    "sample_count"
  ],
  "properties": {
    "api_version": {"const": "tamandua.io/ml-dataset-manifest-publish-probe/v1"},
    "kind": {"const": "MLDatasetManifestPublishProbe"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_id", "generated_at", "created_by", "claim_boundary"],
      "properties": {
        "report_id": {"type": "string", "minLength": 1},
        "generated_at": {"type": "string", "format": "date-time"},
        "created_by": {"type": "string", "minLength": 1},
        "claim_boundary": {"type": "string", "minLength": 10}
      }
    },
    "source_status_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_manifest_outside_repo",
        "output_is_not_canonical_manifest",
        "raw_samples_not_in_git",
        "malware_and_goodware_present",
        "train_validation_test_splits_present",
        "manifest_contract_validated",
        "dataset_id",
        "sample_count",
        "label_count",
        "split_count",
        "check_count",
        "passed_checks",
        "failed_checks",
        "passed"
      ],
      "properties": {
        "source_manifest_outside_repo": {"type": "boolean"},
        "output_is_not_canonical_manifest": {"type": "boolean"},
        "raw_samples_not_in_git": {"type": "boolean"},
        "malware_and_goodware_present": {"type": "boolean"},
        "train_validation_test_splits_present": {"type": "boolean"},
        "manifest_contract_validated": {"type": "boolean"},
        "dataset_id": {"const": "ml-publish-probe-v1"},
        "sample_count": {"type": "integer", "minimum": 1},
        "label_count": {"type": "integer", "minimum": 0},
        "split_count": {"type": "integer", "minimum": 0},
        "check_count": {"type": "integer", "minimum": 0},
        "passed_checks": {"type": "integer", "minimum": 0},
        "failed_checks": {"type": "integer", "minimum": 0},
        "passed": {"type": "boolean"}
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_manifest", "output_manifest", "canonical_manifest_ref", "dataset_id"],
      "properties": {
        "source_manifest": {"type": "string", "minLength": 1},
        "output_manifest": {"type": "string", "minLength": 1},
        "canonical_manifest_ref": {"type": "string", "minLength": 1},
        "dataset_id": {"const": "ml-publish-probe-v1"}
      }
    },
    "passed": {"type": "boolean"},
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "passed", "detail"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "passed": {"type": "boolean"},
          "detail": {"type": "string"}
        }
      }
    },
    "sample_count": {"type": "integer", "minimum": 1}
  }
}
