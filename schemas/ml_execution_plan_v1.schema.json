{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamandua.io/schemas/ml_execution_plan_v1.schema.json",
  "title": "Tamandua ML Execution Plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "api_version",
    "kind",
    "metadata",
    "waves",
    "status_counts",
    "packages"
  ],
  "properties": {
    "api_version": {"const": "tamandua.io/ml-execution-plan/v1"},
    "kind": {"const": "MLExecutionPlan"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generated_at", "created_by", "claim_boundary"],
      "properties": {
        "generated_at": {"type": "string", "format": "date-time"},
        "created_by": {"type": "string", "minLength": 1},
        "claim_boundary": {"type": "string", "minLength": 10}
      }
    },
    "waves": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["wave", "purpose", "parallel"],
        "properties": {
          "wave": {"type": "integer", "minimum": 0},
          "purpose": {"type": "string", "minLength": 1},
          "parallel": {"type": "boolean"}
        }
      }
    },
    "status_counts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "evidence_exists": {"type": "integer", "minimum": 0},
        "ready": {"type": "integer", "minimum": 0},
        "blocked_missing_env": {"type": "integer", "minimum": 0},
        "blocked_missing_artifact": {"type": "integer", "minimum": 0},
        "blocked_dependency": {"type": "integer", "minimum": 0}
      }
    },
    "packages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "package_id",
          "wave",
          "title",
          "owner_role",
          "parallel_group",
          "status",
          "dependencies",
          "required_env",
          "required_artifacts",
          "expected_artifacts",
          "safe_commands",
          "safe_command_fingerprints",
          "claim_boundary",
          "next_action"
        ],
        "properties": {
          "package_id": {"type": "string", "pattern": "^ml[a-z0-9_]+$"},
          "wave": {"type": "integer", "minimum": 0},
          "title": {"type": "string", "minLength": 1},
          "owner_role": {"type": "string", "minLength": 1},
          "parallel_group": {"type": "string", "minLength": 1},
          "status": {
            "enum": [
              "evidence_exists",
              "ready",
              "blocked_missing_env",
              "blocked_missing_artifact",
              "blocked_dependency"
            ]
          },
          "dependencies": {"type": "array", "items": {"type": "string"}},
          "required_env": {"type": "array", "items": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]*$"}},
          "required_artifacts": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "expected_artifacts": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "safe_commands": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "safe_command_fingerprints": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["index", "command_sha256"],
              "properties": {
                "index": {"type": "integer", "minimum": 0},
                "command_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
              }
            }
          },
          "claim_boundary": {"type": "string", "minLength": 10},
          "next_action": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
