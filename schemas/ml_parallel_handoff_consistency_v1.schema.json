{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamandua.io/schemas/ml_parallel_handoff_consistency_v1.schema.json",
  "title": "Tamandua ML Parallel Handoff Consistency v1",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "category_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dependency", "artifact", "env", "other"],
      "properties": {
        "dependency": {"type": "integer", "minimum": 0},
        "artifact": {"type": "integer", "minimum": 0},
        "env": {"type": "integer", "minimum": 0},
        "other": {"type": "integer", "minimum": 0}
      }
    }
  },
  "required": ["api_version", "kind", "metadata", "consistent", "blockers", "source_status_summary", "configuration", "summary", "checks"],
  "properties": {
    "api_version": {"const": "tamandua.io/ml-parallel-handoff-consistency/v1"},
    "kind": {"const": "MLParallelHandoffConsistency"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_id", "generated_at", "created_by", "claim_boundary"],
      "properties": {
        "report_id": {"type": "string", "minLength": 1},
        "generated_at": {"type": "string", "format": "date-time"},
        "created_by": {"type": "string", "minLength": 1},
        "claim_boundary": {"type": "string", "minLength": 10}
      }
    },
    "consistent": {"type": "boolean"},
    "blockers": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "source_status_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parallel_work_packages_validation",
        "parallel_handoff_bundle_validation",
        "dispatch_valid",
        "handoff_bundle_valid",
        "bundle_source_matches_dispatch",
        "claim_ids_match",
        "claim_status_and_guard_match",
        "claim_evidence_usability_match",
        "claim_safe_command_fingerprints_match",
        "claim_block_category_match",
        "handoff_content_matches_claims",
        "no_orphan_handoff_files",
        "claim_command_exposure_match",
        "blocked_category_rollups_match",
        "goal_snapshot_matches_dispatch",
        "category_mismatches",
        "fingerprint_mismatches",
        "check_count",
        "passed_checks",
        "failed_checks",
        "blocker_count",
        "dispatch_claims",
        "handoff_claim_files",
        "source_mismatches",
        "orphan_handoff_files",
        "dispatch_validation_command_claims",
        "handoff_validation_command_claim_files",
        "dispatch_execute_guard_claims",
        "handoff_execute_guard_claim_files",
        "dispatch_evidence_usable_for_goal",
        "handoff_evidence_usable_for_goal",
        "ready_validation_only",
        "blocked",
        "blocked_by_category",
        "evidence_exists",
        "goal_complete",
        "completion_state",
        "goal_usable_required_evidence",
        "goal_required_evidence_total",
        "next_unproven_requirement_id",
        "next_unproven_execute_guard_env",
        "consistent"
      ],
      "properties": {
        "parallel_work_packages_validation": {"enum": ["jsonschema+built-in", "built-in", "invalid"]},
        "parallel_handoff_bundle_validation": {"enum": ["jsonschema+built-in", "built-in", "invalid"]},
        "dispatch_valid": {"type": "boolean"},
        "handoff_bundle_valid": {"type": "boolean"},
        "bundle_source_matches_dispatch": {"type": "boolean"},
        "claim_ids_match": {"type": "boolean"},
        "claim_status_and_guard_match": {"type": "boolean"},
        "claim_evidence_usability_match": {"type": "boolean"},
        "claim_safe_command_fingerprints_match": {"type": "boolean"},
        "claim_block_category_match": {"type": "boolean"},
        "handoff_content_matches_claims": {"type": "boolean"},
        "no_orphan_handoff_files": {"type": "boolean"},
        "claim_command_exposure_match": {"type": "boolean"},
        "blocked_category_rollups_match": {"type": "boolean"},
        "goal_snapshot_matches_dispatch": {"type": "boolean"},
        "category_mismatches": {"type": "integer", "minimum": 0},
        "fingerprint_mismatches": {"type": "integer", "minimum": 0},
        "check_count": {"type": "integer", "minimum": 0},
        "passed_checks": {"type": "integer", "minimum": 0},
        "failed_checks": {"type": "integer", "minimum": 0},
        "blocker_count": {"type": "integer", "minimum": 0},
        "dispatch_claims": {"type": "integer", "minimum": 0},
        "handoff_claim_files": {"type": "integer", "minimum": 0},
        "source_mismatches": {"type": "integer", "minimum": 0},
        "orphan_handoff_files": {"type": "integer", "minimum": 0},
        "dispatch_validation_command_claims": {"type": "integer", "minimum": 0},
        "handoff_validation_command_claim_files": {"type": "integer", "minimum": 0},
        "dispatch_execute_guard_claims": {"type": "integer", "minimum": 0},
        "handoff_execute_guard_claim_files": {"type": "integer", "minimum": 0},
        "dispatch_evidence_usable_for_goal": {"type": "integer", "minimum": 0},
        "handoff_evidence_usable_for_goal": {"type": "integer", "minimum": 0},
        "ready_validation_only": {"type": "integer", "minimum": 0},
        "blocked": {"type": "integer", "minimum": 0},
        "blocked_by_category": {"$ref": "#/$defs/category_counts"},
        "evidence_exists": {"type": "integer", "minimum": 0},
        "goal_complete": {"type": "boolean"},
        "completion_state": {"enum": ["partial_evidence", "complete"]},
        "goal_usable_required_evidence": {"type": "integer", "minimum": 0},
        "goal_required_evidence_total": {"type": "integer", "minimum": 0},
        "next_unproven_requirement_id": {"type": "string", "minLength": 1},
        "next_unproven_execute_guard_env": {"type": "string", "minLength": 1},
        "consistent": {"type": "boolean"}
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parallel_work_packages", "parallel_handoff_bundle"],
      "properties": {
        "parallel_work_packages": {"type": "string", "pattern": "20260604T-ml-parallel-work-packages\\.json$"},
        "parallel_handoff_bundle": {"type": "string", "pattern": "20260604T-ml-parallel-handoff-bundle\\.json$"}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dispatch_claims",
        "handoff_claim_files",
        "source_mismatches",
        "orphan_handoff_files",
        "dispatch_validation_command_claims",
        "handoff_validation_command_claim_files",
        "dispatch_execute_guard_claims",
        "handoff_execute_guard_claim_files",
        "dispatch_evidence_usable_for_goal",
        "handoff_evidence_usable_for_goal",
        "ready_validation_only",
        "blocked",
        "blocked_by_category",
        "evidence_exists",
        "category_mismatches",
        "fingerprint_mismatches",
        "goal_complete",
        "completion_state",
        "goal_usable_required_evidence",
        "goal_required_evidence_total",
        "next_unproven_requirement_id",
        "next_unproven_execute_guard_env"
      ],
      "properties": {
        "dispatch_claims": {"type": "integer", "minimum": 0},
        "handoff_claim_files": {"type": "integer", "minimum": 0},
        "source_mismatches": {"type": "integer", "minimum": 0},
        "orphan_handoff_files": {"type": "integer", "minimum": 0},
        "dispatch_validation_command_claims": {"type": "integer", "minimum": 0},
        "handoff_validation_command_claim_files": {"type": "integer", "minimum": 0},
        "dispatch_execute_guard_claims": {"type": "integer", "minimum": 0},
        "handoff_execute_guard_claim_files": {"type": "integer", "minimum": 0},
        "dispatch_evidence_usable_for_goal": {"type": "integer", "minimum": 0},
        "handoff_evidence_usable_for_goal": {"type": "integer", "minimum": 0},
        "ready_validation_only": {"type": "integer", "minimum": 0},
        "blocked": {"type": "integer", "minimum": 0},
        "blocked_by_category": {"$ref": "#/$defs/category_counts"},
        "evidence_exists": {"type": "integer", "minimum": 0},
        "category_mismatches": {"type": "integer", "minimum": 0},
        "fingerprint_mismatches": {"type": "integer", "minimum": 0},
        "goal_complete": {"type": "boolean"},
        "completion_state": {"enum": ["partial_evidence", "complete"]},
        "goal_usable_required_evidence": {"type": "integer", "minimum": 0},
        "goal_required_evidence_total": {"type": "integer", "minimum": 0},
        "next_unproven_requirement_id": {"type": "string", "minLength": 1},
        "next_unproven_execute_guard_env": {"type": "string", "minLength": 1}
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "passed", "detail"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "passed": {"type": "boolean"},
          "detail": {"type": "string"}
        }
      }
    }
  }
}
