{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamandua.io/schemas/ml_goal_snapshot_v1.schema.json",
  "title": "Tamandua ML Goal Snapshot v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "api_version",
    "kind",
    "metadata",
    "source",
    "goal",
    "source_status_summary",
    "ready_for_completion_claim",
    "checks"
  ],
  "properties": {
    "api_version": {"const": "tamandua.io/ml-goal-snapshot/v1"},
    "kind": {"const": "MLGoalSnapshot"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_id", "generated_at", "created_by", "claim_boundary"],
      "properties": {
        "report_id": {"type": "string", "minLength": 1},
        "generated_at": {"type": "string", "format": "date-time"},
        "created_by": {"type": "string", "minLength": 1},
        "claim_boundary": {"type": "string", "minLength": 20}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["master_handoff", "master_handoff_validation"],
      "properties": {
        "master_handoff": {"type": "string", "pattern": "(20260604T-ml-execution-master-handoff|20260621T-ml-execution-master-handoff-post-readiness-refresh)\\.json$"},
        "master_handoff_validation": {"enum": ["jsonschema+built-in", "built-in"]}
      }
    },
    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "goal_complete",
        "completion_state",
        "goal_missing_requirements",
        "goal_required_evidence_total",
        "goal_present_required_evidence",
        "goal_usable_required_evidence",
        "goal_missing_required_evidence",
        "goal_unusable_present_required_evidence",
        "next_unproven_requirement_id",
        "next_unproven_requirement_phase",
        "next_unproven_execute_guard_env",
        "missing_requirement_ids",
        "evidence_status_summary",
        "next_unproven_requirement",
        "requirement_evidence_matrix"
      ],
      "properties": {
        "goal_complete": {"const": false},
        "completion_state": {"const": "partial_evidence"},
        "goal_missing_requirements": {"const": 9},
        "goal_required_evidence_total": {"const": 16},
        "goal_present_required_evidence": {"const": 4},
        "goal_usable_required_evidence": {"const": 1},
        "goal_missing_required_evidence": {"const": 12},
        "goal_unusable_present_required_evidence": {"const": 3},
        "next_unproven_requirement_id": {"const": "wave1_governed_acquisition"},
        "next_unproven_requirement_phase": {"const": "01-wave1-manifest-publication"},
        "next_unproven_execute_guard_env": {"const": "TAMANDUA_ALLOW_ML_REAL_ACQUISITION"},
        "missing_requirement_ids": {
          "type": "array",
          "minItems": 9,
          "maxItems": 9,
          "items": {"type": "string", "minLength": 1},
          "contains": {"const": "wave1_governed_acquisition"}
        },
        "evidence_status_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "total_required_evidence",
            "present_required_evidence",
            "usable_required_evidence",
            "missing_required_evidence",
            "unusable_present_required_evidence",
            "by_status"
          ],
          "properties": {
            "total_required_evidence": {"const": 16},
            "present_required_evidence": {"const": 4},
            "usable_required_evidence": {"const": 1},
            "missing_required_evidence": {"const": 12},
            "unusable_present_required_evidence": {"const": 3},
            "by_status": {
              "type": "object",
              "additionalProperties": {"type": "integer", "minimum": 0}
            }
          }
        },
        "next_unproven_requirement": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "phase",
            "phase_state",
            "execute_guard_env",
            "pending_targets",
            "required_evidence",
            "missing_or_unusable_evidence"
          ],
          "properties": {
            "id": {"const": "wave1_governed_acquisition"},
            "phase": {"const": "01-wave1-manifest-publication"},
            "phase_state": {"type": "string", "minLength": 1},
            "execute_guard_env": {"const": "TAMANDUA_ALLOW_ML_REAL_ACQUISITION"},
            "pending_targets": {"type": "array", "items": {"type": "string", "minLength": 1}},
            "required_evidence": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
            "missing_or_unusable_evidence": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
          }
        },
        "requirement_evidence_matrix": {
          "type": "array",
          "minItems": 10,
          "maxItems": 10,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "phase",
              "status",
              "phase_state",
              "execute_guard_env",
              "command_available",
              "validation_command",
              "execute_command",
              "command_claim_boundary",
              "pending_targets",
              "required_evidence",
              "missing_or_unusable_evidence",
              "platform_status",
              "platform_blockers",
              "evidence_state",
              "evidence"
            ],
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "phase": {"type": "string", "minLength": 1},
              "status": {"enum": ["proven", "missing_evidence"]},
              "phase_state": {"type": "string", "minLength": 1},
              "execute_guard_env": {"type": "string"},
              "command_available": {"type": "boolean"},
              "validation_command": {"type": "string"},
              "execute_command": {"type": "string"},
              "command_claim_boundary": {"type": "string", "minLength": 1},
              "pending_targets": {"type": "array", "items": {"type": "string", "minLength": 1}},
              "required_evidence": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
              "missing_or_unusable_evidence": {"type": "array", "items": {"type": "string", "minLength": 1}},
              "platform_status": {"type": "string", "minLength": 1},
              "platform_blockers": {"type": "array", "items": {"type": "string", "minLength": 1}},
              "evidence_state": {"enum": ["proven", "not_proven"]},
              "evidence": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["ref", "type", "present", "usable", "status"],
                  "properties": {
                    "ref": {"type": "string", "minLength": 1},
                    "type": {"enum": ["file", "env"]},
                    "present": {"type": "boolean"},
                    "usable": {"type": "boolean"},
                    "status": {"type": "string", "minLength": 1}
                  }
                }
              }
            }
          },
          "contains": {
            "type": "object",
            "required": ["id", "status"],
            "properties": {
              "id": {"const": "public_claim_evidence_boundary"},
              "status": {"const": "proven"}
            }
          }
        }
      }
    },
    "source_status_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "goal_complete",
        "completion_state",
        "goal_missing_requirements",
        "goal_required_evidence_total",
        "goal_present_required_evidence",
        "goal_usable_required_evidence",
        "goal_missing_required_evidence",
        "goal_unusable_present_required_evidence",
        "next_unproven_requirement_id",
        "next_unproven_requirement_phase",
        "next_unproven_execute_guard_env",
        "missing_requirement_ids",
        "wave1_pre_execution_transcript_contract_validation_before_run",
        "wave1_pre_execution_transcript_contract_valid_before_run",
        "wave1_pre_execution_transcript_contract_missing_before_run",
        "wave1_acceptance_intake_transcript_contract_validation",
        "wave1_acceptance_intake_transcript_contract_valid",
        "wave1_transcript_contract_valid_for_manifest_publish",
        "wave1_acquisition_transcript_guarded_run_command_packet_sha256",
        "wave1_acquisition_transcript_stdout_sha256",
        "wave1_acquisition_transcript_stderr_sha256",
        "wave1_manifest_transcript_guarded_run_command_packet_sha256",
        "wave1_manifest_transcript_stdout_sha256",
        "wave1_manifest_transcript_stderr_sha256",
        "wave1_transcript_hashes_match_between_receipts",
        "goal_snapshot_anchor_check_passed",
        "mismatched_snapshot_fields",
        "requirement_matrix_items",
        "requirement_matrix_not_proven",
        "requirement_matrix_proven",
        "check_count",
        "passed_checks",
        "failed_checks"
      ],
      "properties": {
        "goal_complete": {"const": false},
        "completion_state": {"const": "partial_evidence"},
        "goal_missing_requirements": {"const": 9},
        "goal_required_evidence_total": {"const": 16},
        "goal_present_required_evidence": {"const": 4},
        "goal_usable_required_evidence": {"const": 1},
        "goal_missing_required_evidence": {"const": 12},
        "goal_unusable_present_required_evidence": {"const": 3},
        "next_unproven_requirement_id": {"const": "wave1_governed_acquisition"},
        "next_unproven_requirement_phase": {"const": "01-wave1-manifest-publication"},
        "next_unproven_execute_guard_env": {"const": "TAMANDUA_ALLOW_ML_REAL_ACQUISITION"},
        "missing_requirement_ids": {"type": "array", "minItems": 9, "maxItems": 9},
        "wave1_pre_execution_transcript_contract_validation_before_run": {"const": "missing"},
        "wave1_pre_execution_transcript_contract_valid_before_run": {"const": false},
        "wave1_pre_execution_transcript_contract_missing_before_run": {"const": true},
        "wave1_acceptance_intake_transcript_contract_validation": {"enum": ["jsonschema+built-in", "built-in", "missing", "failed"]},
        "wave1_acceptance_intake_transcript_contract_valid": {"type": "boolean"},
        "wave1_transcript_contract_valid_for_manifest_publish": {"type": "boolean"},
        "wave1_acquisition_transcript_guarded_run_command_packet_sha256": {"type": "string"},
        "wave1_acquisition_transcript_stdout_sha256": {"type": "string"},
        "wave1_acquisition_transcript_stderr_sha256": {"type": "string"},
        "wave1_manifest_transcript_guarded_run_command_packet_sha256": {"type": "string"},
        "wave1_manifest_transcript_stdout_sha256": {"type": "string"},
        "wave1_manifest_transcript_stderr_sha256": {"type": "string"},
        "wave1_transcript_hashes_match_between_receipts": {"type": "boolean"},
        "goal_snapshot_anchor_check_passed": {"const": true},
        "mismatched_snapshot_fields": {"type": "array", "maxItems": 0},
        "requirement_matrix_items": {"const": 10},
        "requirement_matrix_not_proven": {"const": 9},
        "requirement_matrix_proven": {"const": 1},
        "check_count": {"type": "integer", "minimum": 1},
        "passed_checks": {"type": "integer", "minimum": 1},
        "failed_checks": {"const": 0}
      }
    },
    "ready_for_completion_claim": {"const": false},
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "passed", "detail"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "passed": {"type": "boolean"},
          "detail": {"type": "string"}
        }
      }
    }
  }
}
