{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamandua.io/schemas/ml_next_operator_packet_v1.schema.json",
  "title": "Tamandua ML Next Operator Packet v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "api_version",
    "kind",
    "metadata",
    "source_authorization_packet",
    "operator_decision",
    "source_auth",
    "pre_run_transcript_state",
    "commands",
    "safety_invariants",
    "expected_evidence",
    "downstream_benchmark_surfaces",
    "checks",
    "source_status_summary"
  ],
  "properties": {
    "api_version": {"const": "tamandua.io/ml-next-operator-packet/v1"},
    "kind": {"const": "MLNextOperatorPacket"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_id", "generated_at", "created_by", "claim_boundary"],
      "properties": {
        "report_id": {"type": "string", "minLength": 1},
        "generated_at": {"type": "string", "format": "date-time"},
        "created_by": {"const": "tamandua-ml-next-operator-packet"},
        "claim_boundary": {"type": "string", "minLength": 20}
      }
    },
    "source_authorization_packet": {
      "type": "string",
      "pattern": "(20260620T1615Z-ml-next-gate-authorization-virusshare-source-aware|20260620T2345Z-ml-next-gate-authorization-secret-readiness|20260621T-ml-next-gate-authorization-post-readiness-refresh-governed|20260621T-ml-next-gate-authorization-post-onnx-runtime-governed|20260621T-ml-next-gate-authorization-post-platform-onnx-runtime-governed|20260621T-ml-next-gate-authorization-post-win-template-gate-threading-governed|20260621T-ml-next-gate-authorization-post-lab-root-governed)\\.json$"
    },
    "operator_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_id",
        "ready_for_guarded_execution",
        "authorized_for_guarded_execution",
        "publication_decision",
        "publication_reason",
        "blockers",
        "failed_authorization_checks"
      ],
      "properties": {
        "package_id": {"enum": ["ml_data_virusshare_fallback", "ml_data_governed_acquisition"]},
        "ready_for_guarded_execution": {"type": "boolean"},
        "authorized_for_guarded_execution": {"type": "boolean"},
        "publication_decision": {"enum": ["hold_do_not_push", "eligible_after_operator_approval"]},
        "publication_reason": {"type": "string", "minLength": 10},
        "blockers": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "failed_authorization_checks": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    },
    "source_auth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selected_route",
        "env",
        "required_for_selected_route",
        "present",
        "value_redacted",
        "operator_note"
      ],
      "properties": {
        "selected_route": {"enum": ["virusshare_fallback", "malwarebazaar_governed_acquisition"]},
        "env": {"enum": ["VIRUSSHARE_API_KEY", "TAMANDUA_MALWAREBAZAAR_AUTH_KEY"]},
        "required_for_selected_route": {"const": true},
        "present": {"type": "boolean"},
        "value_redacted": {"enum": ["present", "absent"]},
        "operator_note": {"type": "string", "minLength": 40}
      }
    },
    "pre_run_transcript_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pre_execution_contract_validation",
        "pre_execution_contract_valid",
        "pre_execution_contract_missing",
        "acceptance_intake_contract_validation",
        "acceptance_intake_contract_valid",
        "valid_for_manifest_publish",
        "operator_note"
      ],
      "properties": {
        "pre_execution_contract_validation": {"enum": ["jsonschema+built-in", "built-in", "missing", "failed"]},
        "pre_execution_contract_valid": {"type": "boolean"},
        "pre_execution_contract_missing": {"type": "boolean"},
        "acceptance_intake_contract_validation": {"enum": ["jsonschema+built-in", "built-in", "missing", "failed"]},
        "acceptance_intake_contract_valid": {"type": "boolean"},
        "valid_for_manifest_publish": {"const": false},
        "operator_note": {"type": "string", "minLength": 40}
      }
    },
    "commands": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [
        {"required": ["validation", "guarded_execute", "post_acquisition"]},
        {"required": ["env_remediation"]}
      ],
      "properties": {
        "env_remediation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required_env",
            "rerun_status_command",
            "rerun_readiness_command",
            "rerun_authorization_command",
            "claim_boundary"
          ],
          "properties": {
            "required_env": {
              "type": "object",
              "additionalProperties": {"type": "string"},
              "required": ["TAMANDUA_ML_DATA_ROOT", "VIRUSSHARE_API_KEY"],
              "properties": {
                "TAMANDUA_ML_DATA_ROOT": {"const": "<external isolated lab data root>"},
                "VIRUSSHARE_API_KEY": {"const": "<redacted: isolated lab secret store>"}
              }
            },
            "rerun_status_command": {"type": "string", "pattern": "ml_execution_status\\.py"},
            "rerun_readiness_command": {"type": "string", "pattern": "ml_virusshare_fallback_readiness_probe\\.py"},
            "rerun_authorization_command": {"type": "string", "pattern": "ml_next_gate_authorization_packet\\.py"},
            "claim_boundary": {"type": "string", "minLength": 10}
          }
        },
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["command", "required_env", "claim_boundary"],
          "properties": {
            "command": {"type": "string", "pattern": "(wave_1_virusshare_fallback_readiness_launcher|wave_1_real_acquisition_launcher)\\.ps1$"},
            "required_env": {"type": "object", "maxProperties": 0},
            "claim_boundary": {"type": "string", "minLength": 10}
          }
        },
        "guarded_execute": {
          "type": "object",
          "additionalProperties": false,
          "required": ["guard_set_command", "command", "required_env", "guard_cleanup_command", "claim_boundary"],
          "properties": {
            "guard_set_command": {"const": "$env:TAMANDUA_ALLOW_ML_REAL_ACQUISITION = '1'"},
            "command": {"type": "string", "pattern": "(wave_1_virusshare_fallback_acquisition_launcher|wave_1_real_acquisition_launcher)\\.ps1 -Execute$"},
            "required_env": {
              "type": "object",
              "additionalProperties": {"type": "string"},
              "required": ["TAMANDUA_ML_DATA_ROOT", "TAMANDUA_ALLOW_ML_REAL_ACQUISITION"],
              "properties": {
                "TAMANDUA_ML_DATA_ROOT": {"type": "string", "minLength": 1},
                "TAMANDUA_ALLOW_ML_REAL_ACQUISITION": {"const": "1"},
                "VIRUSSHARE_API_KEY": {"const": "<redacted: isolated lab secret store>"}
              }
            },
            "guard_cleanup_command": {"type": "string", "pattern": "TAMANDUA_ALLOW_ML_REAL_ACQUISITION"},
            "claim_boundary": {"type": "string", "minLength": 10}
          }
        },
        "post_acquisition": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "refresh_command",
            "manifest_guard_set_command",
            "manifest_publish_command",
            "manifest_guard_cleanup_command",
            "post_manifest_refresh_command"
          ],
          "properties": {
            "refresh_command": {"type": "string", "pattern": "wave_1_post_acquisition_refresh_launcher\\.ps1$"},
            "manifest_guard_set_command": {"const": "$env:TAMANDUA_ALLOW_ML_MANIFEST_PUBLISH = '1'"},
            "manifest_publish_command": {"type": "string", "pattern": "wave_1_manifest_publish_launcher\\.ps1 -Execute$"},
            "manifest_guard_cleanup_command": {"const": "Remove-Item Env:TAMANDUA_ALLOW_ML_MANIFEST_PUBLISH -ErrorAction SilentlyContinue"},
            "post_manifest_refresh_command": {"type": "string", "pattern": "wave_1_post_acquisition_refresh_launcher\\.ps1$"}
          }
        }
      }
    },
    "safety_invariants": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vx_archive_download_guard_env",
        "vx_archive_download_guard_must_remain_unset",
        "vx_download_authorized_by_this_packet",
        "vx_inventory_metadata_only",
        "vx_samples_allowed_in_training_splits",
        "raw_samples_allowed_in_git",
        "data_root_must_be_outside_repo",
        "source_mirror_code_and_metadata_only",
        "trained_weights_release_artifact_only_after_ml_gates"
      ],
      "properties": {
        "vx_archive_download_guard_env": {"const": "TAMANDUA_ALLOW_VX_UNDERGROUND_DOWNLOAD"},
        "vx_archive_download_guard_must_remain_unset": {"const": true},
        "vx_download_authorized_by_this_packet": {"const": false},
        "vx_inventory_metadata_only": {"const": true},
        "vx_samples_allowed_in_training_splits": {"const": false},
        "raw_samples_allowed_in_git": {"const": false},
        "data_root_must_be_outside_repo": {"const": true},
        "source_mirror_code_and_metadata_only": {"const": true},
        "trained_weights_release_artifact_only_after_ml_gates": {"const": true}
      }
    },
    "expected_evidence": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "downstream_benchmark_surfaces": {"type": "object"},
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "passed"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "passed": {"type": "boolean"}
        }
      }
    },
    "source_status_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ready_for_guarded_execution",
        "publication_decision",
        "blocker_count",
        "failed_authorization_check_count",
        "passed_checks",
        "failed_checks"
      ],
      "properties": {
        "ready_for_guarded_execution": {"type": "boolean"},
        "publication_decision": {"enum": ["hold_do_not_push", "eligible_after_operator_approval"]},
        "blocker_count": {"type": "integer", "minimum": 0},
        "failed_authorization_check_count": {"type": "integer", "minimum": 0},
        "passed_checks": {"type": "integer", "minimum": 0},
        "failed_checks": {"type": "integer", "minimum": 0}
      }
    }
  }
}
