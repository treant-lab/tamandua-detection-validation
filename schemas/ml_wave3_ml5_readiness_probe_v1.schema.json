{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamandua.io/schemas/ml_wave3_ml5_readiness_probe_v1.schema.json",
  "title": "Tamandua ML Wave 3 ML-5 Readiness Probe v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["api_version", "kind", "metadata", "configuration", "source", "ready_for_ml5_pipeline_replay", "blockers", "checks", "operator_sequence"],
  "properties": {
    "api_version": {"const": "tamandua.io/ml-wave3-ml5-readiness-probe/v1"},
    "kind": {"const": "MLWave3ML5ReadinessProbe"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_id", "generated_at", "created_by", "claim_boundary"],
      "properties": {
        "report_id": {"type": "string", "minLength": 1},
        "generated_at": {"type": "string", "format": "date-time"},
        "created_by": {"type": "string", "minLength": 1},
        "claim_boundary": {"type": "string", "minLength": 10}
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status_ref", "wave2_ml2_ml3_readiness_ref", "wave2_ml4_readiness_ref", "ml1_report", "model_contract", "model_card", "ml3_report", "ml3_agent_side_evidence", "ml4_report", "replay_outcomes", "launcher"],
      "properties": {
        "status_ref": {"type": "string", "minLength": 1},
        "wave2_ml2_ml3_readiness_ref": {"type": "string", "minLength": 1},
        "wave2_ml4_readiness_ref": {"type": "string", "minLength": 1},
        "ml1_report": {"type": "string", "pattern": "ml-prod-candidate-v1-ml1\\.json$"},
        "model_contract": {"type": "string", "pattern": "ml-prod-candidate-v1-model-contract\\.json$"},
        "model_card": {"type": "string", "pattern": "ml-prod-candidate-v1-model-card\\.md$"},
        "ml3_report": {"type": "string", "pattern": "ml-prod-candidate-v1-ml3-agent-parity\\.json$"},
        "ml3_agent_side_evidence": {"type": "string", "pattern": "20260620T-ml3-agent-parity-with-win-template\\.json$"},
        "ml4_report": {"type": "string", "pattern": "ml-prod-candidate-v1-ml4-api\\.json$"},
        "replay_outcomes": {"type": "string", "pattern": "ml-prod-candidate-v1-ml5-replay-outcomes\\.json$"},
        "launcher": {"type": "string", "pattern": "wave_3_ml5_pipeline_launcher\\.ps1$"}
      }
    },
    "ready_for_ml5_pipeline_replay": {"type": "boolean"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "execution_status",
        "execution_status_validation",
        "wave2_ml2_ml3_readiness",
        "wave2_ml2_ml3_readiness_validation",
        "wave2_ml4_readiness",
        "wave2_ml4_readiness_validation",
        "ml1_report",
        "ml1_report_validation",
        "ml1_model_contract",
        "ml1_model_contract_validation",
        "ml1_model_card",
        "ml3_report",
        "ml3_report_validation",
        "ml3_agent_side_evidence",
        "ml3_agent_side_evidence_validation",
        "ml4_report",
        "ml4_report_validation",
        "replay_outcomes",
        "source_status_summary"
      ],
      "properties": {
        "execution_status": {"type": "string", "pattern": "20260604T-ml-execution-status\\.json$"},
        "execution_status_validation": {"type": "string", "enum": ["jsonschema+built-in", "failed"]},
        "wave2_ml2_ml3_readiness": {"type": "string", "pattern": "20260604T-ml-wave2-ml2-ml3-readiness-probe\\.json$"},
        "wave2_ml2_ml3_readiness_validation": {"type": "string", "enum": ["jsonschema+built-in", "failed"]},
        "wave2_ml4_readiness": {"type": "string", "pattern": "20260604T-ml-wave2-ml4-readiness-probe\\.json$"},
        "wave2_ml4_readiness_validation": {"type": "string", "enum": ["jsonschema+built-in", "failed"]},
        "ml1_report": {"type": "string", "pattern": "ml-prod-candidate-v1-ml1\\.json$"},
        "ml1_report_validation": {"type": "string", "enum": ["jsonschema+built-in", "failed", "missing"]},
        "ml1_model_contract": {"type": "string", "pattern": "ml-prod-candidate-v1-model-contract\\.json$"},
        "ml1_model_contract_validation": {"type": "string", "enum": ["jsonschema+built-in", "failed", "missing"]},
        "ml1_model_card": {"type": "string", "pattern": "ml-prod-candidate-v1-model-card\\.md$"},
        "ml3_report": {"type": "string", "pattern": "ml-prod-candidate-v1-ml3-agent-parity\\.json$"},
        "ml3_report_validation": {"type": "string", "enum": ["jsonschema+built-in", "failed", "missing"]},
        "ml3_agent_side_evidence": {"type": "string", "pattern": "20260620T-ml3-agent-parity-with-win-template\\.json$"},
        "ml3_agent_side_evidence_validation": {"type": "string", "enum": ["jsonschema+built-in", "failed", "missing"]},
        "ml4_report": {"type": "string", "pattern": "ml-prod-candidate-v1-ml4-api\\.json$"},
        "ml4_report_validation": {"type": "string", "enum": ["jsonschema+built-in", "failed", "missing"]},
        "replay_outcomes": {"type": "string", "pattern": "ml-prod-candidate-v1-ml5-replay-outcomes\\.json$"},
        "source_status_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "goal_complete",
            "completion_state",
            "goal_missing_requirements",
            "goal_required_evidence_total",
            "goal_present_required_evidence",
            "goal_usable_required_evidence",
            "goal_missing_required_evidence",
            "goal_unusable_present_required_evidence",
            "next_unproven_requirement_id",
            "next_unproven_requirement_phase",
            "next_unproven_execute_guard_env",
            "missing_requirement_ids",
            "evidence_status_summary",
            "next_unproven_requirement",
            "wave2_ml2_ml3_ready_for_parity",
            "wave2_ml2_ml3_lab_guard_proof_mismatch_count",
            "wave2_ml2_ml3_ml_lab_standby_guards_unset",
            "wave2_ml4_ready_for_service_benchmark",
            "wave2_ml4_lab_guard_proof_mismatch_count",
            "wave2_ml4_ml_lab_standby_guards_unset",
            "ml1_benchmark_report_present",
            "ml1_model_contract_present",
            "ml1_model_contract_valid",
            "ml1_model_card_present",
            "ml1_model_card_nonempty",
            "ml1_model_card_references_contract",
            "ml3_agent_parity_report_present",
            "ml3_agent_side_evidence_present",
            "ml3_agent_side_evidence_valid",
            "ml3_agent_side_evidence_quality_gate_passed",
            "ml3_agent_side_evidence_sample_count",
            "ml3_agent_side_evidence_win_template_attached",
            "ml4_service_report_present",
            "ml5_replay_outcomes_present",
            "ml5_replay_outcome_sample_count",
            "ml5_replay_outcomes_have_malicious",
            "ml5_replay_outcomes_have_benign",
            "ml5_replay_outcomes_no_raw_samples",
            "ml5_replay_outcomes_have_pipeline_verdicts",
            "ml5_launcher_exists",
            "required_input_count",
            "required_inputs_present",
            "blocker_count",
            "blockers"
          ],
          "properties": {
            "goal_complete": {"type": "boolean"},
            "completion_state": {"enum": ["not_executed", "partial_evidence", "complete"]},
            "goal_missing_requirements": {"type": "integer", "minimum": 0},
            "goal_required_evidence_total": {"type": "integer", "minimum": 0},
            "goal_present_required_evidence": {"type": "integer", "minimum": 0},
            "goal_usable_required_evidence": {"type": "integer", "minimum": 0},
            "goal_missing_required_evidence": {"type": "integer", "minimum": 0},
            "goal_unusable_present_required_evidence": {"type": "integer", "minimum": 0},
            "next_unproven_requirement_id": {"type": "string"},
            "next_unproven_requirement_phase": {"type": "string"},
            "next_unproven_execute_guard_env": {"type": "string"},
            "missing_requirement_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
            "evidence_status_summary": {"type": "object"},
            "next_unproven_requirement": {"type": "object"},
            "wave2_ml2_ml3_ready_for_parity": {"type": "boolean"},
            "wave2_ml2_ml3_lab_guard_proof_mismatch_count": {"type": "integer", "minimum": 0},
            "wave2_ml2_ml3_ml_lab_standby_guards_unset": {"type": "boolean"},
            "wave2_ml4_ready_for_service_benchmark": {"type": "boolean"},
            "wave2_ml4_lab_guard_proof_mismatch_count": {"type": "integer", "minimum": 0},
            "wave2_ml4_ml_lab_standby_guards_unset": {"type": "boolean"},
            "ml1_benchmark_report_present": {"type": "boolean"},
            "ml1_model_contract_present": {"type": "boolean"},
            "ml1_model_contract_valid": {"type": "boolean"},
            "ml1_model_card_present": {"type": "boolean"},
            "ml1_model_card_nonempty": {"type": "boolean"},
            "ml1_model_card_references_contract": {"type": "boolean"},
            "ml3_agent_parity_report_present": {"type": "boolean"},
            "ml3_agent_side_evidence_present": {"type": "boolean"},
            "ml3_agent_side_evidence_valid": {"type": "boolean"},
            "ml3_agent_side_evidence_quality_gate_passed": {"type": "boolean"},
            "ml3_agent_side_evidence_sample_count": {"type": "integer", "minimum": 0},
            "ml3_agent_side_evidence_win_template_attached": {"type": "boolean"},
            "ml4_service_report_present": {"type": "boolean"},
            "ml5_replay_outcomes_present": {"type": "boolean"},
            "ml5_replay_outcome_sample_count": {"type": "integer", "minimum": 0},
            "ml5_replay_outcomes_have_malicious": {"type": "boolean"},
            "ml5_replay_outcomes_have_benign": {"type": "boolean"},
            "ml5_replay_outcomes_no_raw_samples": {"type": "boolean"},
            "ml5_replay_outcomes_have_pipeline_verdicts": {"type": "boolean"},
            "ml5_launcher_exists": {"type": "boolean"},
            "required_input_count": {"type": "integer", "minimum": 0},
            "required_inputs_present": {"type": "integer", "minimum": 0},
            "blocker_count": {"type": "integer", "minimum": 0},
            "blockers": {"type": "array", "items": {"type": "string", "minLength": 1}}
          }
        }
      }
    },
    "blockers": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "passed", "detail"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "passed": {"type": "boolean"},
          "detail": {"type": "string"}
        }
      }
    },
    "operator_sequence": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step", "mode", "command", "claim_boundary"],
        "properties": {
          "step": {"type": "integer", "minimum": 1},
          "mode": {"type": "string", "enum": ["validation_only", "execute"]},
          "required_env": {"type": "object", "additionalProperties": {"type": "string"}},
          "guard_set_command": {"type": "string", "minLength": 1},
          "command": {"type": "string", "minLength": 1},
          "guard_cleanup_command": {"type": "string", "minLength": 1},
          "claim_boundary": {"type": "string", "minLength": 10}
        }
      }
    }
  }
}
