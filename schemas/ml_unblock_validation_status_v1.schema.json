{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamandua.io/schemas/ml_unblock_validation_status_v1.schema.json",
  "title": "Tamandua ML Unblock Validation Status v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["api_version", "kind", "metadata", "source", "summary", "missing_handoff_ids", "items", "next_pending_items"],
  "properties": {
    "api_version": {"const": "tamandua.io/ml-unblock-validation-status/v1"},
    "kind": {"const": "MLUnblockValidationStatus"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_id", "generated_at", "created_by", "claim_boundary"],
      "properties": {
        "report_id": {"type": "string", "minLength": 1},
        "generated_at": {"type": "string", "format": "date-time"},
        "created_by": {"type": "string", "minLength": 1},
        "claim_boundary": {"type": "string", "minLength": 10}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parallel_work_packages", "parallel_work_packages_validation", "unblock_queue", "unblock_queue_validation", "unblock_handoff_bundle", "unblock_handoff_bundle_validation", "platform_readiness_audit", "platform_readiness_audit_validation", "source_status_summary"],
      "properties": {
        "parallel_work_packages": {"type": "string", "pattern": "20260604T-ml-parallel-work-packages\\.json$"},
        "parallel_work_packages_validation": {"enum": ["jsonschema+built-in", "built-in"]},
        "unblock_queue": {"type": "string", "pattern": "20260604T-ml-unblock-queue\\.json$"},
        "unblock_queue_validation": {"enum": ["jsonschema+built-in", "built-in"]},
        "unblock_handoff_bundle": {"type": "string", "pattern": "20260604T-ml-unblock-handoff-bundle\\.json$"},
        "unblock_handoff_bundle_validation": {"enum": ["jsonschema+built-in", "built-in"]},
        "platform_readiness_audit": {"type": "string", "pattern": "20260604T-ml-platform-readiness-audit\\.json$"},
        "platform_readiness_audit_validation": {"enum": ["jsonschema+built-in", "built-in"]},
        "source_status_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "parallel_work_packages_validated",
            "unblock_queue_validated",
            "unblock_handoff_bundle_validated",
            "platform_readiness_audit_validated",
            "dispatch_claims",
            "queue_items",
            "handoff_files",
            "status_items",
            "resolved",
            "pending",
            "missing_handoff_ids",
            "pending_item_ids",
            "resolved_item_ids",
            "pending_by_category",
            "resolved_by_category",
            "upstream_ready_validation_only",
            "upstream_blocked",
            "items_from_blocked_claims",
            "items_without_command_exposure",
            "items_with_resolution_command_exposure",
            "items_without_resolution_command_exposure",
            "handoff_items_from_blocked_claims",
            "handoff_items_without_command_exposure",
            "handoff_items_with_resolution_command_exposure",
            "handoff_items_without_resolution_command_exposure",
            "dependency_pending",
            "artifact_pending",
            "env_pending",
            "readiness_blocker_links",
            "readiness_blockers_active",
            "primary_resolved_but_readiness_blocked",
            "all_queue_items_have_status",
            "all_status_items_have_handoffs",
            "priority_sequence_valid",
            "goal_complete",
            "completion_state",
            "goal_missing_requirements",
            "goal_required_evidence_total",
            "goal_present_required_evidence",
            "goal_usable_required_evidence",
            "goal_missing_required_evidence",
            "goal_unusable_present_required_evidence",
            "next_unproven_requirement_id",
            "next_unproven_requirement_phase",
            "next_unproven_execute_guard_env",
            "missing_requirement_ids",
            "evidence_status_summary",
            "next_unproven_requirement"
          ],
          "properties": {
            "parallel_work_packages_validated": {"type": "boolean"},
            "unblock_queue_validated": {"type": "boolean"},
            "unblock_handoff_bundle_validated": {"type": "boolean"},
            "platform_readiness_audit_validated": {"type": "boolean"},
            "dispatch_claims": {"type": "integer", "minimum": 0},
            "queue_items": {"type": "integer", "minimum": 0},
            "handoff_files": {"type": "integer", "minimum": 0},
            "status_items": {"type": "integer", "minimum": 0},
            "resolved": {"type": "integer", "minimum": 0},
            "pending": {"type": "integer", "minimum": 0},
            "missing_handoff_ids": {"type": "integer", "minimum": 0},
            "pending_item_ids": {"type": "array", "items": {"type": "string", "pattern": "^ml-unblock-[0-9]{3}$"}},
            "resolved_item_ids": {"type": "array", "items": {"type": "string", "pattern": "^ml-unblock-[0-9]{3}$"}},
            "pending_by_category": {"$ref": "#/$defs/category_counts"},
            "resolved_by_category": {"$ref": "#/$defs/category_counts"},
            "upstream_ready_validation_only": {"type": "integer", "minimum": 0},
            "upstream_blocked": {"type": "integer", "minimum": 0},
            "items_from_blocked_claims": {"type": "integer", "minimum": 0},
            "items_without_command_exposure": {"type": "integer", "minimum": 0},
            "items_with_resolution_command_exposure": {"type": "integer", "minimum": 0},
            "items_without_resolution_command_exposure": {"type": "integer", "minimum": 0},
            "handoff_items_from_blocked_claims": {"type": "integer", "minimum": 0},
            "handoff_items_without_command_exposure": {"type": "integer", "minimum": 0},
            "handoff_items_with_resolution_command_exposure": {"type": "integer", "minimum": 0},
            "handoff_items_without_resolution_command_exposure": {"type": "integer", "minimum": 0},
            "dependency_pending": {"type": "integer", "minimum": 0},
            "artifact_pending": {"type": "integer", "minimum": 0},
            "env_pending": {"type": "integer", "minimum": 0},
            "readiness_blocker_links": {"type": "integer", "minimum": 0},
            "readiness_blockers_active": {"type": "integer", "minimum": 0},
            "primary_resolved_but_readiness_blocked": {"type": "integer", "minimum": 0},
            "all_queue_items_have_status": {"type": "boolean"},
            "all_status_items_have_handoffs": {"type": "boolean"},
            "priority_sequence_valid": {"type": "boolean"},
            "goal_complete": {"type": "boolean"},
            "completion_state": {"enum": ["not_executed", "partial_evidence", "complete"]},
            "goal_missing_requirements": {"type": "integer", "minimum": 0},
            "goal_required_evidence_total": {"type": "integer", "minimum": 0},
            "goal_present_required_evidence": {"type": "integer", "minimum": 0},
            "goal_usable_required_evidence": {"type": "integer", "minimum": 0},
            "goal_missing_required_evidence": {"type": "integer", "minimum": 0},
            "goal_unusable_present_required_evidence": {"type": "integer", "minimum": 0},
            "next_unproven_requirement_id": {"type": "string", "minLength": 1},
            "next_unproven_requirement_phase": {"type": "string", "minLength": 1},
            "next_unproven_execute_guard_env": {"type": "string", "minLength": 1},
            "missing_requirement_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
            "evidence_status_summary": {"type": "object"},
            "next_unproven_requirement": {"type": "object"}
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_items", "resolved", "pending", "missing_handoff_ids", "pending_by_category", "resolved_by_category", "upstream_ready_validation_only", "upstream_blocked", "items_from_blocked_claims", "items_without_command_exposure", "items_with_resolution_command_exposure", "items_without_resolution_command_exposure", "handoff_items_from_blocked_claims", "handoff_items_without_command_exposure", "handoff_items_with_resolution_command_exposure", "handoff_items_without_resolution_command_exposure", "dependency_pending", "artifact_pending", "env_pending", "readiness_blocker_links", "readiness_blockers_active", "primary_resolved_but_readiness_blocked", "goal_complete", "completion_state", "goal_usable_required_evidence", "goal_required_evidence_total", "next_unproven_requirement_id", "next_unproven_execute_guard_env"],
      "properties": {
        "total_items": {"type": "integer", "minimum": 0},
        "resolved": {"type": "integer", "minimum": 0},
        "pending": {"type": "integer", "minimum": 0},
        "missing_handoff_ids": {"type": "integer", "minimum": 0},
        "pending_by_category": {"$ref": "#/$defs/category_counts"},
        "resolved_by_category": {"$ref": "#/$defs/category_counts"},
        "upstream_ready_validation_only": {"type": "integer", "minimum": 0},
        "upstream_blocked": {"type": "integer", "minimum": 0},
        "items_from_blocked_claims": {"type": "integer", "minimum": 0},
        "items_without_command_exposure": {"type": "integer", "minimum": 0},
        "items_with_resolution_command_exposure": {"type": "integer", "minimum": 0},
        "items_without_resolution_command_exposure": {"type": "integer", "minimum": 0},
        "handoff_items_from_blocked_claims": {"type": "integer", "minimum": 0},
        "handoff_items_without_command_exposure": {"type": "integer", "minimum": 0},
        "handoff_items_with_resolution_command_exposure": {"type": "integer", "minimum": 0},
        "handoff_items_without_resolution_command_exposure": {"type": "integer", "minimum": 0},
        "dependency_pending": {"type": "integer", "minimum": 0},
        "artifact_pending": {"type": "integer", "minimum": 0},
        "env_pending": {"type": "integer", "minimum": 0},
        "readiness_blocker_links": {"type": "integer", "minimum": 0},
        "readiness_blockers_active": {"type": "integer", "minimum": 0},
        "primary_resolved_but_readiness_blocked": {"type": "integer", "minimum": 0},
        "goal_complete": {"type": "boolean"},
        "completion_state": {"enum": ["not_executed", "partial_evidence", "complete", "unknown"]},
        "goal_usable_required_evidence": {"type": "integer", "minimum": 0},
        "goal_required_evidence_total": {"type": "integer", "minimum": 0},
        "next_unproven_requirement_id": {"type": "string", "minLength": 1},
        "next_unproven_execute_guard_env": {"type": "string", "minLength": 1}
      }
    },
    "missing_handoff_ids": {"type": "array", "items": {"type": "string", "pattern": "^ml-unblock-[0-9]{3}$"}},
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["unblock_id", "claim_id", "package_id", "wave", "owner_role", "parallel_group", "category", "target", "priority", "primary_resolved", "readiness_blockers", "readiness_blockers_active", "readiness_evidence_paths", "resolved", "resolution_state", "detail"],
        "properties": {
          "unblock_id": {"type": "string", "pattern": "^ml-unblock-[0-9]{3}$"},
          "claim_id": {"type": "string", "pattern": "^ml-ml[a-z0-9_]+$"},
          "package_id": {"type": "string", "pattern": "^ml[a-z0-9_]+$"},
          "wave": {"type": "integer", "minimum": 0},
          "owner_role": {"type": "string", "minLength": 1},
          "parallel_group": {"type": "string", "minLength": 1},
          "category": {"enum": ["dependency", "artifact", "env", "other"]},
          "target": {"type": "string", "minLength": 1},
          "priority": {"type": "integer", "minimum": 1},
          "primary_resolved": {"type": "boolean"},
          "readiness_blockers": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "readiness_blockers_active": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "readiness_evidence_paths": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "resolved": {"type": "boolean"},
          "resolution_state": {"enum": ["resolved", "pending"]},
          "detail": {"type": "string", "minLength": 1}
        }
      }
    },
    "next_pending_items": {"type": "array", "items": {"type": "object"}}
  },
  "$defs": {
    "category_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dependency", "artifact", "env", "other"],
      "properties": {
        "dependency": {"type": "integer", "minimum": 0},
        "artifact": {"type": "integer", "minimum": 0},
        "env": {"type": "integer", "minimum": 0},
        "other": {"type": "integer", "minimum": 0}
      }
    }
  }
}
