{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamandua.io/schemas/ml_wave1_go_no_go_v1.schema.json",
  "title": "Tamandua ML Wave 1 Go/No-Go Probe v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "api_version",
    "kind",
    "metadata",
    "source_status_summary",
    "vx_policy",
    "configuration",
    "go_for_guarded_real_acquisition",
    "ml1_blocked_until_canonical_manifest",
    "checks",
    "next_operator_action"
  ],
  "properties": {
    "api_version": {"const": "tamandua.io/ml-wave1-go-no-go/v1"},
    "kind": {"const": "MLWave1GoNoGoProbe"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_id", "generated_at", "created_by", "claim_boundary"],
      "properties": {
        "report_id": {"type": "string", "minLength": 1},
        "generated_at": {"type": "string", "format": "date-time"},
        "created_by": {"type": "string", "minLength": 1},
        "claim_boundary": {"type": "string", "minLength": 10}
      }
    },
    "source_status_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "goal_complete",
        "completion_state",
        "goal_missing_requirements",
        "goal_required_evidence_total",
        "goal_present_required_evidence",
        "goal_usable_required_evidence",
        "goal_missing_required_evidence",
        "goal_unusable_present_required_evidence",
        "next_unproven_requirement_id",
        "next_unproven_requirement_phase",
        "next_unproven_execute_guard_env",
        "missing_requirement_ids",
        "evidence_status_summary",
        "next_unproven_requirement",
        "acquisition_readiness_valid",
        "acquisition_dry_run_valid",
        "execution_status_valid",
        "manifest_publish_transition_valid",
        "dataset_manifest_publish_probe_valid",
        "wave1_real_acquisition_launcher_exists",
        "canonical_dataset_manifest_absent",
        "next_action_is_guarded_acquisition",
        "vx_policy_metadata_only_boundary",
        "check_count",
        "passed_checks",
        "failed_checks",
        "go_for_guarded_real_acquisition",
        "ml1_blocked_until_canonical_manifest",
        "canonical_manifest_path",
        "vx_archive_download_guard_env",
        "vx_archive_download_guard_present",
        "vx_download_authorized_by_go_no_go",
        "vx_inventory_metadata_only",
        "vx_samples_allowed_in_training_splits",
        "vx_guard_must_remain_unset_for_wave1_acquisition"
      ],
      "properties": {
        "goal_complete": {"type": "boolean"},
        "completion_state": {"enum": ["not_executed", "partial_evidence", "complete"]},
        "goal_missing_requirements": {"type": "integer", "minimum": 0},
        "goal_required_evidence_total": {"type": "integer", "minimum": 0},
        "goal_present_required_evidence": {"type": "integer", "minimum": 0},
        "goal_usable_required_evidence": {"type": "integer", "minimum": 0},
        "goal_missing_required_evidence": {"type": "integer", "minimum": 0},
        "goal_unusable_present_required_evidence": {"type": "integer", "minimum": 0},
        "next_unproven_requirement_id": {"type": "string"},
        "next_unproven_requirement_phase": {"type": "string"},
        "next_unproven_execute_guard_env": {"type": "string"},
        "missing_requirement_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "evidence_status_summary": {"type": "object"},
        "next_unproven_requirement": {"type": "object"},
        "acquisition_readiness_valid": {"type": "boolean"},
        "acquisition_dry_run_valid": {"type": "boolean"},
        "execution_status_valid": {"type": "boolean"},
        "manifest_publish_transition_valid": {"type": "boolean"},
        "dataset_manifest_publish_probe_valid": {"type": "boolean"},
        "wave1_real_acquisition_launcher_exists": {"type": "boolean"},
        "canonical_dataset_manifest_absent": {"type": "boolean"},
        "next_action_is_guarded_acquisition": {"type": "boolean"},
        "vx_policy_metadata_only_boundary": {"type": "boolean"},
        "check_count": {"type": "integer", "minimum": 0},
        "passed_checks": {"type": "integer", "minimum": 0},
        "failed_checks": {"type": "integer", "minimum": 0},
        "go_for_guarded_real_acquisition": {"type": "boolean"},
        "ml1_blocked_until_canonical_manifest": {"type": "boolean"},
        "canonical_manifest_path": {
          "type": "string",
          "pattern": "ml-prod-candidate-v1-dataset-manifest\\.json$"
        },
        "vx_archive_download_guard_env": {"const": "TAMANDUA_ALLOW_VX_UNDERGROUND_DOWNLOAD"},
        "vx_archive_download_guard_present": {"const": false},
        "vx_download_authorized_by_go_no_go": {"const": false},
        "vx_inventory_metadata_only": {"const": true},
        "vx_samples_allowed_in_training_splits": {"const": false},
        "vx_guard_must_remain_unset_for_wave1_acquisition": {"const": true}
      }
    },
    "vx_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vx_archive_download_guard_env",
        "vx_archive_download_guard_present",
        "vx_download_authorized_by_go_no_go",
        "vx_inventory_metadata_only",
        "vx_samples_allowed_in_training_splits",
        "vx_guard_must_remain_unset_for_wave1_acquisition"
      ],
      "properties": {
        "vx_archive_download_guard_env": {"const": "TAMANDUA_ALLOW_VX_UNDERGROUND_DOWNLOAD"},
        "vx_archive_download_guard_present": {"const": false},
        "vx_download_authorized_by_go_no_go": {"const": false},
        "vx_inventory_metadata_only": {"const": true},
        "vx_samples_allowed_in_training_splits": {"const": false},
        "vx_guard_must_remain_unset_for_wave1_acquisition": {"const": true}
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "readiness_ref",
        "dry_run_ref",
        "execution_status_ref",
        "manifest_publish_transition_ref",
        "dataset_manifest_publish_probe_ref",
        "handoff_dir",
        "canonical_dataset_manifest"
      ],
      "properties": {
        "readiness_ref": {"type": "string", "minLength": 1},
        "dry_run_ref": {"type": "string", "minLength": 1},
        "execution_status_ref": {"type": "string", "minLength": 1},
        "manifest_publish_transition_ref": {"type": "string", "minLength": 1},
        "dataset_manifest_publish_probe_ref": {"type": "string", "minLength": 1},
        "handoff_dir": {"type": "string", "minLength": 1},
        "canonical_dataset_manifest": {
          "type": "string",
          "pattern": "ml-prod-candidate-v1-dataset-manifest\\.json$"
        }
      }
    },
    "go_for_guarded_real_acquisition": {"type": "boolean"},
    "ml1_blocked_until_canonical_manifest": {"type": "boolean"},
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "passed", "detail"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "passed": {"type": "boolean"},
          "detail": {"type": "string"}
        }
      }
    },
    "next_operator_action": {"type": "string", "minLength": 1}
  }
}
