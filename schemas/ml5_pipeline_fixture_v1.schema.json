{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamandua.io/schemas/ml5_pipeline_fixture_v1.schema.json",
  "title": "Tamandua ML-5 Pipeline Replay Fixture v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "api_version",
    "kind",
    "fixture_id",
    "dataset_id",
    "created_at",
    "created_by",
    "raw_samples_in_fixture",
    "subject",
    "environment",
    "samples",
    "claim_boundary"
  ],
  "properties": {
    "api_version": {
      "const": "tamandua.io/ml5-pipeline-fixture/v1"
    },
    "kind": {
      "const": "ML5PipelineReplayFixture"
    },
    "fixture_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.-]{2,127}$"
    },
    "dataset_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "minLength": 2
    },
    "raw_samples_in_fixture": {
      "const": false
    },
    "pipeline_trace_ref": {
      "type": ["string", "null"]
    },
    "model_report_ref": {
      "type": ["string", "null"]
    },
    "ml_service_report_ref": {
      "type": ["string", "null"]
    },
    "agent_parity_report_ref": {
      "type": ["string", "null"]
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "build_ref": {
          "type": ["string", "null"]
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": true,
      "required": ["agent_features"],
      "properties": {
        "agent_features": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rust_version": {
          "type": ["string", "null"]
        },
        "onnxruntime_version": {
          "type": ["string", "null"]
        }
      }
    },
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sample_id",
          "label",
          "expected_malicious",
          "deterministic_detected",
          "ml_detected"
        ],
        "properties": {
          "sample_id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "enum": [
              "malware",
              "suspicious",
              "trojan",
              "ransomware",
              "spyware",
              "adware",
              "worm",
              "backdoor",
              "unknown_malware",
              "goodware",
              "benign"
            ]
          },
          "expected_malicious": {
            "type": "boolean"
          },
          "deterministic_detected": {
            "type": "boolean"
          },
          "ml_detected": {
            "type": "boolean"
          },
          "latency_ms": {
            "type": ["number", "null"],
            "minimum": 0
          },
          "alert_created": {
            "type": ["boolean", "null"]
          },
          "duplicate_suppressed": {
            "type": ["boolean", "null"]
          },
          "trace_id": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "claim_boundary": {
      "type": "string",
      "minLength": 10
    }
  }
}
