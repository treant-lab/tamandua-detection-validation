{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamandua.io/schemas/ml_vx_underground_inventory_v1.schema.json",
  "title": "Tamandua ML VX Underground InTheWild Inventory v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["api_version", "kind", "metadata", "archives"],
  "properties": {
    "api_version": {"const": "tamandua.io/ml-vx-underground-inventory/v1"},
    "kind": {"const": "VxUndergroundInTheWildInventory"},
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "created_at",
        "listing_url",
        "archive_downloaded",
        "inventory_role",
        "used_in_training",
        "raw_archives_in_repo",
        "archive_extraction_performed",
        "endpoint_exposed",
        "claim_boundary"
      ],
      "properties": {
        "created_at": {"type": "string", "format": "date-time"},
        "listing_url": {
          "type": "string",
          "pattern": "^https://vx-underground\\.org/Samples/InTheWild%20Collection/Downloadable%20Releases$"
        },
        "collection_method": {"type": "string", "minLength": 1},
        "script_fetch_status": {"type": "string", "minLength": 1},
        "archive_downloaded": {"type": "boolean"},
        "inventory_role": {"const": "holdout_candidate"},
        "holdout_role": {"const": "holdout_metadata_only"},
        "used_in_training": {"const": false},
        "raw_archives_in_repo": {"const": false},
        "archive_extraction_performed": {"const": false},
        "endpoint_exposed": {"const": false},
        "downloads_require_guard_env": {"const": "TAMANDUA_ALLOW_VX_UNDERGROUND_DOWNLOAD"},
        "operator_next_command": {
          "type": "string",
          "minLength": 1,
          "not": {
            "anyOf": [
              {"pattern": "--download"},
              {"pattern": "[Ss][Ee][Cc][Rr][Ee][Tt]"},
              {"pattern": "[Aa][Pp][Ii][_-]?[Kk][Ee][Yy]"},
              {"pattern": "[Tt][Oo][Kk][Ee][Nn]"}
            ]
          }
        },
        "claim_boundary": {"type": "string", "minLength": 20}
      }
    },
    "archives": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["release_id", "filename", "url", "listed_size", "listed_modified", "source"],
        "properties": {
          "release_id": {"type": "string", "pattern": "^\\d{4}$"},
          "filename": {"type": "string", "pattern": "^InTheWild\\.\\d{4}\\.7z$"},
          "url": {"type": "string"},
          "listed_size": {"type": "string"},
          "listed_modified": {"type": "string"},
          "source": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
