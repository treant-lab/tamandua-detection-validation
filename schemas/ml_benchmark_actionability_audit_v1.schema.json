{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamandua.io/schemas/ml_benchmark_actionability_audit_v1.schema.json",
  "title": "Tamandua ML Benchmark Actionability Audit v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["api_version", "kind", "metadata", "actionable", "source", "summary", "checks"],
  "properties": {
    "api_version": {"const": "tamandua.io/ml-benchmark-actionability-audit/v1"},
    "kind": {"const": "MLBenchmarkActionabilityAudit"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_id", "generated_at", "created_by", "claim_boundary"],
      "properties": {
        "report_id": {"type": "string", "minLength": 1},
        "generated_at": {"type": "string", "format": "date-time"},
        "created_by": {"type": "string", "minLength": 1},
        "claim_boundary": {"type": "string", "minLength": 10}
      }
    },
    "actionable": {"type": "boolean"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "benchmark_unblock_queue",
        "benchmark_unblock_queue_validation",
        "benchmark_critical_path",
        "benchmark_critical_path_validation",
        "benchmark_critical_path_handoff_bundle",
        "benchmark_critical_path_handoff_bundle_validation",
        "benchmark_critical_path_handoff_consistency",
        "benchmark_critical_path_handoff_consistency_validation",
        "source_status_summary"
      ],
      "properties": {
        "benchmark_unblock_queue": {"type": "string", "pattern": "20260604T-ml-benchmark-unblock-queue\\.json$"},
        "benchmark_unblock_queue_validation": {"enum": ["jsonschema+built-in", "built-in"]},
        "benchmark_critical_path": {"type": "string", "pattern": "20260604T-ml-benchmark-critical-path\\.json$"},
        "benchmark_critical_path_validation": {"enum": ["jsonschema+built-in", "built-in"]},
        "benchmark_critical_path_handoff_bundle": {"type": "string", "pattern": "20260604T-ml-benchmark-critical-path-handoff-bundle\\.json$"},
        "benchmark_critical_path_handoff_bundle_validation": {"enum": ["jsonschema+built-in", "built-in"]},
        "benchmark_critical_path_handoff_consistency": {"type": "string", "pattern": "20260604T-ml-benchmark-critical-path-handoff-consistency\\.json$"},
        "benchmark_critical_path_handoff_consistency_validation": {"enum": ["jsonschema+built-in", "built-in"]},
        "source_status_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "goal_complete",
            "completion_state",
            "goal_missing_requirements",
            "goal_required_evidence_total",
            "goal_present_required_evidence",
            "goal_usable_required_evidence",
            "goal_missing_required_evidence",
            "goal_unusable_present_required_evidence",
            "next_unproven_requirement_id",
            "next_unproven_requirement_phase",
            "next_unproven_execute_guard_env",
            "standalone_detection_surface_covered",
            "agent_onnx_detection_surface_covered",
            "tamandua_detection_surface_covered",
            "benchmark_detection_surface_contract_ready",
            "missing_requirement_ids",
            "evidence_status_summary",
            "next_unproven_requirement"
          ],
          "properties": {
            "goal_complete": {"const": false},
            "completion_state": {"enum": ["not_executed", "partial_evidence"]},
            "goal_missing_requirements": {"const": 9},
            "goal_required_evidence_total": {"type": "integer", "minimum": 1},
            "goal_present_required_evidence": {"type": "integer", "minimum": 0},
            "goal_usable_required_evidence": {"type": "integer", "minimum": 0},
            "goal_missing_required_evidence": {"type": "integer", "minimum": 0},
            "goal_unusable_present_required_evidence": {"type": "integer", "minimum": 0},
            "next_unproven_requirement_id": {"const": "wave1_governed_acquisition"},
            "next_unproven_requirement_phase": {"const": "01-wave1-manifest-publication"},
            "next_unproven_execute_guard_env": {"const": "TAMANDUA_ALLOW_ML_REAL_ACQUISITION"},
            "standalone_detection_surface_covered": {"const": true},
            "agent_onnx_detection_surface_covered": {"const": true},
            "tamandua_detection_surface_covered": {"const": true},
            "benchmark_detection_surface_contract_ready": {"const": true},
            "missing_requirement_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
            "evidence_status_summary": {"type": "object"},
            "next_unproven_requirement": {"type": "object"}
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "queue_items",
        "queue_items_with_resolution_command",
        "queue_items_without_resolution_command",
        "critical_path_steps",
        "critical_path_steps_with_resolution_command",
        "critical_path_steps_without_resolution_command",
        "handoff_files",
        "handoff_files_with_resolution_command",
        "validation_command_count",
        "validation_commands_are_validation_only",
        "guarded_execute_commands_exposed",
        "non_guarded_resolution_commands",
        "env_validation_commands",
        "env_validation_commands_redacted",
        "env_validation_commands_parse_cutoff",
        "evidence_usable_for_goal",
        "actionability_gap_count",
        "check_count",
        "passed_checks",
        "failed_checks",
        "goal_complete",
        "completion_state",
        "goal_usable_required_evidence",
        "goal_required_evidence_total",
        "next_unproven_requirement_id",
        "next_unproven_execute_guard_env",
        "standalone_detection_surface_covered",
        "agent_onnx_detection_surface_covered",
        "tamandua_detection_surface_covered",
        "benchmark_detection_surface_contract_ready"
      ],
      "properties": {
        "queue_items": {"type": "integer", "minimum": 0},
        "queue_items_with_resolution_command": {"type": "integer", "minimum": 0},
        "queue_items_without_resolution_command": {"type": "integer", "minimum": 0},
        "critical_path_steps": {"type": "integer", "minimum": 0},
        "critical_path_steps_with_resolution_command": {"type": "integer", "minimum": 0},
        "critical_path_steps_without_resolution_command": {"type": "integer", "minimum": 0},
        "handoff_files": {"type": "integer", "minimum": 0},
        "handoff_files_with_resolution_command": {"type": "integer", "minimum": 0},
        "validation_command_count": {"type": "integer", "minimum": 0},
        "validation_commands_are_validation_only": {"type": "boolean"},
        "guarded_execute_commands_exposed": {"type": "integer", "minimum": 0},
        "non_guarded_resolution_commands": {"type": "integer", "minimum": 0},
        "env_validation_commands": {"type": "integer", "minimum": 0},
        "env_validation_commands_redacted": {"type": "boolean"},
        "env_validation_commands_parse_cutoff": {"type": "boolean"},
        "evidence_usable_for_goal": {"type": "integer", "minimum": 0},
        "actionability_gap_count": {"type": "integer", "minimum": 0},
        "check_count": {"type": "integer", "minimum": 0},
        "passed_checks": {"type": "integer", "minimum": 0},
        "failed_checks": {"type": "integer", "minimum": 0},
        "goal_complete": {"const": false},
        "completion_state": {"enum": ["not_executed", "partial_evidence"]},
        "goal_usable_required_evidence": {"type": "integer", "minimum": 0},
        "goal_required_evidence_total": {"type": "integer", "minimum": 1},
        "next_unproven_requirement_id": {"const": "wave1_governed_acquisition"},
        "next_unproven_execute_guard_env": {"const": "TAMANDUA_ALLOW_ML_REAL_ACQUISITION"},
        "standalone_detection_surface_covered": {"const": true},
        "agent_onnx_detection_surface_covered": {"const": true},
        "tamandua_detection_surface_covered": {"const": true},
        "benchmark_detection_surface_contract_ready": {"const": true}
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "passed", "detail"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "passed": {"type": "boolean"},
          "detail": {"type": "string"}
        }
      }
    }
  }
}
