{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamandua.io/schemas/ml_wave1_execution_packet_v1.schema.json",
  "title": "Tamandua ML Wave 1 Execution Packet v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["api_version", "kind", "metadata", "source", "authorized_acquisition", "safe_to_hand_to_operator", "blockers", "configuration", "operator_sequence", "commands", "operator_checklist", "artifact_expectations", "forbidden_actions"],
  "properties": {
    "api_version": {"const": "tamandua.io/ml-wave1-execution-packet/v1"},
    "kind": {"const": "MLWave1ExecutionPacket"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_id", "generated_at", "created_by", "claim_boundary"],
      "properties": {
        "report_id": {"type": "string", "minLength": 1},
        "generated_at": {"type": "string", "format": "date-time"},
        "created_by": {"type": "string", "minLength": 1},
        "claim_boundary": {"type": "string", "minLength": 10}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operator_launch_brief", "operator_launch_brief_validation", "lab_transcript_template", "lab_transcript_template_validation", "source_operator_launch_brief_summary"],
      "properties": {
        "operator_launch_brief": {"type": "string", "pattern": "20260604T-ml-wave1-operator-launch-brief\\.json$"},
        "operator_launch_brief_validation": {"enum": ["jsonschema+built-in", "built-in"]},
        "lab_transcript_template": {"type": "string", "pattern": "20260604T-ml-wave1-real-acquisition-transcript\\.template\\.json$"},
        "lab_transcript_template_validation": {"enum": ["jsonschema+built-in", "built-in"]},
        "source_operator_launch_brief_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "goal_complete",
            "completion_state",
            "goal_missing_requirements",
            "goal_required_evidence_total",
            "goal_present_required_evidence",
            "goal_usable_required_evidence",
            "goal_missing_required_evidence",
            "goal_unusable_present_required_evidence",
            "next_unproven_requirement_id",
            "next_unproven_requirement_phase",
            "next_unproven_execute_guard_env",
            "missing_requirement_ids",
            "evidence_status_summary",
            "next_unproven_requirement",
            "ready_for_operator",
            "checks",
            "check_names",
            "operator_sequence_steps",
            "operator_sequence_modes",
            "operator_sequence_modes_sha256",
            "operator_commands_by_mode_sha256",
            "next_action_run_validated",
            "next_action_run_mode",
            "next_action_run_returncode",
            "next_action_run_package_id",
            "next_action_run_wave",
            "next_action_validation_scope_selected",
            "next_action_safety_assertions",
            "next_action_safety_assertions_passed",
            "ml_lab_standby_guards_unset",
            "ml_lab_standby_required_unset_guard_env",
            "ml_lab_standby_enabled_guards",
            "validation_only_command_count",
            "guarded_execute_command_count",
            "guarded_required_env_count",
            "command_guard_boundary_preserved"
          ],
          "properties": {
            "goal_complete": {"type": "boolean"},
            "completion_state": {"enum": ["not_executed", "partial_evidence", "complete"]},
            "goal_missing_requirements": {"type": "integer", "minimum": 0},
            "goal_required_evidence_total": {"type": "integer", "minimum": 0},
            "goal_present_required_evidence": {"type": "integer", "minimum": 0},
            "goal_usable_required_evidence": {"type": "integer", "minimum": 0},
            "goal_missing_required_evidence": {"type": "integer", "minimum": 0},
            "goal_unusable_present_required_evidence": {"type": "integer", "minimum": 0},
            "next_unproven_requirement_id": {"type": "string"},
            "next_unproven_requirement_phase": {"type": "string"},
            "next_unproven_execute_guard_env": {"type": "string"},
            "missing_requirement_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
            "evidence_status_summary": {"type": "object"},
            "next_unproven_requirement": {"type": "object"},
            "ready_for_operator": {"type": "boolean"},
            "checks": {"type": "integer", "minimum": 1},
            "check_names": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string", "minLength": 1},
              "uniqueItems": true
            },
            "operator_sequence_steps": {"type": "integer", "minimum": 5},
            "operator_sequence_modes": {
              "type": "array",
              "minItems": 5,
              "items": {"type": "string", "minLength": 1}
            },
            "operator_sequence_modes_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
            "operator_commands_by_mode_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
            "next_action_run_validated": {"type": "boolean"},
            "next_action_run_mode": {"const": "validation_only"},
            "next_action_run_returncode": {"type": "integer", "enum": [0, 1]},
            "next_action_run_package_id": {"const": "ml_data_governed_acquisition"},
            "next_action_run_wave": {"const": 1},
            "next_action_validation_scope_selected": {"type": "boolean"},
            "next_action_safety_assertions": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "command_validation_only",
                "execute_guard_absent",
                "selected_action_only",
                "no_success_stderr",
                "no_real_operation_evidence",
                "guarded_command_printed",
                "no_real_acquisition_evidence",
                "guarded_would_run_command_printed",
                "data_root_outside_repo"
              ],
              "properties": {
                "command_validation_only": {"type": "boolean"},
                "execute_guard_absent": {"type": "boolean"},
                "selected_action_only": {"type": "boolean"},
                "no_success_stderr": {"type": "boolean"},
                "no_real_operation_evidence": {"type": "boolean"},
                "guarded_command_printed": {"type": "boolean"},
                "no_real_acquisition_evidence": {"type": "boolean"},
                "guarded_would_run_command_printed": {"type": "boolean"},
                "data_root_outside_repo": {"type": "boolean"}
              }
            },
            "next_action_safety_assertions_passed": {"type": "boolean"},
            "ml_lab_standby_guards_unset": {"const": true},
            "ml_lab_standby_required_unset_guard_env": {
              "type": "array",
              "minItems": 8,
              "items": {"type": "string", "minLength": 1},
              "contains": {"const": "TAMANDUA_ALLOW_ML_REAL_ACQUISITION"}
            },
            "ml_lab_standby_enabled_guards": {
              "type": "array",
              "maxItems": 0,
              "items": {"type": "string", "minLength": 1}
            },
            "validation_only_command_count": {"const": 3},
            "guarded_execute_command_count": {"const": 2},
            "guarded_required_env_count": {"const": 2},
            "command_guard_boundary_preserved": {"const": true}
          }
        }
      }
    },
    "authorized_acquisition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transcript_template", "acquisition_command", "acquisition_command_sha256"],
      "properties": {
        "transcript_template": {"type": "string", "pattern": "20260604T-ml-wave1-real-acquisition-transcript\\.template\\.json$"},
        "acquisition_command": {"type": "string", "minLength": 1},
        "acquisition_command_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "safe_to_hand_to_operator": {"type": "boolean"},
    "blockers": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["data_root", "production_manifest", "canonical_dataset_manifest", "launcher", "post_acquisition_refresh_launcher", "publish_launcher"],
      "properties": {
        "data_root": {"type": "string", "minLength": 1},
        "production_manifest": {"type": "string", "minLength": 1},
        "canonical_dataset_manifest": {"type": "string", "minLength": 1},
        "launcher": {"type": "string", "pattern": "wave_1_real_acquisition_launcher\\.ps1$"},
        "post_acquisition_refresh_launcher": {"type": "string", "pattern": "wave_1_post_acquisition_refresh_launcher\\.ps1$"},
        "publish_launcher": {"type": "string", "pattern": "wave_1_manifest_publish_launcher\\.ps1$"}
      }
    },
    "commands": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prelab_validation", "validation_only", "execute", "post_acquisition_refresh", "post_acquisition_publish"],
      "properties": {
        "prelab_validation": {"$ref": "#/$defs/command_with_env"},
        "validation_only": {"$ref": "#/$defs/command"},
        "execute": {"$ref": "#/$defs/command_with_env"},
        "post_acquisition_refresh": {"$ref": "#/$defs/command_with_env"},
        "post_acquisition_publish": {"$ref": "#/$defs/command_with_env"}
      }
    },
    "operator_sequence": {
      "type": "array",
      "minItems": 5,
      "items": {"$ref": "#/$defs/operator_sequence_step"}
    },
    "operator_checklist": {"type": "array", "minItems": 3, "items": {"type": "string", "minLength": 5}},
    "artifact_expectations": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact", "scope", "required_after"],
        "properties": {
          "artifact": {"type": "string", "minLength": 1},
          "scope": {"enum": ["external_lab_only", "repo_no_execution_receipt", "repo_hash_only_manifest"]},
          "required_after": {"enum": ["execute", "post_acquisition_refresh", "post_acquisition_publish"]}
        }
      }
    },
    "forbidden_actions": {"type": "array", "minItems": 3, "items": {"type": "string", "minLength": 5}}
  },
  "$defs": {
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "claim_boundary"],
      "properties": {
        "command": {"type": "string", "minLength": 1},
        "claim_boundary": {"type": "string", "minLength": 10}
      }
    },
    "command_with_env": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_env", "command", "claim_boundary"],
      "properties": {
        "required_env": {"type": "object", "additionalProperties": {"type": "string", "minLength": 1}},
        "command": {"type": "string", "minLength": 1},
        "claim_boundary": {"type": "string", "minLength": 10}
      }
    },
    "operator_sequence_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "mode", "command", "required_env", "claim_boundary"],
      "properties": {
        "step": {"type": "integer", "minimum": 1},
        "mode": {"type": "string", "minLength": 1},
        "required_env": {"type": "object", "additionalProperties": {"type": "string", "minLength": 1}},
        "command": {"type": "string", "minLength": 1},
        "claim_boundary": {"type": "string", "minLength": 10}
      }
    }
  }
}
