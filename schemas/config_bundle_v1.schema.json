{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamandua.local/schemas/config_bundle_v1.schema.json",
  "title": "Tamandua Config Bundle v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["api_version", "kind", "metadata", "contents", "rollout"],
  "properties": {
    "api_version": {
      "const": "tamandua.io/config-bundle/v1"
    },
    "kind": {
      "const": "ConfigBundle"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "owner", "created_at"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]{2,127}$"},
        "version": {"type": "integer", "minimum": 1},
        "owner": {"type": "string", "minLength": 2},
        "created_at": {"type": "string", "format": "date-time"},
        "description": {"type": "string"}
      }
    },
    "contents": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "detection_response_rules": {"type": "array", "items": {"type": "string"}},
        "collector_registry": {"type": "string"},
        "collector_policy": {"type": "string"},
        "response_policy": {"type": "string"},
        "suppressions": {"type": "array", "items": {"type": "string"}},
        "validation_profiles": {"type": "array", "items": {"type": "string"}}
      }
    },
    "rollout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tag", "apply_mode", "promotion_gates", "rollback"],
      "properties": {
        "tag": {"enum": ["canary", "beta", "stable", "pinned", "blocked"]},
        "apply_mode": {"enum": ["dry_run", "approval_required", "disabled"]},
        "target_selectors": {"type": "array", "items": {"type": "string"}},
        "promotion_gates": {"type": "array", "items": {"type": "string"}},
        "rollback": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "previous_bundle_id"],
          "properties": {
            "enabled": {"const": true},
            "previous_bundle_id": {"type": ["string", "null"]},
            "max_unhealthy_minutes": {"type": "integer", "minimum": 1}
          }
        }
      }
    }
  }
}
