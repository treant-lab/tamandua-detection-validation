        "pre_execution_transcript_contract_validation_before_run": {"const": "missing"},
        "pre_execution_transcript_contract_valid_before_run": {"const": false},
        "pre_execution_transcript_contract_missing_before_run": {"const": true},
        "acceptance_intake_transcript_contract_validation": {"enum": ["jsonschema+built-in", "built-in", "missing", "failed"]},
        "acceptance_intake_transcript_contract_valid": {"type": "boolean"},
        "transcript_contract_valid_for_manifest_publish": {"type": "boolean"},
        "wave1_pre_execution_transcript_contract_validation_before_run": {"const": "missing"},
        "wave1_pre_execution_transcript_contract_valid_before_run": {"const": false},
        "wave1_pre_execution_transcript_contract_missing_before_run": {"const": true},
        "wave1_acceptance_intake_transcript_contract_validation": {"enum": ["jsonschema+built-in", "built-in", "missing", "failed"]},
        "wave1_acceptance_intake_transcript_contract_valid": {"type": "boolean"},
        "wave1_transcript_contract_valid_for_manifest_publish": {"type": "boolean"},
        "acquisition_transcript_guarded_run_command_packet_sha256": {"type": "string"},
        "acquisition_transcript_stdout_sha256": {"type": "string"},
        "acquisition_transcript_stderr_sha256": {"type": "string"},
        "manifest_transcript_guarded_run_command_packet_sha256": {"type": "string"},
        "manifest_transcript_stdout_sha256": {"type": "string"},
        "manifest_transcript_stderr_sha256": {"type": "string"},
        "transcript_hashes_match_between_receipts": {"type": "boolean"},
        "transcript_template_ready": {"type": "boolean"},
        "transcript_template_hash_verification_ready": {"type": "boolean"},
        "transcript_capture_contract_ready": {"type": "boolean"},
        "goal_snapshot_anchor_check_passed": {"const": true},
        "guarded_packet_vx_inventory_metadata_only": {"const": true},
        "guarded_packet_vx_samples_allowed_in_training_splits": {"const": false},
        "acquisition_receipt_ready_for_manifest_publish": {"type": "boolean"},
        "manifest_publish_complete": {"type": "boolean"},
        "post_run_receipts_wait_for_real_evidence": {"type": "boolean"},
        "first_unblock_id": {"type": "string", "minLength": 1},
        "first_unblock_target": {"type": "string", "minLength": 1},
        "next_operator_action": {"type": "string", "minLength": 1},
        "operator_path_steps": {"type": "integer", "minimum": 0},
        "execution_packet_operator_sequence_steps": {"type": "integer", "minimum": 5}
