    },
    "vx_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vx_archive_download_guard_env",
        "vx_archive_download_guard_present",
        "vx_download_authorized_by_this_packet",
        "vx_inventory_metadata_only",
        "vx_samples_allowed_in_training_splits",
        "vx_guard_must_remain_unset_for_wave1_acquisition"
      ],
      "properties": {
        "vx_archive_download_guard_env": {"const": "TAMANDUA_ALLOW_VX_UNDERGROUND_DOWNLOAD"},
        "vx_archive_download_guard_present": {"const": false},
        "vx_download_authorized_by_this_packet": {"const": false},
        "vx_inventory_metadata_only": {"const": true},
        "vx_samples_allowed_in_training_splits": {"const": false},
        "vx_guard_must_remain_unset_for_wave1_acquisition": {"const": true}
      }
    },
    "transcript_capture_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "template_ref",
        "output_path",
        "required_before",
        "required_fields",
        "required_fields_sha256",
        "acquisition_command",
        "acquisition_command_sha256",
        "guarded_run_command_packet_ref",
        "hash_verification",
        "log_policy",
        "capture_helper",
        "operator_instruction_count"
      ],
      "properties": {
        "template_ref": {"type": "string", "pattern": "20260604T-ml-wave1-real-acquisition-transcript\\.template\\.json$"},
        "output_path": {"type": "string", "pattern": "20260604T-ml-wave1-real-acquisition-transcript\\.json$"},
        "required_before": {"const": "post_acquisition_refresh"},
        "required_fields": {
          "type": "array",
          "minItems": 20,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "required_fields_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "acquisition_command": {"type": "string", "minLength": 10},
        "acquisition_command_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "guarded_run_command_packet_ref": {"type": "string", "pattern": "20260604T-ml-wave1-guarded-run-command-packet\\.json$"},
        "hash_verification": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "algorithm",
            "hex_format",
            "acquisition_command_encoding",
            "file_fields",
            "required_file_hash_fields",
            "powershell_command_count"
          ],
          "properties": {
            "algorithm": {"const": "SHA256"},
            "hex_format": {"const": "lowercase"},
            "acquisition_command_encoding": {"const": "UTF-8"},
            "file_fields": {
              "type": "object",
              "additionalProperties": false,
              "required": ["launcher_sha256", "guarded_run_command_packet_sha256", "stdout_sha256", "stderr_sha256"],
              "properties": {
                "launcher_sha256": {"type": "string", "pattern": "20260604T-ml-execution-plan\\.handoff.*wave_1_real_acquisition_launcher\\.ps1$"},
                "guarded_run_command_packet_sha256": {"type": "string", "pattern": "20260604T-ml-wave1-guarded-run-command-packet\\.json$"},
                "stdout_sha256": {"type": "string", "pattern": "20260604T-ml-wave1-real-acquisition\\.stdout\\.txt$"},
                "stderr_sha256": {"type": "string", "pattern": "20260604T-ml-wave1-real-acquisition\\.stderr\\.txt$"}
              }
            },
            "required_file_hash_fields": {
              "type": "array",
              "items": {"enum": ["launcher_sha256", "guarded_run_command_packet_sha256", "stderr_sha256", "stdout_sha256"]},
              "minItems": 4,
              "maxItems": 4,
              "uniqueItems": true
            },
            "powershell_command_count": {"type": "integer", "minimum": 5}
          }
        },
        "log_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "published_stdout_ref",
            "published_stderr_ref",
            "published_logs_are_sanitized",
            "hashes_cover_published_sanitized_logs",
            "forbidden_published_log_content_count"
          ],
          "properties": {
            "published_stdout_ref": {"type": "string", "pattern": "20260604T-ml-wave1-real-acquisition\\.stdout\\.txt$"},
            "published_stderr_ref": {"type": "string", "pattern": "20260604T-ml-wave1-real-acquisition\\.stderr\\.txt$"},
            "published_logs_are_sanitized": {"const": true},
            "hashes_cover_published_sanitized_logs": {"const": true},
            "forbidden_published_log_content_count": {"type": "integer", "minimum": 1}
          }
        },
        "capture_helper": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "shell",
            "mode",
            "requires_guard_env",
            "requires_vx_download_guard_unset",
            "published_stdout_ref",
            "published_stderr_ref",
            "command_count",
            "claim_boundary"
          ],
          "properties": {
            "shell": {"const": "powershell"},
            "mode": {"const": "operator_copy_paste"},
            "requires_guard_env": {"const": "TAMANDUA_ALLOW_ML_REAL_ACQUISITION"},
            "requires_vx_download_guard_unset": {"const": "TAMANDUA_ALLOW_VX_UNDERGROUND_DOWNLOAD"},
            "published_stdout_ref": {"type": "string", "pattern": "20260604T-ml-wave1-real-acquisition\\.stdout\\.txt$"},
            "published_stderr_ref": {"type": "string", "pattern": "20260604T-ml-wave1-real-acquisition\\.stderr\\.txt$"},
            "command_count": {"type": "integer", "minimum": 16},
            "claim_boundary": {"type": "string", "pattern": "not executed"}
          }
        },
        "operator_instruction_count": {"type": "integer", "minimum": 8}
      }
    },
    "execution_packet_operator_sequence": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step", "mode", "command", "required_env", "claim_boundary"],
        "properties": {
          "step": {"type": "integer", "minimum": 1},
          "mode": {"type": "string", "minLength": 1},
          "required_env": {"type": "object", "additionalProperties": {"type": "string", "minLength": 1}},
          "command": {"type": "string", "minLength": 1},
          "claim_boundary": {"type": "string", "minLength": 10}
        }
      }
    },
    "operator_path": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step", "artifact", "required_before", "claim_boundary"],
        "properties": {
          "step": {"type": "string", "minLength": 1},
          "artifact": {"type": "string", "minLength": 1},
          "required_before": {"type": "string", "minLength": 1},
          "claim_boundary": {"type": "string", "minLength": 10}
        }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "passed", "detail"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "passed": {"type": "boolean"},
          "detail": {"type": "string"}
        }
      }
    }
  }
