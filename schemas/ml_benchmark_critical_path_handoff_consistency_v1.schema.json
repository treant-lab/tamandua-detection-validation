{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamandua.io/schemas/ml_benchmark_critical_path_handoff_consistency_v1.schema.json",
  "title": "Tamandua ML Benchmark Critical Path Handoff Consistency v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["api_version", "kind", "metadata", "consistent", "blockers", "source_status_summary", "configuration", "summary", "checks"],
  "$defs": {
    "category_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dependency", "artifact", "env", "other"],
      "properties": {
        "dependency": {"type": "integer", "minimum": 0},
        "artifact": {"type": "integer", "minimum": 0},
        "env": {"type": "integer", "minimum": 0},
        "other": {"type": "integer", "minimum": 0}
      }
    }
  },
  "properties": {
    "api_version": {"const": "tamandua.io/ml-benchmark-critical-path-handoff-consistency/v1"},
    "kind": {"const": "MLBenchmarkCriticalPathHandoffConsistency"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_id", "generated_at", "created_by", "claim_boundary"],
      "properties": {
        "report_id": {"type": "string", "minLength": 1},
        "generated_at": {"type": "string", "format": "date-time"},
        "created_by": {"type": "string", "minLength": 1},
        "claim_boundary": {"type": "string", "minLength": 10}
      }
    },
    "consistent": {"type": "boolean"},
    "blockers": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "source_status_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "benchmark_critical_path_validation",
        "benchmark_critical_path_handoff_bundle_validation",
        "critical_path_validated",
        "handoff_bundle_validated",
        "bundle_source_matches_critical_path",
        "all_critical_steps_have_handoffs",
        "no_stale_critical_handoffs",
        "handoff_fields_match_critical_path",
        "handoff_evidence_items_match_critical_path",
        "validation_command_hashes_match",
        "handoff_markdown_matches_manifest",
        "category_rollups_match",
        "upstream_summary_matches",
        "check_count",
        "passed_checks",
        "failed_checks",
        "blocker_count",
        "critical_path_steps",
        "handoff_files",
        "source_mismatches",
        "missing_handoffs",
        "stale_handoffs",
        "field_mismatches",
        "evidence_mismatches",
        "command_hash_mismatches",
        "category_mismatches",
        "content_mismatches",
        "upstream_ready_validation_only",
        "upstream_blocked",
        "critical_path_evidence_usable_for_goal",
        "handoff_evidence_usable_for_goal",
        "pending_by_category",
        "resolved_by_category",
        "consistent",
        "goal_complete",
        "completion_state",
        "goal_missing_requirements",
        "goal_required_evidence_total",
        "goal_present_required_evidence",
        "goal_usable_required_evidence",
        "goal_missing_required_evidence",
        "goal_unusable_present_required_evidence",
        "next_unproven_requirement_id",
        "next_unproven_requirement_phase",
        "next_unproven_execute_guard_env",
        "missing_requirement_ids",
        "evidence_status_summary",
        "next_unproven_requirement"
      ],
      "properties": {
        "benchmark_critical_path_validation": {"type": "string", "pattern": "^(jsonschema\\+built-in|built-in|failed)$"},
        "benchmark_critical_path_handoff_bundle_validation": {"type": "string", "pattern": "^(jsonschema\\+built-in|built-in|failed)$"},
        "critical_path_validated": {"type": "boolean"},
        "handoff_bundle_validated": {"type": "boolean"},
        "bundle_source_matches_critical_path": {"type": "boolean"},
        "all_critical_steps_have_handoffs": {"type": "boolean"},
        "no_stale_critical_handoffs": {"type": "boolean"},
        "handoff_fields_match_critical_path": {"type": "boolean"},
        "handoff_evidence_items_match_critical_path": {"type": "boolean"},
        "validation_command_hashes_match": {"type": "boolean"},
        "handoff_markdown_matches_manifest": {"type": "boolean"},
        "category_rollups_match": {"type": "boolean"},
        "upstream_summary_matches": {"type": "boolean"},
        "check_count": {"type": "integer", "minimum": 0},
        "passed_checks": {"type": "integer", "minimum": 0},
        "failed_checks": {"type": "integer", "minimum": 0},
        "blocker_count": {"type": "integer", "minimum": 0},
        "critical_path_steps": {"type": "integer", "minimum": 0},
        "handoff_files": {"type": "integer", "minimum": 0},
        "source_mismatches": {"type": "integer", "minimum": 0},
        "missing_handoffs": {"type": "integer", "minimum": 0},
        "stale_handoffs": {"type": "integer", "minimum": 0},
        "field_mismatches": {"type": "integer", "minimum": 0},
        "evidence_mismatches": {"type": "integer", "minimum": 0},
        "command_hash_mismatches": {"type": "integer", "minimum": 0},
        "category_mismatches": {"type": "integer", "minimum": 0},
        "content_mismatches": {"type": "integer", "minimum": 0},
        "upstream_ready_validation_only": {"type": "integer", "minimum": 0},
        "upstream_blocked": {"type": "integer", "minimum": 0},
        "critical_path_evidence_usable_for_goal": {"type": "integer", "minimum": 0},
        "handoff_evidence_usable_for_goal": {"type": "integer", "minimum": 0},
        "pending_by_category": {"$ref": "#/$defs/category_counts"},
        "resolved_by_category": {"$ref": "#/$defs/category_counts"},
        "consistent": {"type": "boolean"},
        "goal_complete": {"const": false},
        "completion_state": {"enum": ["not_executed", "partial_evidence"]},
        "goal_missing_requirements": {"const": 9},
        "goal_required_evidence_total": {"type": "integer", "minimum": 1},
        "goal_present_required_evidence": {"type": "integer", "minimum": 0},
        "goal_usable_required_evidence": {"type": "integer", "minimum": 0},
        "goal_missing_required_evidence": {"type": "integer", "minimum": 0},
        "goal_unusable_present_required_evidence": {"type": "integer", "minimum": 0},
        "next_unproven_requirement_id": {"const": "wave1_governed_acquisition"},
        "next_unproven_requirement_phase": {"const": "01-wave1-manifest-publication"},
        "next_unproven_execute_guard_env": {"const": "TAMANDUA_ALLOW_ML_REAL_ACQUISITION"},
        "missing_requirement_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "evidence_status_summary": {"type": "object"},
        "next_unproven_requirement": {"type": "object"}
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["benchmark_critical_path", "benchmark_critical_path_handoff_bundle"],
      "properties": {
        "benchmark_critical_path": {
          "type": "string",
          "anyOf": [
            {"pattern": "20260604T-ml-benchmark-critical-path\\.json$"},
            {"pattern": "20260620T2005Z-ml-benchmark-critical-path-contract-packets\\.json$"}
          ]
        },
        "benchmark_critical_path_handoff_bundle": {
          "type": "string",
          "anyOf": [
            {"pattern": "20260604T-ml-benchmark-critical-path-handoff-bundle\\.json$"},
            {"pattern": "20260620T2015Z-ml-benchmark-critical-path-handoff-bundle-contract-packets\\.json$"}
          ]
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["critical_path_steps", "handoff_files", "source_mismatches", "missing_handoffs", "stale_handoffs", "field_mismatches", "evidence_mismatches", "command_hash_mismatches", "category_mismatches", "content_mismatches", "upstream_ready_validation_only", "upstream_blocked", "critical_path_evidence_usable_for_goal", "handoff_evidence_usable_for_goal", "pending_by_category", "resolved_by_category", "goal_complete", "completion_state", "goal_usable_required_evidence", "goal_required_evidence_total", "next_unproven_requirement_id", "next_unproven_execute_guard_env"],
      "properties": {
        "critical_path_steps": {"type": "integer", "minimum": 0},
        "handoff_files": {"type": "integer", "minimum": 0},
        "source_mismatches": {"type": "integer", "minimum": 0},
        "missing_handoffs": {"type": "integer", "minimum": 0},
        "stale_handoffs": {"type": "integer", "minimum": 0},
        "field_mismatches": {"type": "integer", "minimum": 0},
        "evidence_mismatches": {"type": "integer", "minimum": 0},
        "command_hash_mismatches": {"type": "integer", "minimum": 0},
        "category_mismatches": {"type": "integer", "minimum": 0},
        "content_mismatches": {"type": "integer", "minimum": 0},
        "upstream_ready_validation_only": {"type": "integer", "minimum": 0},
        "upstream_blocked": {"type": "integer", "minimum": 0},
        "critical_path_evidence_usable_for_goal": {"type": "integer", "minimum": 0},
        "handoff_evidence_usable_for_goal": {"type": "integer", "minimum": 0},
        "pending_by_category": {"$ref": "#/$defs/category_counts"},
        "resolved_by_category": {"$ref": "#/$defs/category_counts"},
        "goal_complete": {"const": false},
        "completion_state": {"enum": ["not_executed", "partial_evidence"]},
        "goal_usable_required_evidence": {"type": "integer", "minimum": 0},
        "goal_required_evidence_total": {"type": "integer", "minimum": 1},
        "next_unproven_requirement_id": {"const": "wave1_governed_acquisition"},
        "next_unproven_execute_guard_env": {"const": "TAMANDUA_ALLOW_ML_REAL_ACQUISITION"}
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "passed", "detail"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "passed": {"type": "boolean"},
          "detail": {"type": "string"}
        }
      }
    }
  }
}
