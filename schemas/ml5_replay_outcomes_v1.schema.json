{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamandua.io/schemas/ml5_replay_outcomes_v1.schema.json",
  "title": "Tamandua ML-5 Replay Outcomes v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "api_version",
    "kind",
    "dataset_id",
    "produced_at",
    "created_by",
    "raw_samples_in_artifact",
    "pipeline_trace_ref",
    "model_report_ref",
    "ml_service_report_ref",
    "agent_parity_report_ref",
    "samples",
    "claim_boundary"
  ],
  "properties": {
    "api_version": {"const": "tamandua.io/ml5-replay-outcomes/v1"},
    "kind": {"const": "ML5ReplayOutcomes"},
    "dataset_id": {"type": "string", "minLength": 1},
    "produced_at": {"type": "string", "format": "date-time"},
    "created_by": {"type": "string", "minLength": 2},
    "raw_samples_in_artifact": {"const": false},
    "pipeline_trace_ref": {"type": "string", "minLength": 1},
    "model_report_ref": {"type": "string", "minLength": 1},
    "ml_service_report_ref": {"type": "string", "minLength": 1},
    "agent_parity_report_ref": {"type": "string", "minLength": 1},
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sample_id", "label", "expected_malicious", "deterministic_detected", "ml_detected"],
        "properties": {
          "sample_id": {"type": "string", "minLength": 1},
          "label": {
            "enum": [
              "malware",
              "suspicious",
              "trojan",
              "ransomware",
              "spyware",
              "adware",
              "worm",
              "backdoor",
              "unknown_malware",
              "goodware",
              "benign"
            ]
          },
          "expected_malicious": {"type": "boolean"},
          "deterministic_detected": {"type": "boolean"},
          "ml_detected": {"type": "boolean"},
          "latency_ms": {"type": ["number", "null"], "minimum": 0},
          "alert_created": {"type": ["boolean", "null"]},
          "duplicate_suppressed": {"type": ["boolean", "null"]},
          "trace_id": {"type": ["string", "null"]}
        }
      }
    },
    "claim_boundary": {"type": "string", "minLength": 10}
  }
}
