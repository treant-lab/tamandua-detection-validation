{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamandua.local/schemas/ml_dataset_manifest_v1.schema.json",
  "title": "Tamandua ML Dataset Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "api_version",
    "kind",
    "metadata",
    "storage",
    "sources",
    "splits",
    "samples",
    "quality_gates"
  ],
  "properties": {
    "api_version": {
      "const": "tamandua.io/ml-dataset-manifest/v1"
    },
    "kind": {
      "const": "MLDatasetManifest"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dataset_id",
        "version",
        "created_at",
        "created_by",
        "purpose",
        "claim_boundary"
      ],
      "properties": {
        "dataset_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.-]{2,127}$"
        },
        "version": {
          "type": "string",
          "pattern": "^v?[0-9][a-zA-Z0-9_.-]*$"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "created_by": {
          "type": "string",
          "minLength": 2
        },
        "purpose": {
          "enum": ["smoke", "parity", "training", "validation", "test", "holdout", "false_positive_review"]
        },
        "description": {
          "type": "string"
        },
        "claim_boundary": {
          "type": "string",
          "minLength": 10
        },
        "git_commit": {
          "type": "string"
        }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["raw_samples_in_git", "raw_sample_storage", "manifest_path"],
      "properties": {
        "raw_samples_in_git": {
          "const": false
        },
        "raw_sample_storage": {
          "type": "string",
          "minLength": 1
        },
        "manifest_path": {
          "type": "string",
          "minLength": 1
        },
        "dvc_remote": {
          "type": ["string", "null"]
        },
        "retention_policy": {
          "type": "string"
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_id", "source_type", "role", "acquired_at"],
        "properties": {
          "source_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]{2,127}$"
          },
          "source_type": {
            "enum": [
              "malwarebazaar",
              "goodware_system",
              "malimg",
              "malevis",
              "virustotal",
              "virusshare",
              "hybrid_analysis",
              "vx_underground",
              "internal_telemetry",
              "synthetic",
              "other"
            ]
          },
          "role": {
            "enum": ["malware", "goodware", "enrichment", "holdout", "synthetic", "mixed"]
          },
          "url": {
            "type": ["string", "null"]
          },
          "acquisition_command": {
            "type": ["string", "null"]
          },
          "acquired_at": {
            "type": "string",
            "format": "date-time"
          },
          "operator": {
            "type": "string"
          },
          "isolated_lab_required": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "splits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "ratios"],
      "properties": {
        "strategy": {
          "enum": ["none", "random", "stratified_family", "time_based", "source_holdout", "manual"]
        },
        "seed": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "ratios": {
          "type": "object",
          "additionalProperties": false,
          "required": ["train", "validation", "test", "holdout"],
          "properties": {
            "train": {"type": "number", "minimum": 0, "maximum": 1},
            "validation": {"type": "number", "minimum": 0, "maximum": 1},
            "test": {"type": "number", "minimum": 0, "maximum": 1},
            "holdout": {"type": "number", "minimum": 0, "maximum": 1}
          }
        }
      }
    },
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sample_id",
          "sha256",
          "label",
          "label_source",
          "source_id",
          "split",
          "storage_ref"
        ],
        "properties": {
          "sample_id": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "sha1": {
            "type": ["string", "null"],
            "pattern": "^[a-fA-F0-9]{40}$"
          },
          "md5": {
            "type": ["string", "null"],
            "pattern": "^[a-fA-F0-9]{32}$"
          },
          "label": {
            "enum": ["malware", "goodware", "unknown", "suspicious"]
          },
          "label_source": {
            "enum": ["malwarebazaar", "virustotal", "hybrid_analysis", "analyst", "signed_goodware", "synthetic", "unknown", "other"]
          },
          "label_confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "family": {
            "type": ["string", "null"]
          },
          "source_id": {
            "type": "string",
            "minLength": 1
          },
          "split": {
            "enum": ["train", "validation", "test", "holdout", "smoke", "parity"]
          },
          "file_type": {
            "enum": ["pe", "elf", "macho", "script", "archive", "unknown"]
          },
          "size_bytes": {
            "type": ["integer", "null"],
            "minimum": 0
          },
          "storage_ref": {
            "type": "string",
            "minLength": 1
          },
          "raw_malware": {
            "type": "boolean"
          },
          "tags": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "quality_gates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "checks"],
      "properties": {
        "status": {
          "enum": ["pass", "fail", "not_run", "partial"]
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "status"],
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "status": {"enum": ["pass", "fail", "not_run", "warning"]},
              "details": {"type": "string"}
            }
          }
        }
      }
    }
  }
}
