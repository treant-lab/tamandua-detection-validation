{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamandua.io/schemas/ml_wave1_manifest_publish_receipt_v1.schema.json",
  "title": "Tamandua ML Wave 1 Manifest Publish Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["api_version", "kind", "metadata", "manifest_publish_complete", "blockers", "source_status_summary", "vx_policy", "configuration", "summary", "checks", "next_required_action"],
  "properties": {
    "api_version": {"const": "tamandua.io/ml-wave1-manifest-publish-receipt/v1"},
    "kind": {"const": "MLWave1ManifestPublishReceipt"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_id", "generated_at", "created_by", "claim_boundary"],
      "properties": {
        "report_id": {"type": "string", "minLength": 1},
        "generated_at": {"type": "string", "minLength": 1},
        "created_by": {"type": "string", "minLength": 1},
        "claim_boundary": {"type": "string", "minLength": 1}
      }
    },
    "manifest_publish_complete": {"type": "boolean"},
    "blockers": {"type": "array", "items": {"type": "string"}},
    "source_status_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest_publish_complete",
        "receipt_ready_for_publish",
        "acquisition_transcript_present",
        "acquisition_transcript_valid",
        "acquisition_transcript_validation",
        "acquisition_transcript_execute_succeeded",
        "acquisition_transcript_guarded_run_command_packet_ref",
        "acquisition_transcript_acquisition_command_sha256",
        "acquisition_transcript_guarded_run_command_packet_sha256",
        "acquisition_transcript_stdout_sha256",
        "acquisition_transcript_stderr_sha256",
        "acquisition_transcript_vx_policy_valid",
        "acquisition_transcript_vx_inventory_metadata_only",
        "acquisition_transcript_vx_samples_in_training_splits",
        "acquisition_transcript_vx_archive_download_guard_env",
        "acquisition_transcript_vx_archive_download_guard_must_be_unset",
        "acquisition_receipt_expected_vx_policy_valid",
        "expected_vx_inventory_ref",
        "expected_vx_inventory_metadata_only",
        "expected_vx_samples_in_training_splits",
        "expected_vx_archive_download_guard_env",
        "expected_vx_archive_download_guard_must_be_unset",
        "production_manifest_exists",
        "production_manifest_shape_valid",
        "production_manifest_sha256",
        "canonical_dataset_manifest_exists",
        "canonical_dataset_manifest_valid",
        "canonical_dataset_manifest_sha256",
        "canonical_manifest_raw_samples_not_in_git",
        "canonical_manifest_raw_sample_storage_external",
        "canonical_manifest_storage_refs_external",
        "canonical_manifest_storage_refs_match_expected_layout",
        "external_sample_count",
        "canonical_sample_count",
        "external_split_counts",
        "canonical_split_counts",
        "check_count",
        "passed_checks",
        "failed_checks",
        "blocker_count",
        "blockers",
        "next_required_action"
      ],
      "properties": {
        "manifest_publish_complete": {"type": "boolean"},
        "receipt_ready_for_publish": {"type": "boolean"},
        "acquisition_transcript_present": {"type": "boolean"},
        "acquisition_transcript_valid": {"type": "boolean"},
        "acquisition_transcript_validation": {"enum": ["jsonschema+built-in", "built-in", "missing", "failed"]},
        "acquisition_transcript_execute_succeeded": {"type": "boolean"},
        "acquisition_transcript_guarded_run_command_packet_ref": {"type": "string"},
        "acquisition_transcript_acquisition_command_sha256": {"type": "string"},
        "acquisition_transcript_guarded_run_command_packet_sha256": {"type": "string"},
        "acquisition_transcript_stdout_sha256": {"type": "string"},
        "acquisition_transcript_stderr_sha256": {"type": "string"},
        "acquisition_transcript_vx_policy_valid": {"type": "boolean"},
        "acquisition_transcript_vx_inventory_metadata_only": {"type": "boolean"},
        "acquisition_transcript_vx_samples_in_training_splits": {"type": ["boolean", "null"]},
        "acquisition_transcript_vx_archive_download_guard_env": {"type": "string"},
        "acquisition_transcript_vx_archive_download_guard_must_be_unset": {"type": "boolean"},
        "acquisition_receipt_expected_vx_policy_valid": {"type": "boolean"},
        "expected_vx_inventory_ref": {"const": "docs\\benchmarks\\runs\\ml-vx-inthewild-inventory.json"},
        "expected_vx_inventory_metadata_only": {"const": true},
        "expected_vx_samples_in_training_splits": {"const": false},
        "expected_vx_archive_download_guard_env": {"const": "TAMANDUA_ALLOW_VX_UNDERGROUND_DOWNLOAD"},
        "expected_vx_archive_download_guard_must_be_unset": {"const": true},
        "production_manifest_exists": {"type": "boolean"},
        "production_manifest_shape_valid": {"type": "boolean"},
        "production_manifest_sha256": {"type": "string", "pattern": "^$|^[a-f0-9]{64}$"},
        "canonical_dataset_manifest_exists": {"type": "boolean"},
        "canonical_dataset_manifest_valid": {"type": "boolean"},
        "canonical_dataset_manifest_sha256": {"type": "string", "pattern": "^$|^[a-f0-9]{64}$"},
        "canonical_manifest_raw_samples_not_in_git": {"type": "boolean"},
        "canonical_manifest_raw_sample_storage_external": {"type": "boolean"},
        "canonical_manifest_storage_refs_external": {"type": "boolean"},
        "canonical_manifest_storage_refs_match_expected_layout": {"type": "boolean"},
        "external_sample_count": {"type": "integer", "minimum": 0},
        "canonical_sample_count": {"type": "integer", "minimum": 0},
        "external_split_counts": {"$ref": "#/$defs/split_counts"},
        "canonical_split_counts": {"$ref": "#/$defs/split_counts"},
        "check_count": {"type": "integer", "minimum": 0},
        "passed_checks": {"type": "integer", "minimum": 0},
        "failed_checks": {"type": "integer", "minimum": 0},
        "blocker_count": {"type": "integer", "minimum": 0},
        "blockers": {"type": "array", "items": {"type": "string"}},
        "goal_complete": {"const": false},
        "next_unproven_requirement_id": {"type": "string", "minLength": 1},
        "next_required_action": {"type": "string", "minLength": 1}
      }
    },
    "vx_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vx_inventory_ref",
        "vx_inventory_metadata_only",
        "vx_samples_in_training_splits",
        "vx_archive_download_guard_env",
        "vx_archive_download_guard_must_be_unset",
        "operator_note"
      ],
      "properties": {
        "vx_inventory_ref": {"const": "docs\\benchmarks\\runs\\ml-vx-inthewild-inventory.json"},
        "vx_inventory_metadata_only": {"const": true},
        "vx_samples_in_training_splits": {"const": false},
        "vx_archive_download_guard_env": {"const": "TAMANDUA_ALLOW_VX_UNDERGROUND_DOWNLOAD"},
        "vx_archive_download_guard_must_be_unset": {"const": true},
        "operator_note": {"type": "string", "minLength": 40}
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["acquisition_receipt", "production_manifest", "production_manifest_sha256", "canonical_dataset_manifest", "canonical_dataset_manifest_sha256", "publish_guard_env", "publish_command", "publish_command_sha256"],
      "properties": {
        "acquisition_receipt": {"type": "string", "minLength": 1},
        "production_manifest": {"type": "string", "minLength": 1},
        "production_manifest_sha256": {"type": "string", "pattern": "^$|^[a-f0-9]{64}$"},
        "canonical_dataset_manifest": {"type": "string", "minLength": 1},
        "canonical_dataset_manifest_sha256": {"type": "string", "pattern": "^$|^[a-f0-9]{64}$"},
        "publish_guard_env": {"const": "TAMANDUA_ALLOW_ML_MANIFEST_PUBLISH"},
        "publish_command": {"type": "string", "minLength": 1},
        "publish_command_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "external_sample_count",
        "canonical_sample_count",
        "external_split_counts",
        "canonical_split_counts",
        "production_manifest_sha256",
        "canonical_dataset_manifest_sha256",
        "receipt_ready_for_publish",
        "acquisition_transcript_present",
        "acquisition_transcript_valid",
        "acquisition_transcript_execute_succeeded",
        "acquisition_transcript_vx_policy_valid",
        "acquisition_transcript_vx_samples_in_training_splits",
        "acquisition_receipt_expected_vx_policy_valid"
      ],
      "properties": {
        "external_sample_count": {"type": "integer", "minimum": 0},
        "canonical_sample_count": {"type": "integer", "minimum": 0},
        "external_split_counts": {"$ref": "#/$defs/split_counts"},
        "canonical_split_counts": {"$ref": "#/$defs/split_counts"},
        "production_manifest_sha256": {"type": "string", "pattern": "^$|^[a-f0-9]{64}$"},
        "canonical_dataset_manifest_sha256": {"type": "string", "pattern": "^$|^[a-f0-9]{64}$"},
        "receipt_ready_for_publish": {"type": "boolean"},
        "acquisition_transcript_present": {"type": "boolean"},
        "acquisition_transcript_valid": {"type": "boolean"},
        "acquisition_transcript_execute_succeeded": {"type": "boolean"},
        "acquisition_transcript_vx_policy_valid": {"type": "boolean"},
        "acquisition_transcript_vx_samples_in_training_splits": {"type": ["boolean", "null"]},
        "acquisition_receipt_expected_vx_policy_valid": {"type": "boolean"}
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "passed", "detail"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "passed": {"type": "boolean"},
          "detail": {"type": "string"}
        }
      }
    },
    "next_required_action": {"type": "string", "minLength": 1}
  },
  "$defs": {
    "split_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["train", "validation", "test"],
      "properties": {
        "train": {"type": "integer", "minimum": 0},
        "validation": {"type": "integer", "minimum": 0},
        "test": {"type": "integer", "minimum": 0}
      }
    }
  }
}
