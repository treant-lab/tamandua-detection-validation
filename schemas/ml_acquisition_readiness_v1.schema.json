{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamandua.io/schemas/ml_acquisition_readiness_v1.schema.json",
  "title": "Tamandua ML Acquisition Readiness Probe v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "api_version",
    "kind",
    "metadata",
    "source_status_summary",
    "vx_policy",
    "configuration",
    "passed",
    "checks"
  ],
  "properties": {
    "api_version": {"const": "tamandua.io/ml-acquisition-readiness/v1"},
    "kind": {"const": "MLAcquisitionReadinessProbe"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_id", "generated_at", "created_by", "claim_boundary"],
      "properties": {
        "report_id": {"type": "string", "minLength": 1},
        "generated_at": {"type": "string", "format": "date-time"},
        "created_by": {"type": "string", "minLength": 1},
        "claim_boundary": {"type": "string", "minLength": 10}
      }
    },
    "source_status_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "data_root_set",
        "data_root_outside_repo",
        "production_dir_writeable",
        "raw_dir_writeable",
        "free_space_gib",
        "min_free_gib",
        "free_space_meets_minimum",
        "acquisition_dry_run_exists",
        "dry_run_contract_shape_valid",
        "dry_run_output_matches_data_root",
        "dry_run_safety_no_downloads",
        "dry_run_vx_policy_metadata_only_boundary",
        "vx_inventory_ref",
        "vx_inventory_metadata_only",
        "vx_samples_in_training_splits",
        "vx_archive_download_guard_env",
        "vx_archive_download_guard_must_be_unset",
        "vx_inventory_metadata_present",
        "vx_inventory_contract_shape_valid",
        "status_next_action_is_acquisition",
        "production_manifest_absent_before_real_run",
        "acquisition_guard_absent_before_real_run",
        "manifest_publish_guard_absent_before_real_run",
        "malware_bazaar_auth_key_env",
        "malware_bazaar_auth_key_present",
        "real_acquisition_transcript_absent_before_real_run",
        "canonical_dataset_manifest_absent_before_real_run",
        "check_count",
        "passed_checks",
        "failed_checks",
        "passed"
      ],
      "properties": {
        "data_root_set": {"type": "boolean"},
        "data_root_outside_repo": {"type": "boolean"},
        "production_dir_writeable": {"type": "boolean"},
        "raw_dir_writeable": {"type": "boolean"},
        "free_space_gib": {"type": "number", "minimum": 0},
        "min_free_gib": {"type": "integer", "minimum": 0},
        "free_space_meets_minimum": {"type": "boolean"},
        "acquisition_dry_run_exists": {"type": "boolean"},
        "dry_run_contract_shape_valid": {"type": "boolean"},
        "dry_run_output_matches_data_root": {"type": "boolean"},
        "dry_run_safety_no_downloads": {"type": "boolean"},
        "dry_run_vx_policy_metadata_only_boundary": {"type": "boolean"},
        "vx_inventory_ref": {"type": "string", "minLength": 1},
        "vx_inventory_metadata_only": {"const": true},
        "vx_samples_in_training_splits": {"const": false},
        "vx_archive_download_guard_env": {"const": "TAMANDUA_ALLOW_VX_UNDERGROUND_DOWNLOAD"},
        "vx_archive_download_guard_must_be_unset": {"const": true},
        "vx_inventory_metadata_present": {"type": "boolean"},
        "vx_inventory_contract_shape_valid": {"type": "boolean"},
        "status_next_action_is_acquisition": {"type": "boolean"},
        "production_manifest_absent_before_real_run": {"type": "boolean"},
        "acquisition_guard_absent_before_real_run": {"type": "boolean"},
        "manifest_publish_guard_absent_before_real_run": {"type": "boolean"},
        "malware_bazaar_auth_key_env": {"const": "TAMANDUA_MALWAREBAZAAR_AUTH_KEY"},
        "malware_bazaar_auth_key_present": {"type": "boolean"},
        "real_acquisition_transcript_absent_before_real_run": {"type": "boolean"},
        "canonical_dataset_manifest_absent_before_real_run": {"type": "boolean"},
        "check_count": {"type": "integer", "minimum": 0},
        "passed_checks": {"type": "integer", "minimum": 0},
        "failed_checks": {"type": "integer", "minimum": 0},
        "passed": {"type": "boolean"}
      }
    },
    "vx_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vx_inventory_ref",
        "vx_inventory_metadata_only",
        "vx_samples_in_training_splits",
        "vx_archive_download_guard_env",
        "vx_archive_download_guard_must_be_unset",
        "operator_note"
      ],
      "properties": {
        "vx_inventory_ref": {"type": "string", "minLength": 1},
        "vx_inventory_metadata_only": {"const": true},
        "vx_samples_in_training_splits": {"const": false},
        "vx_archive_download_guard_env": {"const": "TAMANDUA_ALLOW_VX_UNDERGROUND_DOWNLOAD"},
        "vx_archive_download_guard_must_be_unset": {"const": true},
        "operator_note": {"type": "string", "minLength": 20}
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "data_root",
        "production_dir",
        "raw_dir",
        "dry_run_ref",
        "vx_inventory_ref",
        "execution_status_ref",
        "real_acquisition_guard_env",
        "manifest_publish_guard_env",
        "malware_bazaar_auth_key_env",
        "real_acquisition_transcript",
        "canonical_dataset_manifest",
        "min_free_gib"
      ],
      "properties": {
        "data_root": {"type": "string", "minLength": 1},
        "production_dir": {"type": "string", "minLength": 1},
        "raw_dir": {"type": "string", "minLength": 1},
        "dry_run_ref": {"type": "string", "minLength": 1},
        "vx_inventory_ref": {"type": "string", "minLength": 1},
        "execution_status_ref": {"type": "string", "minLength": 1},
        "real_acquisition_guard_env": {"const": "TAMANDUA_ALLOW_ML_REAL_ACQUISITION"},
        "manifest_publish_guard_env": {"const": "TAMANDUA_ALLOW_ML_MANIFEST_PUBLISH"},
        "malware_bazaar_auth_key_env": {"const": "TAMANDUA_MALWAREBAZAAR_AUTH_KEY"},
        "real_acquisition_transcript": {
          "type": "string",
          "pattern": "20260604T-ml-wave1-real-acquisition-transcript\\.json$"
        },
        "canonical_dataset_manifest": {
          "type": "string",
          "pattern": "ml-prod-candidate-v1-dataset-manifest\\.json$"
        },
        "min_free_gib": {"type": "integer", "minimum": 0}
      }
    },
    "passed": {"type": "boolean"},
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["name", "passed", "detail"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "passed": {"type": "boolean"},
          "detail": {"type": "string"}
        }
      }
    }
  }
}
