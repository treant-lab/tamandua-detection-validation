{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamandua.io/schemas/ml_benchmark_handoff_consistency_v1.schema.json",
  "title": "Tamandua ML Benchmark Handoff Consistency v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["api_version", "kind", "metadata", "consistent", "blockers", "source_status_summary", "configuration", "summary", "checks"],
  "properties": {
    "api_version": {"const": "tamandua.io/ml-benchmark-handoff-consistency/v1"},
    "kind": {"const": "MLBenchmarkHandoffConsistency"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_id", "generated_at", "created_by", "claim_boundary"],
      "properties": {
        "report_id": {"type": "string", "minLength": 1},
        "generated_at": {"type": "string", "format": "date-time"},
        "created_by": {"type": "string", "minLength": 1},
        "claim_boundary": {"type": "string", "minLength": 10}
      }
    },
    "consistent": {"type": "boolean"},
    "blockers": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "source_status_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "benchmark_matrix_validation",
        "benchmark_handoff_bundle_validation",
        "matrix_validated",
        "bundle_validated",
        "bundle_source_matches_matrix",
        "lane_ids_match",
        "lane_status_scope_and_guard_match",
        "lane_evidence_usability_match",
        "handoff_content_matches_lanes",
        "lane_guarded_command_fingerprints_match",
        "no_orphan_handoff_files",
        "status_rollups_match",
        "upstream_parallel_summary_matches",
        "goal_snapshot_matches_matrix",
        "passed_checks",
        "failed_checks",
        "check_count",
        "blocker_count",
        "matrix_lanes",
        "handoff_lane_files",
        "source_mismatches",
        "orphan_handoff_files",
        "fingerprint_mismatches",
        "ready_validation_only",
        "blocked",
        "evidence_exists",
        "matrix_evidence_usable_for_goal",
        "handoff_evidence_usable_for_goal",
        "upstream_ready_validation_only",
        "upstream_blocked",
        "goal_complete",
        "completion_state",
        "goal_usable_required_evidence",
        "goal_required_evidence_total",
        "next_unproven_requirement_id",
        "next_unproven_execute_guard_env",
        "consistent"
      ],
      "properties": {
        "benchmark_matrix_validation": {"type": "string", "pattern": "^(jsonschema\\+built-in|built-in|failed)$"},
        "benchmark_handoff_bundle_validation": {"type": "string", "pattern": "^(jsonschema\\+built-in|built-in|failed)$"},
        "matrix_validated": {"type": "boolean"},
        "bundle_validated": {"type": "boolean"},
        "bundle_source_matches_matrix": {"type": "boolean"},
        "lane_ids_match": {"type": "boolean"},
        "lane_status_scope_and_guard_match": {"type": "boolean"},
        "lane_evidence_usability_match": {"type": "boolean"},
        "handoff_content_matches_lanes": {"type": "boolean"},
        "lane_guarded_command_fingerprints_match": {"type": "boolean"},
        "no_orphan_handoff_files": {"type": "boolean"},
        "status_rollups_match": {"type": "boolean"},
        "upstream_parallel_summary_matches": {"type": "boolean"},
        "goal_snapshot_matches_matrix": {"type": "boolean"},
        "passed_checks": {"type": "integer", "minimum": 0},
        "failed_checks": {"type": "integer", "minimum": 0},
        "check_count": {"type": "integer", "minimum": 0},
        "blocker_count": {"type": "integer", "minimum": 0},
        "matrix_lanes": {"type": "integer", "minimum": 0},
        "handoff_lane_files": {"type": "integer", "minimum": 0},
        "source_mismatches": {"type": "integer", "minimum": 0},
        "orphan_handoff_files": {"type": "integer", "minimum": 0},
        "fingerprint_mismatches": {"type": "integer", "minimum": 0},
        "ready_validation_only": {"type": "integer", "minimum": 0},
        "blocked": {"type": "integer", "minimum": 0},
        "evidence_exists": {"type": "integer", "minimum": 0},
        "matrix_evidence_usable_for_goal": {"type": "integer", "minimum": 0},
        "handoff_evidence_usable_for_goal": {"type": "integer", "minimum": 0},
        "upstream_ready_validation_only": {"type": "integer", "minimum": 0},
        "upstream_blocked": {"type": "integer", "minimum": 0},
        "goal_complete": {"type": "boolean"},
        "completion_state": {"enum": ["partial_evidence", "complete"]},
        "goal_usable_required_evidence": {"type": "integer", "minimum": 0},
        "goal_required_evidence_total": {"type": "integer", "minimum": 0},
        "next_unproven_requirement_id": {"type": "string", "minLength": 1},
        "next_unproven_execute_guard_env": {"type": "string", "minLength": 1},
        "consistent": {"type": "boolean"}
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["benchmark_execution_matrix", "benchmark_handoff_bundle"],
      "properties": {
        "benchmark_execution_matrix": {"type": "string", "pattern": "20260604T-ml-benchmark-execution-matrix\\.json$"},
        "benchmark_handoff_bundle": {"type": "string", "pattern": "20260604T-ml-benchmark-handoff-bundle\\.json$"}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "matrix_lanes",
        "handoff_lane_files",
        "source_mismatches",
        "orphan_handoff_files",
        "fingerprint_mismatches",
        "ready_validation_only",
        "blocked",
        "evidence_exists",
        "matrix_evidence_usable_for_goal",
        "handoff_evidence_usable_for_goal",
        "upstream_ready_validation_only",
        "upstream_blocked",
        "goal_complete",
        "completion_state",
        "goal_usable_required_evidence",
        "goal_required_evidence_total",
        "next_unproven_requirement_id",
        "next_unproven_execute_guard_env"
      ],
      "properties": {
        "matrix_lanes": {"type": "integer", "minimum": 0},
        "handoff_lane_files": {"type": "integer", "minimum": 0},
        "source_mismatches": {"type": "integer", "minimum": 0},
        "orphan_handoff_files": {"type": "integer", "minimum": 0},
        "fingerprint_mismatches": {"type": "integer", "minimum": 0},
        "ready_validation_only": {"type": "integer", "minimum": 0},
        "blocked": {"type": "integer", "minimum": 0},
        "evidence_exists": {"type": "integer", "minimum": 0},
        "matrix_evidence_usable_for_goal": {"type": "integer", "minimum": 0},
        "handoff_evidence_usable_for_goal": {"type": "integer", "minimum": 0},
        "upstream_ready_validation_only": {"type": "integer", "minimum": 0},
        "upstream_blocked": {"type": "integer", "minimum": 0},
        "goal_complete": {"type": "boolean"},
        "completion_state": {"enum": ["partial_evidence", "complete"]},
        "goal_usable_required_evidence": {"type": "integer", "minimum": 0},
        "goal_required_evidence_total": {"type": "integer", "minimum": 0},
        "next_unproven_requirement_id": {"type": "string", "minLength": 1},
        "next_unproven_execute_guard_env": {"type": "string", "minLength": 1}
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "passed", "detail"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "passed": {"type": "boolean"},
          "detail": {"type": "string"}
        }
      }
    }
  }
}
