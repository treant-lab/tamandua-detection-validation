{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamandua.io/schemas/ml_unblock_validation_status_consistency_v1.schema.json",
  "title": "Tamandua ML Unblock Validation Status Consistency v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["api_version", "kind", "metadata", "consistent", "blockers", "source_status_summary", "configuration", "summary", "checks"],
  "properties": {
    "api_version": {"const": "tamandua.io/ml-unblock-validation-status-consistency/v1"},
    "kind": {"const": "MLUnblockValidationStatusConsistency"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_id", "generated_at", "created_by", "claim_boundary"],
      "properties": {
        "report_id": {"type": "string", "minLength": 1},
        "generated_at": {"type": "string", "format": "date-time"},
        "created_by": {"type": "string", "minLength": 1},
        "claim_boundary": {"type": "string", "minLength": 10}
      }
    },
    "consistent": {"type": "boolean"},
    "blockers": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "source_status_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unblock_queue_validation",
        "unblock_validation_status_validation",
        "platform_readiness_audit_validation",
        "unblock_queue_valid",
        "unblock_validation_status_valid",
        "platform_readiness_audit_valid",
        "status_source_matches_queue",
        "status_source_matches_platform_audit",
        "all_queue_items_have_status",
        "no_stale_status_items",
        "readiness_links_match_queue",
        "active_readiness_blockers_match_audit",
        "upstream_summary_matches",
        "status_preserves_handoff_coverage",
        "status_preserves_blocked_no_command_counts",
        "status_preserves_resolution_command_counts",
        "goal_snapshot_matches_sources",
        "check_count",
        "passed_checks",
        "failed_checks",
        "blocker_count",
        "queue_items",
        "status_items",
        "pending_by_category",
        "resolved_by_category",
        "source_mismatches",
        "missing_status_items",
        "stale_status_items",
        "readiness_blocker_links",
        "active_readiness_blockers_expected",
        "active_readiness_blockers_reported",
        "mismatched_active_readiness_items",
        "upstream_ready_validation_only",
        "upstream_blocked",
        "missing_handoff_ids",
        "items_from_blocked_claims",
        "items_without_command_exposure",
        "items_with_resolution_command_exposure",
        "items_without_resolution_command_exposure",
        "handoff_items_from_blocked_claims",
        "handoff_items_without_command_exposure",
        "handoff_items_with_resolution_command_exposure",
        "handoff_items_without_resolution_command_exposure",
        "goal_complete",
        "completion_state",
        "goal_usable_required_evidence",
        "goal_required_evidence_total",
        "next_unproven_requirement_id",
        "next_unproven_execute_guard_env",
        "consistent"
      ],
      "properties": {
        "unblock_queue_validation": {"enum": ["jsonschema+built-in", "built-in", "invalid"]},
        "unblock_validation_status_validation": {"enum": ["jsonschema+built-in", "built-in", "invalid"]},
        "platform_readiness_audit_validation": {"enum": ["jsonschema+built-in", "built-in", "invalid"]},
        "unblock_queue_valid": {"type": "boolean"},
        "unblock_validation_status_valid": {"type": "boolean"},
        "platform_readiness_audit_valid": {"type": "boolean"},
        "status_source_matches_queue": {"type": "boolean"},
        "status_source_matches_platform_audit": {"type": "boolean"},
        "all_queue_items_have_status": {"type": "boolean"},
        "no_stale_status_items": {"type": "boolean"},
        "readiness_links_match_queue": {"type": "boolean"},
        "active_readiness_blockers_match_audit": {"type": "boolean"},
        "upstream_summary_matches": {"type": "boolean"},
        "status_preserves_handoff_coverage": {"type": "boolean"},
        "status_preserves_blocked_no_command_counts": {"type": "boolean"},
        "status_preserves_resolution_command_counts": {"type": "boolean"},
        "goal_snapshot_matches_sources": {"type": "boolean"},
        "check_count": {"type": "integer", "minimum": 0},
        "passed_checks": {"type": "integer", "minimum": 0},
        "failed_checks": {"type": "integer", "minimum": 0},
        "blocker_count": {"type": "integer", "minimum": 0},
        "queue_items": {"type": "integer", "minimum": 0},
        "status_items": {"type": "integer", "minimum": 0},
        "pending_by_category": {"$ref": "#/$defs/category_counts"},
        "resolved_by_category": {"$ref": "#/$defs/category_counts"},
        "source_mismatches": {"type": "integer", "minimum": 0},
        "missing_status_items": {"type": "integer", "minimum": 0},
        "stale_status_items": {"type": "integer", "minimum": 0},
        "readiness_blocker_links": {"type": "integer", "minimum": 0},
        "active_readiness_blockers_expected": {"type": "integer", "minimum": 0},
        "active_readiness_blockers_reported": {"type": "integer", "minimum": 0},
        "mismatched_active_readiness_items": {"type": "integer", "minimum": 0},
        "upstream_ready_validation_only": {"type": "integer", "minimum": 0},
        "upstream_blocked": {"type": "integer", "minimum": 0},
        "missing_handoff_ids": {"type": "integer", "minimum": 0},
        "items_from_blocked_claims": {"type": "integer", "minimum": 0},
        "items_without_command_exposure": {"type": "integer", "minimum": 0},
        "items_with_resolution_command_exposure": {"type": "integer", "minimum": 0},
        "items_without_resolution_command_exposure": {"type": "integer", "minimum": 0},
        "handoff_items_from_blocked_claims": {"type": "integer", "minimum": 0},
        "handoff_items_without_command_exposure": {"type": "integer", "minimum": 0},
        "handoff_items_with_resolution_command_exposure": {"type": "integer", "minimum": 0},
        "handoff_items_without_resolution_command_exposure": {"type": "integer", "minimum": 0},
        "goal_complete": {"type": "boolean"},
        "completion_state": {"enum": ["not_executed", "partial_evidence", "complete", "unknown"]},
        "goal_usable_required_evidence": {"type": "integer", "minimum": 0},
        "goal_required_evidence_total": {"type": "integer", "minimum": 0},
        "next_unproven_requirement_id": {"type": "string", "minLength": 1},
        "next_unproven_execute_guard_env": {"type": "string", "minLength": 1},
        "consistent": {"type": "boolean"}
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unblock_queue", "unblock_validation_status", "platform_readiness_audit"],
      "properties": {
        "unblock_queue": {"type": "string", "pattern": "20260604T-ml-unblock-queue\\.json$"},
        "unblock_validation_status": {"type": "string", "pattern": "20260604T-ml-unblock-validation-status\\.json$"},
        "platform_readiness_audit": {"type": "string", "pattern": "20260604T-ml-platform-readiness-audit\\.json$"}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["queue_items", "status_items", "pending_by_category", "resolved_by_category", "source_mismatches", "missing_status_items", "stale_status_items", "readiness_blocker_links", "active_readiness_blockers_expected", "active_readiness_blockers_reported", "mismatched_active_readiness_items", "upstream_ready_validation_only", "upstream_blocked", "missing_handoff_ids", "items_from_blocked_claims", "items_without_command_exposure", "items_with_resolution_command_exposure", "items_without_resolution_command_exposure", "handoff_items_from_blocked_claims", "handoff_items_without_command_exposure", "handoff_items_with_resolution_command_exposure", "handoff_items_without_resolution_command_exposure", "goal_complete", "completion_state", "goal_usable_required_evidence", "goal_required_evidence_total", "next_unproven_requirement_id", "next_unproven_execute_guard_env"],
      "properties": {
        "queue_items": {"type": "integer", "minimum": 0},
        "status_items": {"type": "integer", "minimum": 0},
        "pending_by_category": {"$ref": "#/$defs/category_counts"},
        "resolved_by_category": {"$ref": "#/$defs/category_counts"},
        "source_mismatches": {"type": "integer", "minimum": 0},
        "missing_status_items": {"type": "integer", "minimum": 0},
        "stale_status_items": {"type": "integer", "minimum": 0},
        "readiness_blocker_links": {"type": "integer", "minimum": 0},
        "active_readiness_blockers_expected": {"type": "integer", "minimum": 0},
        "active_readiness_blockers_reported": {"type": "integer", "minimum": 0},
        "mismatched_active_readiness_items": {"type": "integer", "minimum": 0},
        "upstream_ready_validation_only": {"type": "integer", "minimum": 0},
        "upstream_blocked": {"type": "integer", "minimum": 0},
        "missing_handoff_ids": {"type": "integer", "minimum": 0},
        "items_from_blocked_claims": {"type": "integer", "minimum": 0},
        "items_without_command_exposure": {"type": "integer", "minimum": 0},
        "items_with_resolution_command_exposure": {"type": "integer", "minimum": 0},
        "items_without_resolution_command_exposure": {"type": "integer", "minimum": 0},
        "handoff_items_from_blocked_claims": {"type": "integer", "minimum": 0},
        "handoff_items_without_command_exposure": {"type": "integer", "minimum": 0},
        "handoff_items_with_resolution_command_exposure": {"type": "integer", "minimum": 0},
        "handoff_items_without_resolution_command_exposure": {"type": "integer", "minimum": 0},
        "goal_complete": {"type": "boolean"},
        "completion_state": {"enum": ["not_executed", "partial_evidence", "complete", "unknown"]},
        "goal_usable_required_evidence": {"type": "integer", "minimum": 0},
        "goal_required_evidence_total": {"type": "integer", "minimum": 0},
        "next_unproven_requirement_id": {"type": "string", "minLength": 1},
        "next_unproven_execute_guard_env": {"type": "string", "minLength": 1}
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "passed", "detail"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "passed": {"type": "boolean"},
          "detail": {"type": "string"}
        }
      }
    }
  },
  "$defs": {
    "category_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dependency", "artifact", "env", "other"],
      "properties": {
        "dependency": {"type": "integer", "minimum": 0},
        "artifact": {"type": "integer", "minimum": 0},
        "env": {"type": "integer", "minimum": 0},
        "other": {"type": "integer", "minimum": 0}
      }
    }
  }
}
