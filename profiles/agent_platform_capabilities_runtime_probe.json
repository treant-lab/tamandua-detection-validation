{
  "schema_version": 1,
  "profile_id": "agent-platform-capabilities-runtime-probe",
  "name": "Agent Platform Capabilities Runtime Probe",
  "description": "Local Analyst UX/API probe that validates online healthy agents are shown as runtime-reported for basic capabilities without falsely claiming observed collector telemetry.",
  "platform": "multi",
  "default_observation_seconds": 0,
  "benchmark_lane": "analyst-ux",
  "execution": {
    "type": "local_probe",
    "command": "python tools\\detection_validation\\agent_platform_capabilities_runtime_probe.py",
    "timeout_seconds": 180,
    "runtime_effect": "none",
    "requires_agent": false,
    "requires_server": false,
    "requires_database": false
  },
  "quality_bar": {
    "purpose": "agent_platform_capabilities_runtime",
    "requires_persisted_events": false,
    "requires_driver_health": false,
    "max_unknown_source_events": 0,
    "max_unexpected_high_critical": 0,
    "max_driver_channel_drops": 0,
    "max_driver_kernel_drops": 0
  },
  "claim_boundary": "Local source and unit-test contract only. Does not prove the deployed server is updated or that endpoint collectors emitted telemetry.",
  "tests": [
    {
      "id": "agent-capabilities-runtime-source-contract",
      "name": "PlatformCapabilities reports online healthy runtime without claiming observed telemetry",
      "executor": "agent_platform_capabilities_runtime_probe",
      "expected_telemetry": [
        "local_source_and_unit_probe"
      ],
      "expected_fields": [
        "online_runtime",
        "reported",
        "not_observed"
      ]
    },
    {
      "id": "agent-capabilities-api-serialization-contract",
      "name": "Agent API serialization passes effective status and health into platform capability derivation",
      "executor": "agent_platform_capabilities_runtime_probe",
      "expected_telemetry": [
        "local_source_and_unit_probe"
      ],
      "expected_fields": [
        "status",
        "health"
      ]
    },
    {
      "id": "agent-capabilities-unit-contract",
      "name": "Elixir unit contract covers online reported and offline not_observed semantics",
      "executor": "agent_platform_capabilities_runtime_probe",
      "expected_telemetry": [
        "local_source_and_unit_probe"
      ],
      "expected_fields": [
        "unit_tests",
        "online_reported",
        "offline_not_observed"
      ]
    }
  ]
}
