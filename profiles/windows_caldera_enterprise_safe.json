{
  "schema_version": 1,
  "profile_id": "windows-caldera-enterprise-safe",
  "name": "Windows CALDERA Enterprise Safe",
  "description": "Broad CALDERA-backed enterprise benchmark profile for safe adversary emulation. This profile intentionally raises the bar beyond telemetry coverage: suspicious chains require detections, actionable alerts, investigation fields, and timeline correlations. Abilities must be safe: no credential dumping, destructive encryption, firewall isolation, real data exfiltration, or irreversible persistence.",
  "platform": "windows",
  "default_observation_seconds": 150,
  "adapter_status": "experimental",
  "benchmark_lane": "caldera-upstream",
  "quality_bar": {
    "purpose": "caldera_enterprise_safe",
    "requires_driver_health": true,
    "requires_persisted_events": true,
    "max_unknown_source_events": 0,
    "max_unexpected_high_critical": 0,
    "max_driver_channel_drops": 0,
    "max_driver_kernel_drops": 0
  },
  "coverage_model": {
    "visibility": "Every operation must produce persisted process telemetry with source attribution.",
    "analytics": "Suspicious operations require expected_detections and expected_alerts; low-risk discovery can remain telemetry-only.",
    "storyline": "Process, parent, command line, file, registry, DNS, and network evidence must be present when relevant.",
    "noise": "Safe discovery and setup activity must not emit unexpected high/critical events.",
    "response": "This profile validates detection readiness. Response actions are covered by windows_response_validation_safe_v1."
  },
  "tests": [
