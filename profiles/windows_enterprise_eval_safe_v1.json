      "id": "eval-T1047-wmi-execution",
      "name": "WMI Execution/Discovery",
      "executor": "atomic_or_command",
      "atomic": {
        "technique": "T1047",
        "test_numbers": [
          1
        ]
      },
      "precondition_command": "cmd.exe /d /c \"if exist %SystemRoot%\\System32\\wbem\\wmic.exe (exit /b 0) else exit /b 2\"",
      "precondition_timeout_seconds": 45,
      "precondition_error_code": "wmi_cli_unavailable_on_target",
      "fallback_command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"$wmic = Join-Path $env:SystemRoot 'System32\\wbem\\wmic.exe'; $p = Start-Process -FilePath $wmic -ArgumentList @('process','list','brief') -WindowStyle Hidden -PassThru; if (-not $p.WaitForExit(20)) { Stop-Process -Id $p.Id -Force -ErrorAction SilentlyContinue; exit 124 }; exit $p.ExitCode\"",
      "expected_telemetry": [
        "process_create"
      ],
      "tags": [
        "enterprise-eval-safe",
        "tactic:execution",
        "mitre:T1047"
