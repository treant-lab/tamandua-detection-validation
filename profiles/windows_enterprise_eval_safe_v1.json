{
  "schema_version": 1,
  "profile_id": "windows-enterprise-eval-safe-v1",
  "name": "Windows Enterprise Evaluation Safe v1",
  "description": "Safe enterprise-style endpoint evaluation profile modeled after ATT&CK evaluation outcomes: broad tactic coverage, investigative context, low noise, deterministic fallback commands, and readiness for Atomic/CALDERA upstream lanes. It avoids credential dumping, LSASS access, destructive encryption, firewall isolation, and irreversible persistence.",
  "platform": "windows",
  "default_observation_seconds": 90,
  "quality_bar": {
    "purpose": "enterprise_eval_safe",
    "requires_driver_health": true,
    "requires_persisted_events": true,
    "max_unknown_source_events": 0,
    "max_unexpected_high_critical": 0,
    "max_driver_channel_drops": 0,
    "max_driver_kernel_drops": 0
  },
  "coverage_model": {
    "visibility": "Expected telemetry must be persisted with source attribution.",
    "analytics": "Expected detections/alerts are required only where the behavior is unambiguously suspicious.",
    "storyline": "Process, parent, command line, file, registry, DNS, and network fields are required when relevant.",
    "noise": "Low-risk tests must not emit unexpected high/critical events.",
    "upstream": "Atomic/CALDERA-backed runs should use --require-upstream; fallback runs remain valid for regression only."
  },
  "tests": [
