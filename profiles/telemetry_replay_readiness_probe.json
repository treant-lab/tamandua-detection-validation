{
  "schema_version": 1,
  "profile_id": "telemetry-replay-readiness-probe",
  "name": "Telemetry Replay Readiness Probe",
  "description": "Executed non-destructive Roadmap P probe that validates sanitized replay fixture files and emits benchmark artifacts for replay/regression readiness. This does not execute historical server replay or mutate live alerts.",
  "platform": "multi",
  "default_observation_seconds": 0,
  "benchmark_lane": "telemetry-replay",
  "quality_bar": {
    "purpose": "telemetry_replay_readiness_probe",
    "requires_persisted_events": false,
    "requires_driver_health": false,
    "max_unknown_source_events": 0,
    "max_unexpected_high_critical": 0,
    "max_driver_channel_drops": 0,
    "max_driver_kernel_drops": 0
  },
  "claim_boundary": "Sanitized replay fixture/schema readiness proof only. Full Roadmap P still requires a replay executor that validates normalization, detection, alert context, correlation/storyline, and retrospective-only result persistence without mutating live alerts.",
  "tests": [
    {
      "id": "replay-fixture-schema-macos-false-positive-replay-v1",
      "name": "Replay fixture schema valid: macos_false_positive_replay_v1.json",
      "executor": "telemetry_replay_readiness_probe",
      "expected_telemetry": ["replay_fixture_schema"],
      "expected_fields": ["path", "fixture_id", "fixture_count", "claim_boundary"]
    },
    {
      "id": "replay-fixture-schema-roadmap-k-n-s-t-contracts-v1",
      "name": "Replay fixture schema valid: roadmap_k_n_s_t_contracts_v1.json",
      "executor": "telemetry_replay_readiness_probe",
      "expected_telemetry": ["replay_fixture_schema"],
      "expected_fields": ["path", "fixture_id", "lane_count", "claim_boundary"]
    },
    {
      "id": "replay-fixture-schema-windows-false-positive-replay-v1",
      "name": "Replay fixture schema valid: windows_false_positive_replay_v1.json",
      "executor": "telemetry_replay_readiness_probe",
      "expected_telemetry": ["replay_fixture_schema"],
      "expected_fields": ["path", "fixture_id", "fixture_count", "claim_boundary"]
    },
    {
      "id": "replay-fixture-platform-coverage",
      "name": "Replay fixture set includes Windows FP, macOS FP, and roadmap contract fixtures",
      "executor": "telemetry_replay_readiness_probe",
      "expected_telemetry": ["replay_fixture_schema"],
      "expected_fields": ["fixture_files", "has_windows_fp_fixture", "has_macos_fp_fixture", "has_roadmap_contract_fixture"]
    }
  ]
}
