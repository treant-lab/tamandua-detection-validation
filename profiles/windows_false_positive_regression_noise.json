{
  "schema_version": 1,
  "profile_id": "windows-false-positive-regression-noise",
  "name": "Windows False Positive Regression Noise",
  "description": "Benign Windows workloads that previously produced noisy high/critical alerts. This profile gates alert severity calibration, not attack coverage.",
  "platform": "windows",
  "default_observation_seconds": 90,
  "benchmark_lane": "enterprise-eval",
  "quality_bar": {
    "purpose": "false_positive_regression_noise",
    "requires_persisted_events": true,
    "max_unknown_source_events": 0,
    "max_unexpected_high_critical": 0,
    "requires_driver_health": false,
    "max_driver_channel_drops": 0,
    "max_driver_kernel_drops": 0
  },
  "claim_boundary": "Benign/noise regression only. Passing this profile supports severity calibration claims, not detection coverage claims.",
  "tests": [
    {
      "id": "fp-edgeupdate-scheduled-updater",
      "name": "Microsoft Edge scheduled updater should not remain high/critical",
      "executor": "command",
      "fallback_command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -EncodedCommand ",
      "validation_category": "benign-noise",
      "expected_telemetry": [
        "process_create"
      ],
      "optional_telemetry": [
        "network_connect",
        "dns_query",
        "file_create",
        "file_modify"
      ],
      "expected_fields": [
        "agent_id",
        "hostname",
        "process_name",
        "command_line",
        "parent_process_name"
      ],
      "expected_detections": [],
      "expected_alerts": [],
      "tags": [
        "benign",
        "noise-regression",
        "edgeupdate",
        "etw",
        "mitre:T1562.006"
      ],
      "risk": "low"
    },
    {
      "id": "fp-systemdrive-system32-processes",
