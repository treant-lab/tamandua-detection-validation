    {
      "id": "T1027-certutil-encode-safe",
      "name": "Obfuscated Files or Information Certutil Encode Safe",
      "executor": "command",
      "fallback_command": "cmd.exe /d /c \"echo tamandua>%TEMP%\\tamandua-certutil.txt & certutil.exe -encode %TEMP%\\tamandua-certutil.txt %TEMP%\\tamandua-certutil.b64 > nul & ping -n 3 127.0.0.1 > nul & del /f /q %TEMP%\\tamandua-certutil.txt %TEMP%\\tamandua-certutil.b64\"",
      "expected_telemetry": ["process_create"],
      "optional_telemetry": ["file_create", "file_modify", "file_delete"],
      "expected_fields": ["agent_id", "hostname", "process_name", "command_line", "path"],
      "tags": ["atomic", "defense-evasion", "obfuscation", "mitre:T1027"],
      "risk": "low"
    },
