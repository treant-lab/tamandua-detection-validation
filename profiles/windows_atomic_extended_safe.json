    {
      "id": "T1547.001-run-key-hkcu-safe",
      "name": "Registry Run Key Persistence Safe",
      "executor": "atomic_or_command",
      "atomic": {"technique": "T1547.001", "test_numbers": [1], "direct_command": "cmd.exe /d /c \"reg add HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Run /v TamanduaBenchRunKey /t REG_SZ /d tamandua /f & ping -n 8 127.0.0.1 > nul & reg delete HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Run /v TamanduaBenchRunKey /f\""},
      "fallback_command": "cmd.exe /d /c \"reg add HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Run /v TamanduaBenchRunKey /t REG_SZ /d tamandua /f & ping -n 8 127.0.0.1 > nul & reg delete HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Run /v TamanduaBenchRunKey /f\"",
      "expected_telemetry": ["process_create"],
      "optional_telemetry": ["registry_set_value"],
      "expected_fields": ["agent_id", "hostname", "process_name", "command_line"],
      "tags": ["atomic", "persistence", "registry", "driver-registry", "mitre:T1547.001"],
      "risk": "medium"
    },
