{
  "schema_version": 1,
  "profile_id": "windows-atomic-extended-safe",
  "name": "Windows Atomic Extended Safe",
  "description": "Expanded low-risk Atomic-style Windows validation across discovery, execution, persistence-safe, defense evasion simulation, collection, and network telemetry. Commands are designed for lab use with cleanup and without credential dumping, LSASS access, firewall isolation, ransomware encryption, or destructive actions.",
  "platform": "windows",
  "default_observation_seconds": 75,
  "quality_bar": {
    "purpose": "atomic_extended_safe",
    "requires_driver_health": true,
    "requires_persisted_events": true,
    "max_unknown_source_events": 0,
    "max_unexpected_high_critical": 0,
    "max_driver_channel_drops": 0,
    "max_driver_kernel_drops": 0
  },
  "tests": [
    {
      "id": "T1033-whoami-user-discovery",
      "name": "System Owner/User Discovery",
      "executor": "atomic_or_command",
      "atomic": {"technique": "T1033", "test_numbers": [1], "direct_command": "cmd.exe /d /c \"whoami /all & ping -n 5 127.0.0.1 > nul & tasklist\""},
      "fallback_command": "cmd.exe /d /c \"whoami\"",
      "expected_telemetry": ["process_create"],
      "expected_fields": ["agent_id", "hostname", "process_name", "command_line"],
      "tags": ["atomic", "discovery", "identity", "mitre:T1033"],
      "risk": "low"
    },
    {
      "id": "T1082-systeminfo-discovery",
      "name": "System Information Discovery",
      "executor": "atomic_or_command",
      "atomic": {"technique": "T1082", "test_numbers": [7], "direct_command": "cmd.exe /d /c \"hostname & ver & ping -n 5 127.0.0.1 > nul & ipconfig /all\""},
      "fallback_command": "cmd.exe /d /c \"%SystemRoot%\\System32\\wbem\\wmic.exe computersystem get domain,manufacturer,model,name /format:list\"",
      "expected_telemetry": ["process_create"],
      "expected_fields": ["agent_id", "hostname", "process_name", "command_line"],
      "tags": ["atomic", "discovery", "host", "mitre:T1082"],
      "risk": "low"
    },
    {
      "id": "T1057-process-discovery",
      "name": "Process Discovery",
      "executor": "atomic_or_command",
      "atomic": {"technique": "T1057", "test_numbers": [2], "direct_command": "cmd.exe /d /c tasklist"},
      "fallback_command": "cmd.exe /d /c \"tasklist /FI \\\"PID eq 4\\\"\"",
      "expected_telemetry": ["process_create"],
      "expected_fields": ["agent_id", "hostname", "process_name", "command_line"],
      "tags": ["atomic", "discovery", "process", "mitre:T1057"],
