{
  "schema_version": 1,
  "profile_id": "macos-backend-readiness-probe",
  "name": "macOS Backend Readiness Probe",
  "description": "Non-destructive Roadmap E probe that checks tamandua-ctl inventory for an online, healthy, fresh macOS agent before backend-backed P0 sensor smoke execution.",
  "platform": "macos",
  "default_observation_seconds": 0,
  "benchmark_lane": "claim-boundary",
  "execution": {
    "type": "local_probe",
    "command": "python tools\\detection_validation\\macos_backend_readiness_probe.py",
    "runtime_effect": "none",
    "requires_agent": false,
    "requires_server": true,
    "requires_database": false
  },
  "quality_bar": {
    "purpose": "macos_backend_readiness_probe",
    "requires_persisted_events": false,
    "requires_driver_health": false,
    "max_unknown_source_events": 0,
    "max_unexpected_high_critical": 0,
    "max_driver_channel_drops": 0,
    "max_driver_kernel_drops": 0
  },
  "claim_boundary": "Backend-readiness only. Passing this profile does not execute macOS P0 sensor smoke and does not prove endpoint telemetry coverage.",
  "tests": [
    {
      "id": "macos-backend-agent-row-present",
      "name": "At least one macOS agent row exists in backend inventory",
      "executor": "macos_backend_readiness_probe",
      "expected_telemetry": ["agent_inventory"],
      "expected_fields": ["id", "hostname", "os_type", "status"]
    },
    {
      "id": "macos-backend-agent-online-healthy",
      "name": "At least one macOS agent is online and healthy",
      "executor": "macos_backend_readiness_probe",
      "expected_telemetry": ["agent_inventory"],
      "expected_fields": ["status", "health"]
    },
    {
      "id": "macos-backend-agent-fresh",
      "name": "At least one macOS agent has a fresh heartbeat",
      "executor": "macos_backend_readiness_probe",
      "expected_telemetry": ["agent_inventory"],
      "expected_fields": ["last_seen", "last_seen_age_seconds"]
    },
    {
      "id": "macos-backend-endpoint-telemetry-capability",
      "name": "At least one fresh macOS agent advertises endpoint telemetry capability",
      "executor": "macos_backend_readiness_probe",
      "expected_telemetry": ["agent_inventory"],
      "expected_fields": ["platform_capabilities"]
    }
  ]
}
