{
  "schema_version": 1,
  "profile_id": "platform-capabilities-static-api-probe",
  "name": "Platform Capabilities Static/API Probe",
  "description": "Executed non-destructive Roadmap K probe for source/API readiness across FIM, inventory, compliance, and SIEM/export. This is stronger than the report-only contract, but does not claim live endpoint baselines, inventory freshness, compliance posture, or SIEM delivery acknowledgement.",
  "platform": "multi",
  "default_observation_seconds": 0,
  "benchmark_lane": "platform-capability",
  "quality_bar": {
    "purpose": "platform_capabilities_static_api_probe",
    "requires_persisted_events": false,
    "requires_driver_health": false,
    "max_unknown_source_events": 0,
    "max_unexpected_high_critical": 0,
    "max_driver_channel_drops": 0,
    "max_driver_kernel_drops": 0
  },
  "claim_boundary": "Static source/API readiness proof only. Full Roadmap K still requires executed endpoint FIM baseline/change proof, normalized inventory freshness, compliance control evidence, and SIEM delivery acknowledgement.",
